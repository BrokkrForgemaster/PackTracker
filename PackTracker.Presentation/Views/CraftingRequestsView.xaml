<UserControl x:Class="PackTracker.Presentation.Views.CraftingRequestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:behaviors="clr-namespace:PackTracker.Presentation.Behaviors"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:controls="clr-namespace:PackTracker.Presentation.Controls"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:NullToInverseVisibilityConverter x:Key="NullToInverseVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource OpHeaderBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="CRAFTING REQUESTS"
                               Foreground="{StaticResource OpTextTitleBrush}"
                               FontSize="22"
                               FontWeight="Bold" />
                    <TextBlock Text="Track requested blueprint work, assigned crafters, and delivery objectives across House Wolf."
                               Foreground="{StaticResource OpTextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="REFRESH"
                            Command="{Binding RefreshCommand}"
                            Padding="16,8"
                            FontWeight="Bold"
                            Background="#24374A"
                            Foreground="#E8F0F8"
                            BorderBrush="#4F6A84"
                            BorderThickness="1" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource OpPanelBorderStyle}">
                <DockPanel Margin="12">
                    <TextBlock Text="OPEN QUEUE"
                               DockPanel.Dock="Top"
                               Foreground="{StaticResource OpTextMutedBrush}"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,0,0,10" />

                    <ListBox ItemsSource="{Binding Requests}"
                             SelectedItem="{Binding SelectedRequest, Mode=TwoWay}"
                             Style="{StaticResource OpListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource OpItemBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding BlueprintName}"
                                                   Foreground="{StaticResource OpTextTitleBrush}"
                                                   FontWeight="Bold"
                                                   FontSize="14" />

                                        <TextBlock Text="{Binding RequesterDisplayName}"
                                                   Foreground="{StaticResource OpTextSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0" />

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Border Background="#1D3A1D"
                                                    BorderBrush="#3A6E3A"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Padding="8,2">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#6FD46F"
                                                           FontWeight="Bold"
                                                           FontSize="10" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource OpPanelBorderStyle}">
                <Grid>
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="24"
                                Visibility="{Binding SelectedRequest, Converter={StaticResource NullToInverseVisibilityConverter}}">
                        <TextBlock Text="SELECT A REQUEST"
                                   Foreground="#B9A07D"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />

                        <TextBlock Text="Choose a request from the queue to view details and manage assignments."
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="12"
                                   Margin="0,8,0,0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Width="300" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <!-- Details state -->
                        <Grid Margin="18"
                              Visibility="{Binding SelectedRequest, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="1"
                                    Style="{StaticResource OpItemBorderStyle}"
                                    Margin="0,16,0,0"
                                    Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="REQUEST DETAILS"
                                                   Foreground="{StaticResource OpTextMutedBrush}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,14" />

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Requester"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.RequesterDisplayName}"
                                                       Foreground="{StaticResource OpTextTitleBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Crafter"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.AssignedCrafterUsername, TargetNullValue=Unassigned}"
                                                       Foreground="{StaticResource OpTextTitleBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Quantity"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.QuantityRequested}"
                                                       Foreground="{StaticResource OpTextTitleBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Min Quality"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.MinimumQuality}"
                                                       Foreground="{StaticResource OpTextTitleBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Submitted"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.CreatedAtLocalDisplay}"
                                                       Foreground="{StaticResource OpTextSecondaryBrush}"
                                                       FontSize="13" />
                                        </Grid>

                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Requester Time"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.RequesterCreatedAtDisplay}"
                                                       Foreground="{StaticResource OpTextSecondaryBrush}"
                                                       FontSize="13"
                                                       TextWrapping="Wrap" />
                                        </Grid>

                                        <TextBlock Text="ACTIONS"
                                                   Foreground="{StaticResource OpTextMutedBrush}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Margin="0,10,0,10" />

                                        <WrapPanel>
                                            <Button Content="ASSIGN TO ME"
                                                    Command="{Binding AssignToSelfCommand}"
                                                    Visibility="{Binding CanAssign, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Margin="0,0,8,8"
                                                    Padding="12,6"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Background="#2B4E2E"
                                                    Foreground="#EEF6EE"
                                                    BorderBrush="#5C8B5E"
                                                    BorderThickness="1" />

                                            <Button Content="MARK IN PROGRESS"
                                                    Command="{Binding MarkInProgressCommand}"
                                                    Visibility="{Binding CanMarkInProgress, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Margin="0,0,8,8"
                                                    Padding="12,6"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Background="#5A3A14"
                                                    Foreground="#F8E9D4"
                                                    BorderBrush="#A36E2F"
                                                    BorderThickness="1" />

                                            <Button Content="MARK COMPLETED"
                                                    Command="{Binding MarkCompletedCommand}"
                                                    Visibility="{Binding CanMarkCompleted, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Margin="0,0,8,8"
                                                    Padding="12,6"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Background="#24374A"
                                                    Foreground="#E8F0F8"
                                                    BorderBrush="#4F6A84"
                                                    BorderThickness="1" />

                                            <Button Content="REMOVE REQUEST"
                                                    Command="{Binding CancelCommand}"
                                                    Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Margin="0,0,0,8"
                                                    Padding="12,6"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Background="#8B1A0F"
                                                    Foreground="#F4EBDD"
                                                    BorderBrush="#B15B34"
                                                    BorderThickness="1" />
                                        </WrapPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="LOGISTICS"
                                                   Foreground="{StaticResource OpTextMutedBrush}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,14" />

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Delivery"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.DeliveryLocation, TargetNullValue=Not specified}"
                                                       Foreground="{StaticResource OpTextTitleBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Reward"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.RewardOffered, TargetNullValue=None}"
                                                       Foreground="{StaticResource OpTextAccentBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Materials"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.MaterialSupplyMode, TargetNullValue=Negotiable}"
                                                       Foreground="{StaticResource OpTextTitleBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <Grid Margin="0,0,0,10"
                                              Visibility="{Binding SelectedRequest.Notes, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Notes"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.Notes}"
                                                       Foreground="{StaticResource OpTextSecondaryBrush}"
                                                       FontSize="13"
                                                       TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,0,0,10"
                                              Visibility="{Binding SelectedRequest.RefusalReason, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Refusal Reason"
                                                       Foreground="#E84040"
                                                       FontSize="13" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedRequest.RefusalReason}"
                                                       Foreground="#E84040"
                                                       FontSize="13"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource OpItemBorderStyle}"
                                    Margin="0,12,0,0"
                                    Padding="20"
                                    Visibility="{Binding RequiredMaterials.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="RECIPE MATERIALS"
                                               Foreground="{StaticResource OpTextMutedBrush}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12" />

                                    <ItemsControl ItemsSource="{Binding RequiredMaterials}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate
                                                xmlns:models="clr-namespace:PackTracker.Application.DTOs.Request;assembly=PackTracker.Application">
                                                <Border Background="#1A1A1A"
                                                        BorderBrush="#2D2D2D"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="12,8"
                                                        Margin="0,0,0,6"
                                                        Visibility="{Binding QuantityRequired, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{Binding MaterialName}"
                                                                   Foreground="{StaticResource OpTextTitleBrush}"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   VerticalAlignment="Center" />

                                                        <TextBlock Grid.Column="1"
                                                                   Foreground="{StaticResource OpTextAccentBrush}"
                                                                   FontSize="13"
                                                                   Margin="16,0"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="{Binding QuantityRequired}" />
                                                            <Run Text=" " />
                                                            <Run Text="{Binding Unit}" />
                                                        </TextBlock>

                                                        <Button Grid.Column="2"
                                                                Content="REQUEST PROCUREMENT"
                                                                Command="{Binding DataContext.RequestMaterialCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="12,4"
                                                                FontSize="11"
                                                                FontWeight="Bold"
                                                                Background="#1D2B3D"
                                                                Foreground="#E8F0F8"
                                                                BorderBrush="#3D5A7A"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="3" Margin="0,18,0,0" MinHeight="400">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="320" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource OpPanelBorderStyle}">
                                    <DockPanel Margin="16">
                                        <TextBlock Text="COMMENTS / LOG"
                                                   DockPanel.Dock="Top"
                                                   Foreground="{StaticResource OpTextMutedBrush}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,12" />

                                        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox Text="{Binding NewCommentText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource OpTextBoxStyle}"
                                                     Tag="Type a comment..."
                                                     Padding="10,8" />

                                            <Button Grid.Column="1"
                                                    Content="POST"
                                                    Command="{Binding AddCommentCommand}"
                                                    Padding="20,0"
                                                    Margin="8,0,0,0"
                                                    Background="#24374A"
                                                    Foreground="#E8F0F8"
                                                    BorderBrush="#4F6A84"
                                                    BorderThickness="1" />
                                        </Grid>

                                        <ListBox ItemsSource="{Binding Comments}"
                                                 behaviors:AutoScrollBehavior.AutoScrollSource="{Binding Comments}"
                                                 Style="{StaticResource OpListBoxStyle}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 HorizontalContentAlignment="Stretch">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="10"
                                                            Background="#1A1A1A"
                                                            CornerRadius="4">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding AuthorUsername}"
                                                                           Foreground="{StaticResource OpTextAccentBrush}"
                                                                           FontWeight="Bold"
                                                                           FontSize="12"
                                                                           DockPanel.Dock="Left" />
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:HH:mm}}"
                                                                           Foreground="{StaticResource OpTextMutedBrush}"
                                                                           FontSize="10"
                                                                           DockPanel.Dock="Right"
                                                                           VerticalAlignment="Center" />
                                                            </DockPanel>

                                                            <controls:MarkdownTextBlock Markdown="{Binding Content}"
                                                                       Foreground="{StaticResource OpTextPrimaryBrush}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,4,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource OpPanelBorderStyle}">
                                    <DockPanel Margin="16">
                                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                            <TextBlock Text="LIVE CHAT"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="Direct channel with the crafter"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="10"
                                                       Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding LiveChatStatusText}"
                                                       FontSize="11"
                                                       Margin="0,6,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLiveChatCounterpartOnline}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource OpTextAccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox Text="{Binding LiveChatInput, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource OpTextBoxStyle}"
                                                     Tag="Message..."
                                                     Padding="10,8">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Return"
                                                                Command="{Binding SendLiveChatCommand}" />
                                                </TextBox.InputBindings>
                                            </TextBox>

                                            <Button Grid.Column="1"
                                                    Content="SEND"
                                                    Command="{Binding SendLiveChatCommand}"
                                                    Padding="14,0"
                                                    Margin="8,0,0,0"
                                                    Background="#3A2B4E"
                                                    Foreground="#E8D8FF"
                                                    BorderBrush="#6A4F8B"
                                                    BorderThickness="1" />
                                        </Grid>

                                        <ListBox ItemsSource="{Binding LiveChat}"
                                                 behaviors:AutoScrollBehavior.AutoScrollSource="{Binding LiveChat}"
                                                 Style="{StaticResource OpListBoxStyle}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 HorizontalContentAlignment="Stretch">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1,0,0">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#0CFFFFFF"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsOwnMessage}" Value="True">
                                                                        <Setter Property="ContextMenu">
                                                                            <Setter.Value>
                                                                                <ContextMenu>
                                                                                    <MenuItem Header="Edit" Command="{Binding BeginEditCommand}"/>
                                                                                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}"/>
                                                                                </ContextMenu>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding CanDelete}" Value="True"/>
                                                                            <Condition Binding="{Binding IsOwnMessage}" Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="ContextMenu">
                                                                            <Setter.Value>
                                                                                <ContextMenu>
                                                                                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}"/>
                                                                                </ContextMenu>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                                                Background="#3A2B4E" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                            <Grid>
                                                                <TextBlock Text="{Binding InitialLetter}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           FontWeight="Bold" FontSize="12" Foreground="#B090E0"
                                                                           Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                                <Image Source="{Binding AvatarImage}" Width="32" Height="32" Stretch="UniformToFill"
                                                                       Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}">
                                                                    <Image.Clip>
                                                                        <EllipseGeometry Center="16,16" RadiusX="16" RadiusY="16"/>
                                                                    </Image.Clip>
                                                                </Image>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="4,4,8,4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding SenderDisplayName}" FontWeight="SemiBold" FontSize="12"
                                                                           Foreground="#B090E0"/>
                                                                <TextBlock Text="{Binding FormattedTime}" FontSize="9"
                                                                           Foreground="{StaticResource OpTextMutedBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <controls:MarkdownTextBlock Markdown="{Binding Content}" FontSize="12"
                                                                                        Foreground="{StaticResource OpTextPrimaryBrush}"
                                                                                        TextWrapping="Wrap" Margin="0,2,0,0" LineHeight="18"
                                                                                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                            <Grid Margin="0,3,0,0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0" Text="{Binding EditDraft, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource OpTextBoxStyle}" Padding="6,4" FontSize="11">
                                                                    <TextBox.InputBindings>
                                                                        <KeyBinding Key="Return" Command="{Binding ConfirmEditCommand}"/>
                                                                        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}"/>
                                                                    </TextBox.InputBindings>
                                                                </TextBox>
                                                                <Button Grid.Column="1" Content="Save" Command="{Binding ConfirmEditCommand}"
                                                                        Margin="4,0,0,0" Padding="8,3" FontSize="10"
                                                                        Background="#2A3A2A" Foreground="#AAD4AA" BorderBrush="#5C8B5E" BorderThickness="1"/>
                                                                <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelEditCommand}"
                                                                        Margin="4,0,0,0" Padding="8,3" FontSize="10"
                                                                        Background="#2A211B" Foreground="{StaticResource OpTextMutedBrush}"
                                                                        BorderBrush="{StaticResource OpBorderItemBrush}" BorderThickness="1"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource OpHeaderBorderStyle}"
                Margin="0,16,0,0"
                Padding="12,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource OpTextAccentBrush}"
                       FontSize="12"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
