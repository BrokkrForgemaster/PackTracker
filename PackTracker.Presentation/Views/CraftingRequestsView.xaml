<UserControl x:Class="PackTracker.Presentation.Views.CraftingRequestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Style="{StaticResource OpHeaderBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CRAFTING REQUESTS" Foreground="{StaticResource OpTextTitleBrush}" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Track requested blueprint work, assigned crafters, and delivery objectives across House Wolf."
                               Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="REFRESH"
                            Command="{Binding RefreshCommand}"
                            Padding="16,8" FontWeight="Bold"
                            Background="#24374A" Foreground="#E8F0F8"
                            BorderBrush="#4F6A84" BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left Panel: Open Queue ── -->
            <Border Grid.Column="0" Style="{StaticResource OpPanelBorderStyle}">
                <DockPanel Margin="12">
                    <TextBlock Text="OPEN QUEUE" DockPanel.Dock="Top" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding Requests}"
                             SelectedItem="{Binding SelectedRequest, Mode=TwoWay}"
                             Style="{StaticResource OpListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource OpItemBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftedItemName}" Foreground="{StaticResource OpTextTitleBrush}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding BlueprintName}" Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        <DockPanel Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Status}" DockPanel.Dock="Left" Foreground="#E8A020" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock Text="{Binding Priority}" DockPanel.Dock="Right" Foreground="{StaticResource OpTextMutedBrush}" FontSize="11"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ── Right Panel: Detail ── -->
            <Border Grid.Column="2" Style="{StaticResource OpPanelBorderStyle}">
                <Grid Margin="18">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedRequest, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding SelectedRequest.CraftedItemName}" Foreground="{StaticResource OpTextTitleBrush}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedRequest.BlueprintName}" Foreground="{StaticResource OpTextAccentBrush}" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource OpItemBorderStyle}" Margin="0,18,0,0" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock Text="REQUEST SUMMARY" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                                <TextBlock Text="{Binding SelectedRequest.RequesterUsername, StringFormat=Requester: {0}}" Foreground="{StaticResource OpTextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding SelectedRequest.AssignedCrafterUsername, StringFormat=Assigned: {0}, TargetNullValue=Assigned: Unassigned}" Foreground="{StaticResource OpTextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding SelectedRequest.QuantityRequested, StringFormat=Quantity: {0}}" Foreground="{StaticResource OpTextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding SelectedRequest.DeliveryLocation, StringFormat=Location: {0}, TargetNullValue=Location: Not specified}" Foreground="{StaticResource OpTextPrimaryBrush}" Margin="0,0,0,6"/>
                                
                                <TextBlock Text="NOTES" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,12,0,4"
                                           Visibility="{Binding SelectedRequest.Notes, Converter={StaticResource NullToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding SelectedRequest.Notes}" Foreground="{StaticResource OpTextSecondaryBrush}" TextWrapping="Wrap"
                                           Visibility="{Binding SelectedRequest.Notes, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Width="200" Margin="24,0,0,0">
                                <TextBlock Text="ACTIONS" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                                <Button Content="ASSIGN TO ME"
                                        Command="{Binding AssignToSelfCommand}"
                                        IsEnabled="{Binding CanAssign}"
                                        Margin="0,0,0,8" Padding="12,8" FontWeight="Bold"
                                        Background="#2B4E2E" Foreground="#EEF6EE"
                                        BorderBrush="#5C8B5E" BorderThickness="1"/>
                                <Button Content="MARK IN PROGRESS"
                                        Command="{Binding MarkInProgressCommand}"
                                        IsEnabled="{Binding CanMarkInProgress}"
                                        Margin="0,0,0,8" Padding="12,8" FontWeight="Bold"
                                        Background="#5A3A14" Foreground="#F8E9D4"
                                        BorderBrush="#A36E2F" BorderThickness="1"/>
                                <Button Content="MARK COMPLETED"
                                        Command="{Binding MarkCompletedCommand}"
                                        IsEnabled="{Binding CanMarkCompleted}"
                                        Margin="0,0,0,8" Padding="12,8" FontWeight="Bold"
                                        Background="#24374A" Foreground="#E8F0F8"
                                        BorderBrush="#4F6A84" BorderThickness="1"/>
                                <Button Content="CANCEL REQUEST"
                                        Command="{Binding CancelCommand}"
                                        IsEnabled="{Binding CanCancel}"
                                        Padding="12,8" FontWeight="Bold"
                                        Background="#8B1A0F" Foreground="#F4EBDD"
                                        BorderBrush="#B15B34" BorderThickness="1"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Empty state inside detail area if no selection -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- This is only shown if nothing is selected, but handled by parent Grid visibility above -->
                    </StackPanel>
                </Grid>

                <!-- Alternative Empty State for Right Panel -->
                <Control.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource OpPanelBorderStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedRequest}" Value="{x:Null}">
                                <Setter Property="Child">
                                    <Setter.Value>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="SELECT A REQUEST" Foreground="#B9A07D" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Choose a request from the queue to view details and manage assignments."
                                                       Foreground="{StaticResource OpTextMutedBrush}" FontSize="12" Margin="0,8,0,0"
                                                       TextAlignment="Center" TextWrapping="Wrap" Width="300"/>
                                        </StackPanel>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Control.Style>
            </Border>
        </Grid>

        <!-- ── Footer ── -->
        <Border Grid.Row="2" Style="{StaticResource OpHeaderBorderStyle}" Margin="0,16,0,0" Padding="12,10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource OpTextAccentBrush}" FontSize="12" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>