<Window x:Class="PackTracker.Presentation.Views.Admin.AdminAwardRibbonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
        Title="Award Ribbon"
        Background="Transparent"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <converters:ImagePathToPackUriConverter x:Key="ImagePathToPackUri"/>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="#14110E"
            BorderBrush="#1E1A14"
            BorderThickness="1.5"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0F0C09"
                    CornerRadius="14,14,0,0"
                    Padding="28,18,18,18">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="AWARD RIBBON"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="Select one or more members and a ribbon. Citation is optional.&#x0a;Awards are immediate."
                                   FontSize="12"
                                   Foreground="{StaticResource OpTextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Content="&#x2715;"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Red"
                            Width="20"
                            Height="20"
                            Cursor="Hand"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#2A2118"
                        BorderThickness="0,0,1,0"
                        Background="#12100D">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="SELECT MEMBERS"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,0,0,10"/>

                        <TextBox x:Name="MemberSearch"
                                 Grid.Row="1"
                                 Background="#1D1A15"
                                 Foreground="{StaticResource OpTextPrimaryBrush}"
                                 BorderBrush="#2A2118"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 FontSize="12"
                                 Margin="0,0,0,10"
                                 TextChanged="MemberSearch_TextChanged"/>

                        <ListBox x:Name="MemberListBox"
                                 Grid.Row="2"
                                 SelectionMode="Extended"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="MemberListBox_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#221A12"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#2A1F14"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                                   Text="{Binding DisplayLabel}"/>
                                        <TextBlock FontSize="11"
                                                   Margin="0,1,0,0"
                                                   Foreground="{StaticResource OpTextMutedBrush}"
                                                   Text="{Binding SubLabel}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="#14110E">
                    <StackPanel Margin="16">

                        <TextBlock Text="SELECT RIBBON"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,0,0,10"/>

                        <ItemsControl x:Name="RibbonPickerList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="RibbonCard"
                                            Width="130"
                                            Height="110"
                                            Margin="5"
                                            CornerRadius="8"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="RibbonPicker_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#18140F"/>
                                                <Setter Property="BorderBrush" Value="#2A2118"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#221A12"/>
                                                        <Setter Property="BorderBrush" Value="#C2A23A"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathToPackUri}}"
                                                   Stretch="Uniform"
                                                   Margin="8,8,8,4"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <Border Grid.Row="1"
                                                    Background="#0F0C09"
                                                    CornerRadius="0,0,7,7"
                                                    Padding="6,4">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="10"
                                                           Foreground="#8A7460"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#1A1610"
                                BorderBrush="#2A2118"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="0,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="MEMBERS"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource OpTextMutedBrush}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock x:Name="SelectedMemberLabel"
                                               Text="None selected"
                                               FontSize="12"
                                               Foreground="{StaticResource OpTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="RIBBON"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource OpTextMutedBrush}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock x:Name="SelectedRibbonLabel"
                                               Text="None selected"
                                               FontSize="12"
                                               Foreground="{StaticResource OpTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="CITATION (OPTIONAL)"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,16,0,6"/>

                        <TextBox x:Name="CitationBox"
                                 Background="#1D1A15"
                                 Foreground="{StaticResource OpTextPrimaryBrush}"
                                 BorderBrush="#2A2118"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 FontSize="12"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="100"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    BorderBrush="#2A2118"
                    BorderThickness="0,1,0,0"
                    Padding="24,14,24,18">
                <Grid>
                    <TextBlock x:Name="ValidationMessage"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#B05050"
                               Visibility="Collapsed"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="CANCEL"
                                Background="Red"
                                Padding="20,10"
                                Margin="0,0,10,0"
                                Click="Close_Click"/>

                        <Button Content="AWARD RIBBON"
                                Background="Green"
                                Padding="20,10"
                                Click="Submit_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>