<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminRecruitmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="RecruitTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="#14110E"
                                    BorderBrush="#2A2118"
                                    BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Background="Transparent" Margin="4,0"/>
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecruitTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                Padding="20,12"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Cursor="Hand">
                            <TextBlock x:Name="TabText"
                                       Text="{TemplateBinding Header}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#7E6B56"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#CBB293"/>
                                <Setter TargetName="TabText" Property="Foreground" Value="#E7D7B8"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabText" Property="Foreground" Value="#B09070"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DivisionExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="#1A1510"/>
            <Setter Property="BorderBrush" Value="#2A2118"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <StackPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="14,11"
                                              Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <ContentPresenter ContentSource="Header"/>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite"
                                                  ContentSource="Content"
                                                  Visibility="Collapsed"
                                                  Margin="14,0,14,14"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource OpTextAccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource OpHeaderBorderStyle}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="Recruitment Post Builder"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource OpTextTitleBrush}"/>
                    <TextBlock Text="Edit sections below — preview updates live on the right."
                               Margin="0,3,0,0"
                               Foreground="{StaticResource OpTextSecondaryBrush}"
                               FontSize="12"/>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="1"
                        Style="{StaticResource RecruitTabControlStyle}"
                        ItemContainerStyle="{StaticResource RecruitTabItemStyle}">

                <TabItem Header="Org &amp; Links">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Style="{StaticResource OpScrollViewerStyle}">
                        <StackPanel Margin="16">

                            <Border Style="{StaticResource OpPanelBorderStyle}" Padding="18" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="IDENTITY" Style="{StaticResource SectionLabelStyle}"/>

                                    <TextBlock Text="Banner Image (filename or URL)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding BannerImagePath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="Org Name" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding OrgName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="Headline" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Headline, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="Sign-off Line" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SignOff, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource OpPanelBorderStyle}" Padding="18" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="LINKS" Style="{StaticResource SectionLabelStyle}"/>

                                    <TextBlock Text="Website URL" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding WebsiteUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="RSI Org Page URL" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding RsiUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="Discord Invite URL" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding DiscordUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="Language / Timezone" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource OpPanelBorderStyle}" Padding="18">
                                <Button Content="Reset All to House Wolf Defaults"
                                        Style="{DynamicResource SecondaryActionButtonStyle}"
                                        FontSize="12"
                                        Padding="14,8"
                                        Command="{Binding ResetCommand}"/>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Divisions">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Style="{StaticResource OpScrollViewerStyle}">
                        <ItemsControl ItemsSource="{Binding Divisions}" Margin="16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Style="{StaticResource DivisionExpanderStyle}"
                                              IsExpanded="True">
                                        <Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsEnabled}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Emoji}"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Name}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource OpTextTitleBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Tagline}"
                                                           FontSize="11"
                                                           FontStyle="Italic"
                                                           Foreground="{StaticResource OpTextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,4,0"/>
                                            </Grid>
                                        </Expander.Header>

                                        <StackPanel>
                                            <Grid Margin="0,4,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="52"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Emoji, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource OpTextBoxStyle}"
                                                         FontSize="18"
                                                         TextAlignment="Center"
                                                         Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource OpTextBoxStyle}"
                                                         FontWeight="SemiBold"/>
                                            </Grid>

                                            <TextBlock Text="Tagline" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding Tagline, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource OpTextBoxStyle}"
                                                     FontStyle="Italic"
                                                     Margin="0,0,0,10"/>

                                            <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource OpTextBoxStyle}"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     Height="90"
                                                     VerticalScrollBarVisibility="Auto"
                                                     Margin="0,0,0,10"/>

                                            <TextBlock Text="Image (filename from Assets or full URL)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource OpTextBoxStyle}"
                                                     FontFamily="Consolas"
                                                     FontSize="12"/>
                                        </StackPanel>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Content">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Style="{StaticResource OpScrollViewerStyle}">
                        <StackPanel Margin="16">

                            <Border Style="{StaticResource OpPanelBorderStyle}" Padding="18" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="OPENING STATEMENT" Style="{StaticResource SectionLabelStyle}"/>
                                    <TextBlock Text="The cinematic intro before the division section."
                                               Foreground="{StaticResource OpTextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,10"/>
                                    <TextBox Text="{Binding OpeningStatement, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             Height="180"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource OpPanelBorderStyle}" Padding="18" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="WHY JOIN — ONE BULLET PER LINE" Style="{StaticResource SectionLabelStyle}"/>
                                    <TextBlock Text="Format: Key phrase — supporting detail. Each line becomes a ✦ bullet."
                                               Foreground="{StaticResource OpTextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,10"/>
                                    <TextBox Text="{Binding WhyJoinText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             Height="160"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource OpPanelBorderStyle}" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="CALL TO ACTION" Style="{StaticResource SectionLabelStyle}"/>
                                    <TextBlock Text="The closing pitch. Double blank line = new paragraph."
                                               Foreground="{StaticResource OpTextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,10"/>
                                    <TextBox Text="{Binding CallToAction, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource OpTextBoxStyle}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             Height="140"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource OpPanelBorderStyle}"
                    Padding="16,12"
                    Margin="0,16,0,8">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="PreviewHeaderLabel"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="SPECTRUM PREVIEW"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WebViewAvailable}" Value="False">
                                            <Setter Property="Text" Value="POST PREVIEW (WebView2 unavailable — showing plain text)"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text=" — renders exactly as it will appear on the forum"
                                   FontSize="11"
                                   Foreground="{StaticResource OpTextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource OpTextAccentBrush}"
                                   FontSize="12"
                                   Margin="0,0,16,0"/>
                        <Button Content="Copy Post Text"
                                Style="{DynamicResource PrimaryActionButtonStyle}"
                                FontSize="13"
                                Padding="14,8"
                                Command="{Binding CopyCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource OpPanelBorderStyle}"
                    Padding="0"
                    Margin="0,0,0,16">
                <Grid>
                    <wv2:WebView2 x:Name="WebView"
                                  Visibility="{Binding WebViewAvailable, Converter={StaticResource BoolToVis}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WebViewAvailable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <TextBox Text="{Binding GeneratedPost, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 BorderThickness="0"
                                 Padding="16"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Background="#0b0e13"
                                 Foreground="#aeb7c2"
                                 VerticalScrollBarVisibility="Disabled"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
