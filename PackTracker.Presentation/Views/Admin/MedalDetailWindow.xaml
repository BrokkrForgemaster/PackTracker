<Window x:Class="PackTracker.Presentation.Views.Admin.MedalDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Medal Detail"
        Background="Transparent"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border CornerRadius="16"
            Background="#14110E"
            BorderBrush="#1E1A14"
            BorderThickness="1.5"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Black felt image panel — always rendered, image conditional -->
            <Border Grid.Row="0"
                    CornerRadius="14,14,0,0"
                    ClipToBounds="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.7">
                        <GradientStop Color="#111111" Offset="0"/>
                        <GradientStop Color="#060606" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Grid>
                    <Image Source="{Binding PackUri}"
                           Stretch="Uniform"
                           Margin="48,28,48,28"
                           Visibility="{Binding ImageVisibility}"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                    <Button Content="&#x2715;"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,12,14,0"
                            Width="30" Height="30"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#22000000"/>
                                <Setter Property="Foreground" Value="#5A4A38"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#55000000"/>
                                        <Setter Property="Foreground" Value="#C8C0B0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Text content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="40,24,40,28">

                    <TextBlock Text="{Binding Name}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#C2A23A"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <Rectangle Height="1" Fill="#2A2118" Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding Description}"
                               FontSize="14"
                               Foreground="#C8B48F"
                               TextWrapping="Wrap"
                               LineHeight="24"
                               Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding MetaVisibility}">
                        <Border Background="#1D1610"
                                BorderBrush="#2A2118"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10,5"
                                Margin="0,0,8,0"
                                Visibility="{Binding AwardCountVisibility}">
                            <TextBlock Text="{Binding AwardCountText}"
                                       FontSize="12"
                                       Foreground="#A08060"/>
                        </Border>
                        <Border Background="#1D1610"
                                BorderBrush="#2A2118"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10,5"
                                Visibility="{Binding SourceVisibility}">
                            <TextBlock Text="{Binding SourceSystem}"
                                       FontSize="12"
                                       Foreground="#7E6B56"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom close bar -->
            <Border Grid.Row="2"
                    BorderBrush="#2A2118"
                    BorderThickness="0,1,0,0"
                    Padding="40,14,40,18">
                <Button Content="CLOSE"
                        HorizontalAlignment="Right"
                        Padding="28,10"
                        Click="Close_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1D1610"/>
                            <Setter Property="Foreground" Value="#A08060"/>
                            <Setter Property="BorderBrush" Value="#3E3023"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A2118"/>
                                    <Setter Property="Foreground" Value="#C2A23A"/>
                                    <Setter Property="BorderBrush" Value="#3E3023"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
