<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminRequestHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource OpHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Request History"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextTitleBrush}"/>
                <TextBlock Text="Closed request history for admin review. Standard user hubs remain active-only."
                           Margin="0,4,0,0"
                           Foreground="{StaticResource OpTextSecondaryBrush}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="14"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Queue:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="{StaticResource OpTextSecondaryBrush}"
                           FontSize="13"/>
                <ComboBox Grid.Column="1"
                          Style="{StaticResource OpComboBoxStyle}"
                          ItemsSource="{Binding HistoryTypes}"
                          SelectedItem="{Binding SelectedHistoryType}"
                          VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource OpTextAccentBrush}"
                           FontSize="12"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="0">
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="#14110E"
                      AlternatingRowBackground="#191510"
                      HorizontalGridLinesBrush="#2A2118"
                      VerticalGridLinesBrush="#2A2118"
                      Foreground="{StaticResource OpTextPrimaryBrush}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#15120F"/>
                        <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderBrush" Value="#2A2118"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20170F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2A1F14"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TITLE" Binding="{Binding Title}" Width="2*"/>
                    <DataGridTextColumn Header="TYPE" Binding="{Binding RequestType}" Width="110"/>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="110"/>
                    <DataGridTextColumn Header="PRIORITY" Binding="{Binding Priority}" Width="110"/>
                    <DataGridTextColumn Header="REQUESTER" Binding="{Binding RequesterDisplayName}" Width="150"/>
                    <DataGridTextColumn Header="ASSIGNEE" Binding="{Binding AssigneeDisplayName}" Width="150"/>
                    <DataGridTextColumn Header="CREATED" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="145"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
