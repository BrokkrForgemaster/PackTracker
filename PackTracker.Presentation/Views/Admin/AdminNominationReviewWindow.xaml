<Window x:Class="PackTracker.Presentation.Views.Admin.AdminNominationReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
        Title="Review Nomination"
        Background="Transparent"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <converters:ImagePathToPackUriConverter x:Key="ImagePathToPackUri"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisible"/>
        <converters:NullToInverseVisibilityConverter x:Key="NullToInverseVisible"/>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="#14110E"
            BorderBrush="#1E1A14"
            BorderThickness="1.5"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Medal image panel -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" ClipToBounds="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.7">
                        <GradientStop Color="#111111" Offset="0"/>
                        <GradientStop Color="#060606" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Grid>
                    <Image x:Name="MedalImage"
                           Stretch="Uniform" Margin="48,28,48,28"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Content="&#x2715;"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,14,0" Width="30" Height="30"
                            Cursor="Hand" Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#22000000"/>
                                <Setter Property="Foreground" Value="#5A4A38"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#55000000"/>
                                        <Setter Property="Foreground" Value="#C8C0B0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="36,20,36,24">

                    <!-- Medal name -->
                    <TextBlock x:Name="MedalNameText"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#C2A23A"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"/>

                    <!-- Nominee info -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="Nominated: " FontSize="13"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock x:Name="NomineeNameText"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"/>
                        <TextBlock Text=" by " FontSize="13"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock x:Name="NominatorNameText"
                                   FontSize="13" Foreground="{StaticResource OpTextSecondaryBrush}"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="#2A2118" Margin="0,0,0,16"/>

                    <!-- Citation -->
                    <TextBlock Text="CITATION" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource OpTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="CitationText"
                               FontSize="13"
                               Foreground="#C8B48F"
                               TextWrapping="Wrap"
                               LineHeight="22"
                               Margin="0,0,0,20"/>

                    <!-- Review notes display (only for non-pending) -->
                    <Border x:Name="ReviewNotesPanel"
                            Background="#1A1510"
                            CornerRadius="6"
                            Padding="14,10"
                            Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="REVIEW NOTES" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource OpTextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="ReviewNotesText"
                                       FontSize="12" Foreground="{StaticResource OpTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Notes input (only for Pending) -->
                    <Border x:Name="NotesInputPanel">
                        <StackPanel>
                            <TextBlock Text="REVIEW NOTES (OPTIONAL)" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource OpTextMutedBrush}" Margin="0,0,0,6"/>
                            <TextBox x:Name="ReviewNotesInput"
                                     Background="#1D1A15"
                                     Foreground="{StaticResource OpTextPrimaryBrush}"
                                     BorderBrush="#2A2118" BorderThickness="1"
                                     Padding="10,8" FontSize="12"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="80" VerticalScrollBarVisibility="Auto">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      Margin="{TemplateBinding Padding}"
                                                                      VerticalScrollBarVisibility="Auto"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom bar -->
            <Border Grid.Row="2"
                    BorderBrush="#2A2118"
                    BorderThickness="0,1,0,0"
                    Padding="36,14,36,18">
                <Grid>
                    <StackPanel x:Name="ActionButtons" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="DenyButton"
                                Content="DENY"
                                Padding="24,10" Margin="0,0,10,0"
                                Click="Deny_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#200E0E"/>
                                    <Setter Property="Foreground" Value="#B06060"/>
                                    <Setter Property="BorderBrush" Value="#4A2020"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#301414"/>
                                            <Setter Property="Foreground" Value="#E07070"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="ApproveButton"
                                Content="APPROVE &amp; AWARD"
                                Padding="24,10"
                                Click="Approve_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#102010"/>
                                    <Setter Property="Foreground" Value="#60B060"/>
                                    <Setter Property="BorderBrush" Value="#204820"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#183018"/>
                                            <Setter Property="Foreground" Value="#80D080"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <Button x:Name="CloseButton"
                            Content="CLOSE"
                            HorizontalAlignment="Right"
                            Padding="24,10"
                            Visibility="Collapsed"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1D1610"/>
                                <Setter Property="Foreground" Value="#A08060"/>
                                <Setter Property="BorderBrush" Value="#3E3023"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2118"/>
                                        <Setter Property="Foreground" Value="#C2A23A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
