<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource OpScrollViewerStyle}">
        <StackPanel Margin="24">

            <!-- Header -->
            <Border Style="{StaticResource OpHeaderBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Admin Overview"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource OpTextTitleBrush}"/>
                    <TextBlock Text="High-level system analytics and administrative status."
                               Margin="0,4,0,0"
                               Foreground="{StaticResource OpTextSecondaryBrush}"
                               FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Stat cards -->
            <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource OpItemBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="AUTHORITY LEVEL"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding HighestTier}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextTitleBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource OpItemBorderStyle}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL MEMBERS"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding TotalMembers}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextTitleBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource OpItemBorderStyle}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="ADMIN STAFF"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding ActiveAdminRoleAssignments}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextTitleBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource OpItemBorderStyle}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="AUDIT VOLUME"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding TotalAuditEntries}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextTitleBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Lower panels -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource OpPanelBorderStyle}"
                        Padding="18" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="INFRASTRUCTURE STATUS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Discord Integration"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource OpTextPrimaryBrush}"
                                       FontSize="13"/>
                            <Border HorizontalAlignment="Right" Padding="8,3" CornerRadius="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DiscordSettingsConfigured}" Value="True">
                                                <Setter Property="Background" Value="#1A4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DiscordSettingsConfigured}" Value="False">
                                                <Setter Property="Background" Value="#1ADC3545"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontWeight="Bold" FontSize="10" FontFamily="Consolas">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DiscordSettingsConfigured}" Value="True">
                                                    <Setter Property="Text" Value="CONFIGURED"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DiscordSettingsConfigured}" Value="False">
                                                    <Setter Property="Text" Value="NOT SET"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>

                        <Grid>
                            <TextBlock Text="Core Database"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource OpTextPrimaryBrush}"
                                       FontSize="13"/>
                            <Border HorizontalAlignment="Right" Background="#1A4CAF50" Padding="8,3" CornerRadius="3">
                                <TextBlock Text="CONNECTED"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           FontWeight="Bold" FontSize="10" FontFamily="Consolas"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource OpPanelBorderStyle}"
                        Padding="18" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="QUICK ACTIONS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,0,0,14"/>
                        <Button Content="System Health Check"
                                Style="{DynamicResource SecondaryActionButtonStyle}"
                                HorizontalAlignment="Left" Width="210"
                                FontSize="13" Padding="14,8" Margin="0,0,0,0"/>
                        <Button Content="Sync Discord Roles"
                                Style="{DynamicResource SecondaryActionButtonStyle}"
                                HorizontalAlignment="Left" Width="210"
                                FontSize="13" Padding="14,8" Margin="0"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
