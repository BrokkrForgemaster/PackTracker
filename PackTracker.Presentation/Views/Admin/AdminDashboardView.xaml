<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Admin Dashboard"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Foundation placeholder for admin analytics and controls."
                       Margin="0,6,0,18"
                       Foreground="#D0D0D0"/>

            <WrapPanel>
                <Border Margin="0,0,16,16" Padding="16" Background="#221E1E1E" CornerRadius="8" Width="220">
                    <StackPanel>
                        <TextBlock Text="Highest Tier" Foreground="#C8A040"/>
                        <TextBlock Text="{Binding HighestTier}" FontSize="20" Foreground="White"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,16,16" Padding="16" Background="#221E1E1E" CornerRadius="8" Width="220">
                    <StackPanel>
                        <TextBlock Text="Members" Foreground="#C8A040"/>
                        <TextBlock Text="{Binding TotalMembers}" FontSize="20" Foreground="White"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,16,16" Padding="16" Background="#221E1E1E" CornerRadius="8" Width="220">
                    <StackPanel>
                        <TextBlock Text="Active Admin Assignments" Foreground="#C8A040"/>
                        <TextBlock Text="{Binding ActiveAdminRoleAssignments}" FontSize="20" Foreground="White"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,16,16" Padding="16" Background="#221E1E1E" CornerRadius="8" Width="220">
                    <StackPanel>
                        <TextBlock Text="Audit Entries" Foreground="#C8A040"/>
                        <TextBlock Text="{Binding TotalAuditEntries}" FontSize="20" Foreground="White"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Padding="16" Background="#221E1E1E" CornerRadius="8" Width="320">
                <StackPanel>
                    <TextBlock Text="Discord Settings Seeded" Foreground="#C8A040"/>
                    <TextBlock Text="{Binding DiscordSettingsConfigured}" FontSize="20" Foreground="White"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
