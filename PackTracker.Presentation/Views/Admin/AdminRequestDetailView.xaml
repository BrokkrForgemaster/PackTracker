<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminRequestDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             Background="Transparent">
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource OpHeaderBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Detail.Title, FallbackValue='Loading...'}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource OpTextTitleBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Detail.RequestType}"
                                   Foreground="{StaticResource OpTextSecondaryBrush}"
                                   FontSize="12"/>
                        <TextBlock Text=" · "
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding Detail.Status}"
                                   Foreground="{StaticResource OpTextAccentBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="← Back to History"
                        Style="{DynamicResource SecondaryActionButtonStyle}"
                        VerticalAlignment="Center"
                        Click="Back_Click"/>
            </Grid>
        </Border>

        <!-- Error state -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                   Foreground="{StaticResource OpTextSecondaryBrush}"
                   FontSize="13"
                   Margin="0,16,0,0"/>

        <!-- Core fields panel -->
        <Border Grid.Row="1"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="20"
                Margin="0,0,0,16"
                Visibility="{Binding Detail, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column -->
                <StackPanel>
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="PRIORITY"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.Priority}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="REQUESTER"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.RequesterDisplayName, TargetNullValue='—'}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="ASSIGNEE"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.AssigneeDisplayName, TargetNullValue='—'}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16"
                                Visibility="{Binding Detail.Location, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="LOCATION"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.Location}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16"
                                Visibility="{Binding Detail.RewardOffered, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="REWARD"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.RewardOffered}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right column -->
                <StackPanel Grid.Column="1">
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="CREATED"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="CLOSED"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.ClosedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue='—'}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16"
                                Visibility="{Binding Detail.QuantityRequested, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="QUANTITY REQUESTED"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.QuantityRequested}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16"
                                Visibility="{Binding Detail.QuantityDelivered, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="QUANTITY DELIVERED"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.QuantityDelivered}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16"
                                Visibility="{Binding Detail.MinimumQuality, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="MINIMUM QUALITY"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.MinimumQuality}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16"
                                Visibility="{Binding Detail.MaterialSupplyMode, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="MATERIAL SUPPLY"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="{Binding Detail.MaterialSupplyMode}"
                                   FontSize="14"
                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Description / Refusal Reason panel -->
        <Border Grid.Row="2"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="20"
                Margin="0,0,0,16"
                Visibility="{Binding Detail, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel>
                <StackPanel Visibility="{Binding Detail.Description, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="DESCRIPTION / NOTES"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource OpTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Detail.Description}"
                               FontSize="13"
                               Foreground="{StaticResource OpTextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Margin="0,16,0,0"
                            Visibility="{Binding Detail.RefusalReason, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="REFUSAL REASON"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource OpTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Detail.RefusalReason}"
                               FontSize="13"
                               Foreground="{StaticResource OpTextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Claims panel -->
        <Border Grid.Row="3"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="0"
                Visibility="{Binding Detail, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="CLAIMS"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextMutedBrush}"
                           Margin="14,12,14,8"/>
                <DataGrid ItemsSource="{Binding Detail.Claims}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="#14110E"
                          AlternatingRowBackground="#191510"
                          HorizontalGridLinesBrush="#2A2118"
                          VerticalGridLinesBrush="#2A2118"
                          Foreground="{StaticResource OpTextPrimaryBrush}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#15120F"/>
                            <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderBrush" Value="#2A2118"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MEMBER" Binding="{Binding DisplayName}" Width="*"/>
                        <DataGridTextColumn Header="CLAIMED AT"
                                            Binding="{Binding ClaimedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                            Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
