<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminMembersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource OpHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Members Management"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextTitleBrush}"/>
                <TextBlock Text="Assign and revoke admin roles. Member showcase profiles are managed from the standard Profile page."
                           Margin="0,4,0,0"
                           Foreground="{StaticResource OpTextSecondaryBrush}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="14"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Role:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Foreground="{StaticResource OpTextSecondaryBrush}"
                               FontSize="13"/>
                    <ComboBox Width="220"
                              Style="{StaticResource OpComboBoxStyle}"
                              ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding SelectedRole}"
                              DisplayMemberPath="Name"
                              VerticalAlignment="Center"/>

                    <Button Content="Assign"
                            Style="{DynamicResource PrimaryActionButtonStyle}"
                            Width="110"
                            FontSize="13"
                            Padding="12,7"
                            Margin="16,0,0,0"
                            Click="AssignRole_Click"
                            VerticalAlignment="Center"/>

                    <Button Content="Revoke"
                            Style="{DynamicResource SecondaryActionButtonStyle}"
                            Width="110"
                            FontSize="13"
                            Padding="12,7"
                            Margin="8,0,0,0"
                            Click="RevokeRole_Click"
                            VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource OpTextAccentBrush}"
                           FontSize="12"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="0">
            <DataGrid ItemsSource="{Binding Members}"
                      SelectedItem="{Binding SelectedMember}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="#14110E"
                      AlternatingRowBackground="#191510"
                      HorizontalGridLinesBrush="#2A2118"
                      VerticalGridLinesBrush="#2A2118"
                      Foreground="{StaticResource OpTextPrimaryBrush}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#15120F"/>
                        <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderBrush" Value="#2A2118"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20170F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2A1F14"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="USER" Binding="{Binding Username}" Width="130"/>
                    <DataGridTextColumn Header="DISPLAY NAME" Binding="{Binding DisplayName}" Width="150"/>
                    <DataGridTextColumn Header="RANK" Binding="{Binding DiscordRank}" Width="130"/>
                    <DataGridTextColumn Header="DIVISION" Binding="{Binding DiscordDivision}" Width="110"/>
                    <DataGridTextColumn Header="ADMIN ROLES" Binding="{Binding ActiveAdminRoles}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
