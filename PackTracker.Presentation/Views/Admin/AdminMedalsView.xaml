<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminMedalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:ImagePathToPackUriConverter x:Key="ImagePathToPackUri"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisible"/>
        <converters:NullToInverseVisibilityConverter x:Key="NullToInverseVisible"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource OpHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Medals &amp; Ribbons"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextTitleBrush}"/>
                <TextBlock Text="Load an award JSON file, review it, then import medals and ribbons into PackTracker."
                           Margin="0,4,0,0"
                           Foreground="{StaticResource OpTextSecondaryBrush}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,14">

            <Button Content="Load Award File"
                    Style="{DynamicResource SecondaryActionButtonStyle}"
                    FontSize="13"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Click="LoadFile_Click"/>

            <Button Content="Import Awards"
                    Style="{DynamicResource PrimaryActionButtonStyle}"
                    FontSize="13"
                    Padding="14,8"
                    Click="Import_Click"/>
        </StackPanel>

        <Border Grid.Row="2"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="160"/>
                </Grid.RowDefinitions>

                <TextBlock Text="LOADED AWARD JSON PREVIEW"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextMutedBrush}"
                           Margin="0,0,0,10"/>

                <TextBox Grid.Row="1"
                         Text="{Binding ImportJson, UpdateSourceTrigger=PropertyChanged}"
                         Background="#120D0A"
                         Foreground="{StaticResource OpTextPrimaryBrush}"
                         BorderBrush="#2A2118"
                         BorderThickness="1"
                         Padding="10"
                         FontFamily="Consolas"
                         FontSize="12"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <Border Style="{StaticResource OpPanelBorderStyle}"
                        Padding="0"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="18,16,18,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="AVAILABLE MEDALS"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       VerticalAlignment="Center"/>

                            <Button Content="Nominate Member"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Style="{DynamicResource SecondaryActionButtonStyle}"
                                    FontSize="12"
                                    Padding="12,6"
                                    Click="NominateButton_Click"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Medals}" Margin="12,0,12,14">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="220"
                                            Height="165"
                                            Margin="5"
                                            CornerRadius="8"
                                            Background="#18140F"
                                            BorderBrush="#2A2118"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="MedalCard_MouseLeftButtonUp">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Image Grid.Row="0"
                                                   Source="{Binding ImagePath, Converter={StaticResource ImagePathToPackUri}}"
                                                   Stretch="Uniform"
                                                   Margin="14,14,14,8"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding ImagePath, Converter={StaticResource NullToVisible}}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <TextBlock Grid.Row="0"
                                                       Text="✦"
                                                       FontSize="32"
                                                       Foreground="#2A2118"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding ImagePath, Converter={StaticResource NullToInverseVisible}}"/>

                                            <Border Grid.Row="1"
                                                    Background="#0F0C09"
                                                    CornerRadius="0,0,7,7"
                                                    Padding="10,6,10,8">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="11"
                                                           Foreground="#8A7460"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           LineHeight="15"/>
                                            </Border>
                                        </Grid>

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#221A12"/>
                                                        <Setter Property="BorderBrush" Value="#C2A23A"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource OpPanelBorderStyle}"
                        Padding="0"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="18,16,18,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="AVAILABLE RIBBONS"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       VerticalAlignment="Center"/>

                            <Button Content="Award Ribbon"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Style="{DynamicResource SecondaryActionButtonStyle}"
                                    FontSize="12"
                                    Padding="12,6"
                                    Click="AwardRibbonButton_Click"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding RibbonDefinitions}" Margin="12,0,12,14">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="220"
                                            Height="165"
                                            Margin="5"
                                            CornerRadius="8"
                                            Background="#18140F"
                                            BorderBrush="#2A2118"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="RibbonCard_MouseLeftButtonUp">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Image Grid.Row="0"
                                                   Source="{Binding ImagePath, Converter={StaticResource ImagePathToPackUri}}"
                                                   Stretch="Uniform"
                                                   Margin="14,14,14,8"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding ImagePath, Converter={StaticResource NullToVisible}}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <TextBlock Grid.Row="0"
                                                       Text="✦"
                                                       FontSize="32"
                                                       Foreground="#2A2118"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding ImagePath, Converter={StaticResource NullToInverseVisible}}"/>

                                            <Border Grid.Row="1"
                                                    Background="#0F0C09"
                                                    CornerRadius="0,0,7,7"
                                                    Padding="10,6,10,8">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="11"
                                                           Foreground="#8A7460"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           LineHeight="15"/>
                                            </Border>
                                        </Grid>

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#221A12"/>
                                                        <Setter Property="BorderBrush" Value="#C2A23A"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>