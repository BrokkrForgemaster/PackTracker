<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminMedalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource OpHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Medals"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextTitleBrush}"/>
                <TextBlock Text="Import House Wolf medal definitions and awards from the legacy JSON export."
                           Margin="0,4,0,0"
                           Foreground="{StaticResource OpTextSecondaryBrush}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="18"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="IMPORT JSON"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextMutedBrush}"
                           Margin="0,0,0,12"/>

                <TextBox Grid.Row="1"
                         Text="{Binding ImportJson, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource OpTextBoxStyle}"
                         Height="170"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"/>

                <Grid Grid.Row="2" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource OpTextAccentBrush}"
                               FontSize="12"/>

                    <Button Grid.Column="1"
                            Content="Load File"
                            Style="{DynamicResource SecondaryActionButtonStyle}"
                            FontSize="13"
                            Padding="14,8"
                            Margin="0,0,8,0"
                            Click="LoadFile_Click"/>

                    <Button Grid.Column="2"
                            Content="Import Medals"
                            Style="{DynamicResource PrimaryActionButtonStyle}"
                            FontSize="13"
                            Padding="14,8"
                            Click="Import_Click"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="0"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="AVAILABLE MEDALS"
                           Margin="18,16,18,10"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextMutedBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Medals}"
                          SelectedItem="{Binding SelectedMedal}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="#14110E"
                          AlternatingRowBackground="#191510"
                          HorizontalGridLinesBrush="#2A2118"
                          VerticalGridLinesBrush="#2A2118"
                          Foreground="{StaticResource OpTextPrimaryBrush}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#15120F"/>
                            <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderBrush" Value="#2A2118"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#20170F"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A1F14"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="220"/>
                        <DataGridTextColumn Header="SOURCE" Binding="{Binding SourceSystem}" Width="120"/>
                        <DataGridTextColumn Header="AWARDS" Binding="{Binding AwardCount}" Width="90"/>
                        <DataGridTextColumn Header="IMAGE" Binding="{Binding ImagePath}" Width="240"/>
                        <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="AWARDED MEDALS"
                           Margin="18,16,18,10"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextMutedBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Awards}"
                          SelectedItem="{Binding SelectedAward}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="#14110E"
                          AlternatingRowBackground="#191510"
                          HorizontalGridLinesBrush="#2A2118"
                          VerticalGridLinesBrush="#2A2118"
                          Foreground="{StaticResource OpTextPrimaryBrush}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#15120F"/>
                            <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderBrush" Value="#2A2118"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#20170F"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A1F14"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="RECIPIENT" Binding="{Binding RecipientName}" Width="180"/>
                        <DataGridTextColumn Header="PROFILE" Binding="{Binding ProfileDisplayName}" Width="180"/>
                        <DataGridTextColumn Header="MEDAL" Binding="{Binding MedalName}" Width="220"/>
                        <DataGridTextColumn Header="SOURCE" Binding="{Binding SourceSystem}" Width="120"/>
                        <DataGridTextColumn Header="AWARDED" Binding="{Binding AwardedAt}" Width="140"/>
                        <DataGridTextColumn Header="IMPORTED" Binding="{Binding ImportedAt}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
