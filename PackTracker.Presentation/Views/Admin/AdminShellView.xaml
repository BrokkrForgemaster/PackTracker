<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource MainBackground}">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Margin="20" Style="{DynamicResource SidebarBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="24,32,24,20">
                    <TextBlock Text="ADMIN" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource AccentGoldBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="COMMAND" 
                               FontSize="28" 
                               FontWeight="Black" 
                               HorizontalAlignment="Center"
                               Foreground="White"/>
                    
                    <Border Background="{DynamicResource SurfaceGlassBrush}" 
                            CornerRadius="8" 
                            Padding="12,6" 
                            Margin="0,20,0,0"
                            HorizontalAlignment="Center">
                        <TextBlock Text="{Binding AdminTierLabel}" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentGoldBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" Margin="20,0">
                    <StackPanel x:Name="AdminNavPanel">
                        <Button Content="Dashboard" 
                                Tag="Dashboard"
                                Style="{DynamicResource SidebarButtonStyle}"
                                Click="Dashboard_Click"/>
                        
                        <Button Content="Members" 
                                Tag="Members"
                                Style="{DynamicResource SidebarButtonStyle}"
                                Click="Members_Click"/>
                        
                        <Button Content="Admin Settings" 
                                Tag="Settings"
                                Style="{DynamicResource SidebarButtonStyle}"
                                Click="Settings_Click"/>

                        <Separator Background="{DynamicResource GlassBorderBrush}" Margin="12,20"/>
                        
                        <Button Content="Audit Logs" IsEnabled="False" Style="{DynamicResource SidebarButtonStyle}"/>
                        <Button Content="Medals" IsEnabled="False" Style="{DynamicResource SidebarButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Back Action -->
                <Border Grid.Row="2" Padding="20,0,20,24">
                    <Button Content="RETURN TO HUB" 
                            Style="{DynamicResource PrimaryActionButtonStyle}"
                            Click="Back_Click"/>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">
            <ContentControl x:Name="AdminContentHost"/>
        </Grid>
    </Grid>
</UserControl>
