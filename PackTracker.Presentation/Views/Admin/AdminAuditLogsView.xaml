<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminAuditLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             Loaded="UserControl_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource OpHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="System Audit Logs"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource OpTextTitleBrush}"/>
                <TextBlock Text="View application errors and significant administrative events captured across the system."
                           Margin="0,4,0,0"
                           Foreground="{StaticResource OpTextSecondaryBrush}"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="14"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Refresh Logs"
                            Command="{Binding LoadLogsCommand}"
                            Style="{DynamicResource PrimaryActionButtonStyle}"
                            Width="140"
                            FontSize="13"
                            Padding="12,7"
                            VerticalAlignment="Center"/>
                    
                    <ProgressBar IsIndeterminate="True"
                                 Width="100"
                                 Height="4"
                                 Margin="16,0,0,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                 VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding ErrorMessage}"
                           VerticalAlignment="Center"
                           Foreground="#E57373"
                           FontSize="12"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource OpPanelBorderStyle}"
                Padding="0">
            <DataGrid ItemsSource="{Binding Logs}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="#14110E"
                      AlternatingRowBackground="#191510"
                      HorizontalGridLinesBrush="#2A2118"
                      VerticalGridLinesBrush="#2A2118"
                      Foreground="{StaticResource OpTextPrimaryBrush}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#15120F"/>
                        <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderBrush" Value="#2A2118"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20170F"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                <Setter Property="Foreground" Value="#FFBABA"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="Fatal">
                                <Setter Property="Foreground" Value="#FF5252"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="OCCURRED AT" Binding="{Binding OccurredAt, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" Width="140"/>
                    <DataGridTextColumn Header="SEVERITY" Binding="{Binding Severity}" Width="80"/>
                    <DataGridTextColumn Header="ACTOR" Binding="{Binding ActorDisplayName}" Width="100"/>
                    <DataGridTextColumn Header="ACTION" Binding="{Binding Action}" Width="120"/>
                    <DataGridTextColumn Header="SUMMARY" Binding="{Binding Summary}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="Padding" Value="0,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="MACHINE" Binding="{Binding MachineName}" Width="100"/>
                    <DataGridTemplateColumn Header="EXP" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="8" Height="8" 
                                         Fill="#E57373" 
                                         Visibility="{Binding HasException, Converter={StaticResource BoolToVisibilityConverter}}"
                                         ToolTip="Contains Exception Details"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
