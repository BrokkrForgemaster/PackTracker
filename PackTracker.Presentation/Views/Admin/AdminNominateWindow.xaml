<Window x:Class="PackTracker.Presentation.Views.Admin.AdminNominateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
        Title="Nominate Member"
        Background="Transparent"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <converters:ImagePathToPackUriConverter x:Key="ImagePathToPackUri"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisible"/>
        <converters:NullToInverseVisibilityConverter x:Key="NullToInverseVisible"/>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="#14110E"
            BorderBrush="#1E1A14"
            BorderThickness="1.5"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="#0F0C09"
                    CornerRadius="14,14,0,0"
                    Padding="28,18,18,18">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="NOMINATE FOR MEDAL"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"/>
                        <TextBlock Text="Select a member and a medal, then write a citation."
                                   FontSize="12"
                                   Foreground="{StaticResource OpTextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="&#x2715;"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="30" Height="30"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#5A4A38"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#33000000"/>
                                        <Setter Property="Foreground" Value="#C8C0B0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Main content: 3-column layout -->
            <Grid Grid.Row="1" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Member search -->
                <Border Grid.Column="0"
                        BorderBrush="#2A2118"
                        BorderThickness="0,0,1,0"
                        Background="#12100D">
                    <Grid Margin="16,16,16,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="SELECT MEMBER"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBox x:Name="MemberSearch"
                                 Grid.Row="1"
                                 Background="#1D1A15"
                                 Foreground="{StaticResource OpTextPrimaryBrush}"
                                 BorderBrush="#2A2118"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 FontSize="12"
                                 Margin="0,0,0,10"
                                 TextChanged="MemberSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <ListBox x:Name="MemberListBox"
                                 Grid.Row="2"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="MemberListBox_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#221A12"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#2A1F14"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource OpTextPrimaryBrush}"
                                                   Text="{Binding DisplayLabel}"/>
                                        <TextBlock FontSize="11" Margin="0,1,0,0"
                                                   Foreground="{StaticResource OpTextMutedBrush}"
                                                   Text="{Binding SubLabel}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Center: Medal gallery -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="#14110E">
                    <StackPanel Margin="16">
                        <TextBlock Text="SELECT MEDAL"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,0,0,10"/>
                        <ItemsControl x:Name="MedalPickerList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="130" Height="110"
                                            Margin="5"
                                            CornerRadius="8"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="MedalPicker_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#18140F"/>
                                                <Setter Property="BorderBrush" Value="#2A2118"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#221A12"/>
                                                        <Setter Property="BorderBrush" Value="#C2A23A"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathToPackUri}}"
                                                   Stretch="Uniform" Margin="8,8,8,4"
                                                   Visibility="{Binding ImagePath, Converter={StaticResource NullToVisible}}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Grid.Row="0" Text="&#x2756;" FontSize="22"
                                                       Foreground="#2A2118"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding ImagePath, Converter={StaticResource NullToInverseVisible}}"/>
                                            <Border Grid.Row="1" Background="#0F0C09"
                                                    CornerRadius="0,0,7,7" Padding="6,4">
                                                <TextBlock Text="{Binding Name}" FontSize="10"
                                                           Foreground="#8A7460"
                                                           TextAlignment="Center" TextWrapping="Wrap"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Right: Citation + selection summary -->
                <Border Grid.Column="2"
                        BorderBrush="#2A2118"
                        BorderThickness="1,0,0,0"
                        Background="#12100D">
                    <StackPanel Margin="16">
                        <TextBlock Text="SELECTION" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,0,0,10"/>
                        <Border Background="#1D1A15" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="MEMBER" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource OpTextMutedBrush}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="SelectedMemberLabel"
                                           Text="None selected"
                                           FontSize="12" Foreground="{StaticResource OpTextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1D1A15" CornerRadius="6" Padding="10,8" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="MEDAL" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource OpTextMutedBrush}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="SelectedMedalLabel"
                                           Text="None selected"
                                           FontSize="12" Foreground="{StaticResource OpTextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="CITATION" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="CitationBox"
                                 Background="#1D1A15"
                                 Foreground="{StaticResource OpTextPrimaryBrush}"
                                 BorderBrush="#2A2118"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 FontSize="12"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="140"
                                 VerticalScrollBarVisibility="Auto">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                                                  VerticalScrollBarVisibility="Auto"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom bar -->
            <Border Grid.Row="2"
                    BorderBrush="#2A2118"
                    BorderThickness="0,1,0,0"
                    Padding="24,14,24,18">
                <Grid>
                    <TextBlock x:Name="ValidationMessage"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#B05050"
                               Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL"
                                Padding="20,10" Margin="0,0,10,0"
                                Click="Close_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1D1610"/>
                                    <Setter Property="Foreground" Value="#A08060"/>
                                    <Setter Property="BorderBrush" Value="#3E3023"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2118"/>
                                            <Setter Property="Foreground" Value="#C2A23A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="SUBMIT NOMINATION"
                                Padding="20,10"
                                Click="Submit_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#2A1F14"/>
                                    <Setter Property="Foreground" Value="#C2A23A"/>
                                    <Setter Property="BorderBrush" Value="#C2A23A"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A2A18"/>
                                            <Setter Property="Foreground" Value="#F0C84A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
