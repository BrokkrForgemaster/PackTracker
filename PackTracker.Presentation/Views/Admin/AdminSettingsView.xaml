<UserControl x:Class="PackTracker.Presentation.Views.Admin.AdminSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Admin Settings"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Discord integration foundation for future admin workflows."
                       Margin="0,6,0,18"
                       Foreground="#D0D0D0"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <CheckBox Content="Operations Enabled" IsChecked="{Binding OperationsEnabled}" Foreground="White" Margin="0,0,20,0"/>
                <CheckBox Content="Medal Announcements Enabled" IsChecked="{Binding MedalAnnouncementsEnabled}" Foreground="White" Margin="0,0,20,0"/>
                <CheckBox Content="Recruiting Posts Enabled" IsChecked="{Binding RecruitingPostsEnabled}" Foreground="White"/>
            </StackPanel>

            <TextBlock Text="Operations Channel ID" Foreground="#C8A040"/>
            <TextBox Text="{Binding OperationsChannelId}" Margin="0,4,0,12"/>

            <TextBlock Text="Medal Announcements Channel ID" Foreground="#C8A040"/>
            <TextBox Text="{Binding MedalAnnouncementsChannelId}" Margin="0,4,0,12"/>

            <TextBlock Text="Recruiting Posts Channel ID" Foreground="#C8A040"/>
            <TextBox Text="{Binding RecruitingPostsChannelId}" Margin="0,4,0,12"/>

            <StackPanel Orientation="Horizontal">
                <Button Content="Save Settings" Width="140" Click="Save_Click"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="16,4,0,0" Foreground="#D0D0D0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
