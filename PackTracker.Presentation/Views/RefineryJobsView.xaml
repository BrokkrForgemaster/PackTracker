<UserControl x:Class="PackTracker.Presentation.Views.RefineryJobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:global="clr-namespace:"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Color converter for job status -->
        <global:StatusToColorConverter x:Key="StatusToColorConverter" />
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Regolith Refinery Operations"
                   FontSize="36"
                   FontWeight="Black"
                   Foreground="#FFD700"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20" />

        <!-- Refinery Jobs List -->
        <Border Grid.Row="1"
                Background="#181818"
                CornerRadius="16"
                Padding="20"
                BorderBrush="#2B2B2B"
                BorderThickness="1"
                Effect="{DynamicResource DropShadowEffect}">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel>
                    <TextBlock Text="Active Refinery Jobs"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FFD700"
                               Margin="0 0 0 12"/>

                    <ItemsControl ItemsSource="{Binding RefineryJobs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="400" ItemHeight="Auto"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#202020"
                                        CornerRadius="12"
                                        Padding="16"
                                        Margin="0 10 10 0"
                                        BorderBrush="#303030"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <!-- Job Location -->
                                        <TextBlock Text="{Binding Location}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFD700"
                                                   TextWrapping="Wrap"/>

                                        <!-- Material -->
                                        <TextBlock Text="{Binding Material}"
                                                   FontSize="14"
                                                   Foreground="White"
                                                   Margin="0 2 0 10"
                                                   TextWrapping="Wrap"/>

                                        <!-- Quantity + Status Row -->
                                        <DockPanel Margin="0 0 0 4">
                                            <TextBlock Text="{Binding Status}"
                                                       DockPanel.Dock="Left"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                       FontWeight="Bold"
                                                       FontSize="13"/>
                                            <TextBlock Text="{Binding Quantity, StringFormat={}{0:N0} SCU}"
                                                       DockPanel.Dock="Right"
                                                       Foreground="#AAA"
                                                       FontSize="13"/>
                                        </DockPanel>

                                        <!-- Progress bar -->
                                        <ProgressBar Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding Progress}"
                                                     Height="6"
                                                     Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                     Background="#333"/>

                                        <!-- Times -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SubmittedAt, StringFormat='Started: {0:t}'}"
                                                       Foreground="#888"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding CompletedAt, StringFormat='Completed: {0:t}'}"
                                                       Foreground="#666"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <!-- Remaining Time -->
                                        <TextBlock Text="{Binding RemainingTime, StringFormat='Time Left: {0}'}"
                                                   Foreground="#90EE90"
                                                   FontSize="12"
                                                   Margin="0 2 0 0"
                                                   Visibility="{Binding Status, Converter={StaticResource ProcessingToVisibleConverter}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
