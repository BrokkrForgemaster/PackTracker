<UserControl x:Class="PackTracker.Presentation.Views.RefineryJobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:global="clr-namespace:"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Color converter for job status -->
        <global:StatusToColorConverter x:Key="StatusToColorConverter" />
        <global:ProcessingToVisibleConverter x:Key="ProcessingToVisibleConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Icon -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                CornerRadius="16"
                Padding="20,16"
                Margin="0,0,0,20"
                BorderBrush="{DynamicResource AccentGoldBrush}"
                BorderThickness="2"
                Effect="{DynamicResource CardShadow}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⚙️"
                           FontSize="36"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBlock Text="Regolith Refinery Operations"
                           FontSize="32"
                           FontWeight="Black"
                           Foreground="#C2A23A"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Responsive Refinery Jobs List -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceAltBrush}"
                CornerRadius="16"
                Padding="24"
                BorderBrush="{DynamicResource PanelStrokeBrush}"
                BorderThickness="1"
                Effect="{DynamicResource CardShadow}">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel>
                    <TextBlock Text="🔥 Active Jobs"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#C2A23A"
                               Margin="0,0,0,16"/>

                    <!-- Responsive card grid -->
                    <ItemsControl ItemsSource="{Binding RefineryJobs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        CornerRadius="14"
                                        Padding="20"
                                        Margin="0,0,16,16"
                                        MinWidth="320"
                                        MaxWidth="380"
                                        BorderBrush="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                        BorderThickness="0,0,0,3"
                                        Effect="{DynamicResource CardShadow}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2A2A2A"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>
                                        <!-- Header with Status Badge -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Location Icon + Name -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="📍"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Location}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="#C2A23A"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Status Badge -->
                                            <Border Grid.Column="1"
                                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="11"/>
                                            </Border>
                                        </Grid>

                                        <!-- Material Info -->
                                        <Border Background="{DynamicResource CardBackground}"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Material"
                                                           Foreground="#888"
                                                           FontSize="11"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Material}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Quantity -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="Quantity"
                                                       Foreground="#888"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Quantity, StringFormat={}{0:N0} SCU}"
                                                       Foreground="#C2A23A"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Progress Section -->
                                        <StackPanel Margin="0,0,0,12">
                                            <Grid Margin="0,0,0,6">
                                                <TextBlock Text="Progress"
                                                           Foreground="#888"
                                                           FontSize="11"
                                                           HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding Progress, StringFormat={}{0:N0}%}"
                                                           Foreground="#C2A23A"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>

                                            <!-- Modern Progress Bar -->
                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding Progress}"
                                                         Height="10"
                                                         Background="{DynamicResource CardBackground}"
                                                         Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                         BorderThickness="0">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ProgressBar">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="6"
                                                                            ClipToBounds="True">
                                                                        <Border x:Name="PART_Track"
                                                                                CornerRadius="6"
                                                                                Background="{DynamicResource CardBackground}">
                                                                            <Border x:Name="PART_Indicator"
                                                                                    Background="{TemplateBinding Foreground}"
                                                                                    CornerRadius="6"
                                                                                    HorizontalAlignment="Left"/>
                                                                        </Border>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                        </StackPanel>

                                        <!-- Time Information -->
                                        <StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="⏱️ Started: "
                                                           Foreground="#666"
                                                           FontSize="11"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SubmittedAt, StringFormat='{}{0:g}'}"
                                                           Foreground="#888"
                                                           FontSize="11"/>
                                            </Grid>

                                            <!-- Remaining Time (only for processing) -->
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding Status, Converter={StaticResource ProcessingToVisibleConverter}}">
                                                <TextBlock Text="⏳ Time Left: "
                                                           Foreground="#90EE90"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding RemainingTime}"
                                                           Foreground="#90EE90"
                                                           FontSize="12"
                                                           FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
