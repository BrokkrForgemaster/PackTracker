<UserControl x:Class="PackTracker.Presentation.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dto="clr-namespace:PackTracker.Application.DTOs.Profiles;assembly=PackTracker.Application"
             Background="Transparent">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource OpHeaderBorderStyle}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="PROFILE DOSSIER"
                               Foreground="{StaticResource OpTextTitleBrush}"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock Text="Manage your own showcase card and review medals already recorded on your profile."
                               Margin="0,4,0,0"
                               Foreground="{StaticResource OpTextSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource OpTextAccentBrush}"
                           FontSize="12"
                           Margin="20,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource OpScrollViewerStyle}">
                <StackPanel>
                    <Border Style="{StaticResource OpPanelBorderStyle}"
                            Padding="18"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="SHOWCASE CARD"
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Portrait Image URL"
                                       Foreground="{StaticResource OpTextAccentBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ShowcaseImageUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource OpTextBoxStyle}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Eyebrow Label"
                                       Foreground="{StaticResource OpTextAccentBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ShowcaseEyebrow, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource OpTextBoxStyle}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Tagline / Role Line"
                                       Foreground="{StaticResource OpTextAccentBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ShowcaseTagline, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource OpTextBoxStyle}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Biography"
                                       Foreground="{StaticResource OpTextAccentBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ShowcaseBio, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource OpTextBoxStyle}"
                                     Height="180"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="This page is member-managed. Medals display here, but awarding remains controlled elsewhere."
                                       Foreground="{StaticResource OpTextSecondaryBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <Button Content="SAVE SHOWCASE"
                                    Style="{DynamicResource PrimaryActionButtonStyle}"
                                    Padding="14,8"
                                    FontSize="13"
                                    Click="Save_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OpPanelBorderStyle}"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="MEDALS AND ACHIEVEMENTS"
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Imported medals attached to your profile appear here automatically."
                                       Foreground="{StaticResource OpTextSecondaryBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <ItemsControl ItemsSource="{Binding Medals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type dto:CurrentProfileMedalDto}">
                                        <Border Background="#120D0A"
                                                BorderBrush="{StaticResource OpBorderItemBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="64"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="64"
                                                        Height="64"
                                                        CornerRadius="8"
                                                        Background="#1B1820"
                                                        BorderBrush="#3A3144"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Image Source="{Binding ImagePath}"
                                                               Stretch="Uniform"
                                                               Margin="8"/>
                                                        <TextBlock Text="HW"
                                                                   Foreground="#C8A84B"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource OpTextTitleBrush}"
                                                               FontSize="14"
                                                               FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{StaticResource OpTextSecondaryBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding Citation}"
                                                               Foreground="{StaticResource OpTextAccentBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No medals recorded yet."
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Medals.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Style="{StaticResource OpPanelBorderStyle}"
                    Padding="14"
                    Background="#070B11"
                    BorderBrush="#202734">
                <Grid Width="340"
                      HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="300"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            CornerRadius="20,20,0,0"
                            BorderBrush="#293241"
                            BorderThickness="1"
                            Background="#0B1019"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding PreviewImageUrl}"
                                   Stretch="UniformToFill"/>
                            <Rectangle Fill="#68000000"/>
                            <StackPanel VerticalAlignment="Bottom"
                                        Margin="18,0,18,18">
                                <TextBlock Text="{Binding ShowcaseEyebrow}"
                                           Foreground="#BFD1EA"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding PreviewDisplayName}"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding ShowcaseTagline}"
                                           Foreground="#E0D0B1"
                                           FontSize="13"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            CornerRadius="0,0,20,20"
                            BorderBrush="#293241"
                            BorderThickness="1,0,1,1"
                            Background="#0A0E16"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="{Binding PreviewRoleLine}"
                                       Foreground="#F3F5F7"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>
                            <TextBlock Text="{Binding ShowcaseBio}"
                                       Foreground="#F3F5F7"
                                       FontSize="14"
                                       LineHeight="28"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
