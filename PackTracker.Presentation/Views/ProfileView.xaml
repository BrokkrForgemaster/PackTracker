<UserControl x:Class="PackTracker.Presentation.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dto="clr-namespace:PackTracker.Application.DTOs.Profiles;assembly=PackTracker.Application"
             Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource OpHeaderBorderStyle}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="PROFILE DOSSIER"
                               Foreground="{StaticResource OpTextTitleBrush}"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock Text="Manage your showcase card and review awards recorded on your profile."
                               Margin="0,4,0,0"
                               Foreground="{StaticResource OpTextSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource OpTextAccentBrush}"
                           FontSize="12"
                           Margin="20,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource OpScrollViewerStyle}">
                <StackPanel>

                    <!-- Character Profile Info -->
                    <Border Style="{StaticResource OpPanelBorderStyle}"
                            Padding="18"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="CHARACTER PROFILE"
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Your character profile is now synchronized with housewolf.co."
                                       Foreground="{StaticResource OpTextAccentBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Biographies, portraits, and divisions are managed through the central House Wolf database. Any changes made there will appear here automatically."
                                       Foreground="{StaticResource OpTextSecondaryBrush}"
                                       FontSize="12"
                                       LineHeight="20"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="If you previously had a local profile set up in PackTracker, we've automatically migrated your data to the new system."
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <Button Content="EDIT ON HOUSEWOLF.CO"
                                    Style="{DynamicResource SecondaryActionButtonStyle}"
                                    Padding="14,8"
                                    FontSize="13"
                                    HorizontalAlignment="Left"
                                    Command="{Binding OpenHouseWolfWebsiteCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- SERVICE SHADOW BOX NOW ON LEFT -->
                    <Border CornerRadius="24"
                            Padding="20"
                            Background="#120D09"
                            BorderBrush="#5A3218"
                            BorderThickness="2"
                            Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="26"
                                              ShadowDepth="8"
                                              Opacity="0.65"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="SERVICE SHADOW BOX"
                                           Foreground="#D6A04B"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Medals and combat ribbons earned through House Wolf service"
                                           Foreground="{StaticResource OpTextMutedBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Medals -->
                            <Border Grid.Row="1"
                                    CornerRadius="16"
                                    Background="#080706"
                                    BorderBrush="#A16207"
                                    BorderThickness="1"
                                    Padding="16"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="MEDALS"
                                               Foreground="{StaticResource OpTextMutedBrush}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12"/>

                                    <ItemsControl ItemsSource="{Binding DisplayMedals}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type dto:CurrentProfileMedalDto}">
                                                <StackPanel Width="90"
                                                            Margin="8"
                                                            ToolTip="{Binding Citation}">
                                                    <Border Width="82"
                                                            Height="96"
                                                            CornerRadius="10"
                                                            Background="#17110D"
                                                            BorderBrush="#3F2A17"
                                                            BorderThickness="1"
                                                            Padding="6">
                                                        <Image Source="{Binding ImagePath}"
                                                               Stretch="Uniform"/>
                                                    </Border>

                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="#E7D6B5"
                                                               FontSize="9"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="No medals recorded yet."
                                               Foreground="{StaticResource OpTextMutedBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplayMedals.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Ribbons -->
                            <Border Grid.Row="2"
                                    CornerRadius="16"
                                    Background="#080706"
                                    BorderBrush="#3F2A17"
                                    BorderThickness="1"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="COMBAT RIBBONS"
                                               Foreground="{StaticResource OpTextMutedBrush}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,0,0,12"/>

                                    <ItemsControl ItemsSource="{Binding DisplayRibbons}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type dto:CurrentProfileMedalDto}">
                                                <Border Width="110"
                                                        Height="38"
                                                        CornerRadius="5"
                                                        Background="#130F0B"
                                                        BorderBrush="#4A3420"
                                                        BorderThickness="1"
                                                        Padding="4"
                                                        Margin="5"
                                                        ToolTip="{Binding Citation}">
                                                    <Image Source="{Binding ImagePath}"
                                                           Stretch="Uniform"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="No ribbons recorded yet."
                                               Foreground="{StaticResource OpTextMutedBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplayRibbons.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT SIDE PROFILE CARD ONLY -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource OpScrollViewerStyle}">
                <StackPanel>
                    <Border Style="{StaticResource OpPanelBorderStyle}"
                            Padding="14"
                            Background="#070B11"
                            BorderBrush="#202734"
                            Margin="0,0,0,16">
                        <Grid Width="340"
                              HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="300"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    CornerRadius="20,20,0,0"
                                    BorderBrush="#293241"
                                    BorderThickness="1"
                                    Background="#0B1019"
                                    ClipToBounds="True">
                                <Grid>
                                    <Image Source="{Binding ShowcaseImageSource}"
                                           Stretch="UniformToFill"/>
                                    <Rectangle Fill="#68000000"/>
                                    <StackPanel VerticalAlignment="Bottom"
                                                Margin="18,0,18,18">
                                        <TextBlock Text="{Binding ShowcaseEyebrow}"
                                                   Foreground="#BFD1EA"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding PreviewDisplayName}"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding ShowcaseTagline}"
                                                   Foreground="#E0D0B1"
                                                   FontSize="13"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    CornerRadius="0,0,20,20"
                                    BorderBrush="#293241"
                                    BorderThickness="1,0,1,1"
                                    Background="#0A0E16"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="{Binding PreviewRoleLine}"
                                               Foreground="#F3F5F7"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,14"/>
                                    <TextBlock Text="{Binding ShowcaseBio}"
                                               Foreground="#F3F5F7"
                                               FontSize="14"
                                               LineHeight="28"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>