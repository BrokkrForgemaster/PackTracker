<UserControl x:Class="PackTracker.Presentation.Views.BlueprintExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Blueprint Explorer"
                       FontSize="34"
                       FontWeight="Black"
                       Foreground="White"/>
            <TextBlock Text="Search in-game blueprints, inspect material requirements, and view available House Wolf owners."
                       FontSize="15"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource SectionCardStyle}"
                Padding="20"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="42"
                         Margin="0,0,12,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding CategoryFilter, UpdateSourceTrigger=PropertyChanged}"
                         Height="42"
                         Margin="0,0,12,0"/>

                <CheckBox Grid.Column="2"
                          Content="In-game only"
                          IsChecked="{Binding InGameOnly}"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"/>

                <Button Grid.Column="3"
                        Content="Search"
                        Command="{Binding SearchCommand}"
                        Width="120"
                        Height="42"
                        Style="{StaticResource PrimaryActionButtonStyle}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Results"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Results}"
                             SelectedItem="{Binding SelectedBlueprint, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        BorderBrush="{DynamicResource PanelStrokeBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding BlueprintName}"
                                                   FontWeight="Bold"
                                                   FontSize="16"/>
                                        <TextBlock Text="{Binding CraftedItemName}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <DockPanel Margin="0,10,0,0">
                                            <Border Background="#2D2D2D"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding Category}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="{Binding VerifiedOwnerCount, StringFormat=Verified owners: {0}}"
                                                       DockPanel.Dock="Right"
                                                       Foreground="{DynamicResource AccentGoldBrush}"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding SelectedBlueprintDetail.BlueprintName, TargetNullValue=Select a blueprint}"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedBlueprintDetail.CraftedItemName}"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="15"/>
                        <TextBlock Text="{Binding SelectedBlueprintDetail.AcquisitionSummary}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0">
                        <Button Content="Register Ownership"
                                Command="{Binding RegisterOwnershipCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Height="42"
                                Padding="20,0"
                                Margin="0,0,12,0"/>
                        <Button Content="Create Crafting Request"
                                Command="{Binding CreateCraftingRequestCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Height="42"
                                Padding="20,0"
                                Margin="0,0,12,0"/>
                        <Button Content="Request Materials"
                                Command="{Binding CreateProcurementRequestCommand}"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Height="42"
                                Padding="20,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource GlassPanelStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Recipe"
                                           FontWeight="Bold"
                                           FontSize="16"/>
                                <ListBox ItemsSource="{Binding Materials}"
                                         SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,10,0,0"
                                                    Padding="10"
                                                    Background="#14000000"
                                                    CornerRadius="10">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Left">
                                                        <TextBlock Text="{Binding MaterialName}"/>
                                                        <TextBlock Text="{Binding MaterialType}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding QuantityRequired, StringFormat={}{0:N2}}"
                                                               DockPanel.Dock="Right"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource AccentGoldBrush}"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource GlassPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="Known Owners"
                                           FontWeight="Bold"
                                           FontSize="16"/>
                                <ItemsControl ItemsSource="{Binding Owners}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,10,0,0"
                                                    Padding="10"
                                                    Background="#14000000"
                                                    CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Username}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding OwnershipStatus}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                                    <TextBlock Text="{Binding AvailabilityStatus}" Foreground="{DynamicResource AccentGoldBrush}" FontSize="12"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Margin="0,14,0,0"
                   Foreground="{DynamicResource TextMutedBrush}"/>
    </Grid>
</UserControl>
