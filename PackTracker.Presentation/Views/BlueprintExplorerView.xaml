<UserControl x:Class="PackTracker.Presentation.Views.BlueprintExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource OpHeaderBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="BLUEPRINT OPERATIONS" Style="{x:Null}" Foreground="{StaticResource OpTextTitleBrush}" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Search imported Star Citizen blueprint data, inspect part requirements, evaluate modifiers, and dispatch House Wolf workflow actions."
                               Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource OpPanelBorderStyle}"
                        Background="{StaticResource OpBackgroundPillBrush}" BorderBrush="{StaticResource OpBorderPillBrush}"
                        Padding="10,6" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="STATUS" Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource OpTextPrimaryBrush}" FontSize="11" Width="260" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Left Panel ── -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OpPanelBorderStyle}">
            <DockPanel Margin="12">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="SEARCH" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold"/>
                    <TextBox Margin="0,6,0,10"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource OpTextBoxStyle}"/>

                    <TextBlock Text="CATEGORY" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold"/>
                    <ComboBox Margin="0,6,0,10"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Style="{StaticResource OpComboBoxStyle}"/>

                    <CheckBox Content="Only show default-unlock blueprints"
                              IsChecked="{Binding InGameOnly}"
                              Foreground="{StaticResource OpTextPrimaryBrush}"
                              Margin="0,0,0,12"/>

                    <Button Content="SEARCH BLUEPRINTS"
                            Command="{Binding SearchCommand}"
                            Padding="12,8"
                            FontWeight="Bold"
                            Background="#8B1A0F"
                            Foreground="#F4EBDD"
                            BorderBrush="#B15B34"
                            BorderThickness="1"/>

                    <TextBlock Margin="0,6,0,6"
                               Foreground="{StaticResource OpTextMutedBrush}" FontSize="11"
                               Text="{Binding Results.Count, StringFormat=Results: {0}}"/>

                    <TextBlock Text="SELECT BLUEPRINT" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold"/>
                    <ComboBox Margin="0,6,0,0"
                              ItemsSource="{Binding Results}"
                              SelectedItem="{Binding SelectedBlueprint}"
                              Style="{StaticResource OpComboBoxStyle}"
                              MaxDropDownHeight="420">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding BlueprintName}"
                                               Foreground="{StaticResource OpTextTitleBrush}" FontWeight="SemiBold" FontSize="13"
                                               TextWrapping="Wrap"/>
                                    <DockPanel Margin="0,3,0,0">
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" DockPanel.Dock="Left"/>
                                        <TextBlock Text="{Binding VerifiedOwnerCount, StringFormat=Owners: {0}}"
                                                   Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" DockPanel.Dock="Right"/>
                                    </DockPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Right Panel ── -->
        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSelectedBlueprintDetail}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <Border Style="{StaticResource OpHeaderBorderStyle}" Margin="0" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedBlueprintDetail.BlueprintName}"
                                           FontSize="24" FontWeight="Bold" Foreground="{StaticResource OpTextTitleBrush}"/>
                                <TextBlock Text="{Binding SelectedBlueprintDetail.CraftedItemName}"
                                           FontSize="14" Foreground="{StaticResource OpTextAccentBrush}" Margin="0,4,0,0"/>
                                <WrapPanel Margin="0,10,0,0">
                                    <Border Background="{StaticResource OpBackgroundPillBrush}" BorderBrush="{StaticResource OpBorderPillBrush}" BorderThickness="1"
                                            CornerRadius="5" Padding="8,4" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding SelectedBlueprintDetail.Category}"
                                                   Foreground="{StaticResource OpTextAccentBrush}" FontSize="11"/>
                                    </Border>
                                    <Border Background="{StaticResource OpBackgroundPillBrush}" BorderBrush="{StaticResource OpBorderPillBrush}" BorderThickness="1"
                                            CornerRadius="5" Padding="8,4" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding SelectedBlueprintDetail.DataConfidence}"
                                                   Foreground="{StaticResource OpTextAccentBrush}" FontSize="11"/>
                                    </Border>
                                    <Border Background="{StaticResource OpBackgroundPillBrush}" BorderBrush="{StaticResource OpBorderPillBrush}" BorderThickness="1"
                                            CornerRadius="5" Padding="8,4" Margin="0,0,8,8">
                                        <TextBlock Foreground="{StaticResource OpTextAccentBrush}" FontSize="11">
                                            <Run Text="Craft Time: "/>
                                            <Run Text="{Binding SelectedBlueprintDetail.TimeToCraftSeconds}"/>
                                            <Run Text="s"/>
                                        </TextBlock>
                                    </Border>
                                </WrapPanel>
                                <TextBlock Text="{Binding SelectedBlueprintDetail.Description}"
                                           Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedBlueprintDetail.AcquisitionSummary}"
                                           Foreground="{StaticResource OpTextAccentBrush}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top">
                                <Button Content="MARK OWNED"
                                        Command="{Binding MarkOwnedCommand}"
                                        Margin="0,0,0,8" Padding="12,8" FontWeight="Bold"
                                        Background="#2B4E2E" Foreground="#EEF6EE"
                                        BorderBrush="#5C8B5E" BorderThickness="1"/>
                                <Button Content="MARK WANTED"
                                        Command="{Binding MarkWantedCommand}"
                                        Margin="0,0,0,8" Padding="12,8" FontWeight="Bold"
                                        Background="#5A3A14" Foreground="#F8E9D4"
                                        BorderBrush="#A36E2F" BorderThickness="1"/>
                                <Button Content="CREATE CRAFTING REQUEST"
                                        Command="{Binding CreateCraftingRequestCommand}"
                                        Margin="0,0,0,8" Padding="12,8" FontWeight="Bold"
                                        Background="#8B1A0F" Foreground="#F4EBDD"
                                        BorderBrush="#B15B34" BorderThickness="1"/>
                                <Button Content="REQUEST SELECTED MATERIAL"
                                        Command="{Binding CreateProcurementRequestCommand}"
                                        Padding="12,8" FontWeight="Bold"
                                        Background="#24374A" Foreground="#E8F0F8"
                                        BorderBrush="#4F6A84" BorderThickness="1"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource OpPanelBorderStyle}" Padding="14">
                            <StackPanel>
                                <TextBlock Text="COMPONENT BREAKDOWN" Foreground="{StaticResource OpTextTitleBrush}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Part-level crafting breakdown derived from source blueprint groups and modifier ranges."
                                           Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="11" Margin="0,4,0,12"/>
                                <ItemsControl ItemsSource="{Binding Components}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource OpItemBorderStyle}">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding PartName}" Foreground="{StaticResource OpTextTitleBrush}" FontWeight="Bold" FontSize="14" DockPanel.Dock="Left"/>
                                                        <TextBlock Text="{Binding QualityValue, StringFormat=Quality: {0}}" Foreground="{StaticResource OpTextAccentBrush}" FontSize="11" DockPanel.Dock="Right"/>
                                                    </DockPanel>
                                                    <TextBlock Foreground="{StaticResource OpTextAccentBrush}" FontSize="11" Margin="0,6,0,0">
                                                        <Run Text="Material: "/>
                                                        <Run Text="{Binding MaterialName}"/>
                                                    </TextBlock>
                                                    <TextBlock Foreground="{StaticResource OpTextAccentBrush}" FontSize="11" Margin="0,2,0,0">
                                                        <Run Text="Quantity: "/>
                                                        <Run Text="{Binding Quantity, StringFormat={}{0:N2}}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="QUALITY" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,10,0,4"/>
                                                    <Slider Minimum="0" Maximum="1000" Value="{Binding QualityValue, Mode=TwoWay}"/>
                                                    <ItemsControl ItemsSource="{Binding Modifiers}" Margin="0,10,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,6" Padding="8,6"
                                                                        Background="#211912" BorderBrush="#3A2D22"
                                                                        BorderThickness="1" CornerRadius="6">
                                                                    <DockPanel>
                                                                        <TextBlock Text="{Binding StatName}" Foreground="#DCC6A4" FontSize="11" DockPanel.Dock="Left"/>
                                                                        <TextBlock Text="{Binding Percentage, StringFormat={}{0:+0.##;-0.##;0.##}}" Foreground="#D58A57" FontWeight="SemiBold" FontSize="11" DockPanel.Dock="Right"/>
                                                                    </DockPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource OpPanelBorderStyle}" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="COMBINED MODIFIERS" Foreground="{StaticResource OpTextTitleBrush}" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Aggregate effect preview from current part quality settings."
                                               Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="11" Margin="0,4,0,12"/>
                                    <ItemsControl ItemsSource="{Binding CombinedModifiers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource OpItemBorderStyle}" Padding="10">
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding PropertyKey}" Foreground="{StaticResource OpTextTitleBrush}" FontWeight="SemiBold" FontSize="12" DockPanel.Dock="Left"/>
                                                        <TextBlock Text="{Binding CalculatedValue, StringFormat={}{0:+0.##;-0.##;0.##}}" Foreground="#D58A57" FontWeight="Bold" FontSize="12" DockPanel.Dock="Right"/>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0" Style="{StaticResource OpPanelBorderStyle}" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="OWNERS / INTEREST" Foreground="{StaticResource OpTextTitleBrush}" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Members who own or want this blueprint."
                                               Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="11" Margin="0,4,0,12"/>
                                    <ItemsControl ItemsSource="{Binding Owners}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource OpItemBorderStyle}" Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Username}" Foreground="{StaticResource OpTextTitleBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Foreground="{StaticResource OpTextAccentBrush}" FontSize="11" Margin="0,4,0,0">
                                                            <Run Text="Interest: "/>
                                                            <Run Text="{Binding InterestType}"/>
                                                            <Run Text=" | Status: "/>
                                                            <Run Text="{Binding OwnershipStatus}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding AvailabilityStatus}" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,16,0,0" Style="{StaticResource OpPanelBorderStyle}" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RECIPE MATERIALS" Foreground="{StaticResource OpTextTitleBrush}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Select a material to create a procurement request."
                                           Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="11" Margin="0,4,0,12"/>
                                <ListBox ItemsSource="{Binding Materials}"
                                         SelectedItem="{Binding SelectedMaterial}"
                                         Style="{StaticResource OpListBoxStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource OpItemBorderStyle}" Padding="10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding MaterialName}" Foreground="{StaticResource OpTextTitleBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Foreground="{StaticResource OpTextAccentBrush}" FontSize="11" Margin="0,4,0,0">
                                                        <Run Text="Qty: "/>
                                                        <Run Text="{Binding QuantityRequired}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding Unit}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding SourceType}" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="OPERATIONAL NOTES" Foreground="{StaticResource OpTextTitleBrush}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedBlueprintDetail.Notes}"
                                           Foreground="#AC977B" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Empty state -->
            <Border Padding="22">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource OpPanelBorderStyle}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSelectedBlueprintDetail}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="SELECT A BLUEPRINT" Foreground="#B9A07D"
                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose a blueprint from the registry to inspect components, materials, modifiers, ownership, and workflow actions."
                               Foreground="{StaticResource OpTextMutedBrush}" FontSize="12" Margin="0,8,0,0"
                               TextAlignment="Center" TextWrapping="Wrap" Width="360"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Footer status bar ── -->
        <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource OpHeaderBorderStyle}" Margin="0,16,0,0" Padding="12,10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource OpTextAccentBrush}" FontSize="12" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>