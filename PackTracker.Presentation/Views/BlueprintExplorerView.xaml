<UserControl x:Class="PackTracker.Presentation.Views.BlueprintExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:vm="clr-namespace:PackTracker.Presentation.ViewModels"
             xmlns:views="clr-namespace:PackTracker.Presentation.Views"
             xmlns:global="clr-namespace:"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <DataTemplate DataType="{x:Type global:ComponentViewModel}">
            <views:ComponentView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0" Margin="0,0,14,0" CornerRadius="8" BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#8B1A0F" Offset="0"/>
                    <GradientStop Color="#2A1E12" Offset="0.3"/>
                    <GradientStop Color="#2A1E12" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#18130F" Offset="0"/>
                    <GradientStop Color="#12100E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="14,12,14,6">
                    <TextBlock Text="BLUEPRINT REGISTRY" Foreground="#4A3A28" FontSize="9" FontWeight="Bold"/>
                </Border>
                <Border DockPanel.Dock="Top" Padding="10,0,10,8">
                    <TextBox Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </Border>
                <Border DockPanel.Dock="Top" Padding="12,4,12,6">
                    <Grid>
                        <TextBlock Foreground="#4A3A28" FontSize="10" VerticalAlignment="Center">
                            <Run Text="{Binding Results.Count, Mode=OneWay}"/>
                            <Run Text=" results"/>
                        </TextBlock>
                        <TextBlock Text="Syncing..." Foreground="#8B1A0F" FontSize="10"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Visibility="{Binding IsLoading, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </Grid>
                </Border>
                <Border DockPanel.Dock="Top" Height="1" Background="#2A1E12" Margin="0,0,0,4"/>

                <!-- THE KEY FIX: ItemTemplate set directly on ListBox, not inside the Style -->
                <ListBox Style="{StaticResource BlueprintListStyle}"
                         ItemsSource="{Binding Results}"
                         SelectedItem="{Binding SelectedBlueprint}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <TextBlock Text="{Binding BlueprintName}"
                                               Foreground="#C8B898" FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Category}"
                                               Foreground="#4A3A28" FontSize="10" Margin="0,1,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#201810" BorderBrush="#3D2A1A"
                                        BorderThickness="1" CornerRadius="3" Padding="5,2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Category}" Foreground="#7A6A52"
                                               FontSize="9" FontWeight="Bold" MaxWidth="60"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- RIGHT PANEL -->
        <ScrollViewer Grid.Column="1"
                      Visibility="{Binding SelectedBlueprint, Converter={StaticResource NullToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="4,0,4,20">

                <!-- Title Bar -->
                <Border Margin="0,0,0,16" CornerRadius="8" Padding="0,18" BorderThickness="1">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#8B1A0F" Offset="0"/>
                            <GradientStop Color="#3D2A1A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1E1510" Offset="0"/>
                            <GradientStop Color="#14110D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="18,0,16,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#C8922A" Offset="0"/>
                                    <GradientStop Color="#8B1A0F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="0,0,18,0">
                            <TextBlock Text="CRAFTING SIMULATOR" Foreground="#5A4A32" FontSize="9" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedBlueprint.BlueprintName}"
                                       FontSize="26" FontWeight="Black" Foreground="#E8D5B0"
                                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding SelectedBlueprint.Category}"
                                       Foreground="#7A6A52" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- PARTS label -->
                <StackPanel Orientation="Horizontal" Margin="2,0,0,10">
                    <Border Width="16" Height="1" VerticalAlignment="Center" Background="#3D2A1A" Margin="0,0,8,0"/>
                    <TextBlock Text="PARTS" Foreground="#7A6A52" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Component Cards -->
                <ItemsControl ItemsSource="{Binding SelectedComponents}"/>

                <!-- No recipe message -->
                <Border Margin="0,4,0,0" Padding="14,10" CornerRadius="6"
                        Background="#12100E" BorderBrush="#2A1E12" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedComponents.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="No recipe data available for this blueprint."
                               Foreground="#4A3A28" FontSize="12" HorizontalAlignment="Center"/>
                </Border>

                <!-- Final Combined Modifiers -->
                <Border Style="{StaticResource ModifierSectionStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Viewbox Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Polyline Points="0,12 4,12 7,4 10,20 13,8 16,14 20,14 24,14"
                                                  Stroke="#C8922A" StrokeThickness="1.8"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Final Combined Modifiers"
                                           Foreground="#E8D5B0" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding QualityModifiers.Count, StringFormat={}{0} stats active}"
                                       Foreground="#4A3A28" FontSize="10"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="14,0,14,6">
                            <TextBlock Text="MODIFIER" Foreground="#4A3A28" FontSize="9" FontWeight="Bold"/>
                            <TextBlock Text="COMBINED EFFECT" Foreground="#4A3A28" FontSize="9"
                                       FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding QualityModifiers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ModifierRowStyle}">
                                        <Grid>
                                            <TextBlock Text="{Binding PropertyKey}"
                                                       Foreground="#9A8A72" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CalculatedValue, StringFormat={}{0:+0.##%;-0.##%}}"
                                                       Foreground="#E8A020" FontWeight="Bold" FontSize="14"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Padding="14,10" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QualityModifiers.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Adjust component quality sliders to see modifiers."
                                       Foreground="#4A3A28" FontSize="11" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Empty state -->
        <Border Grid.Column="1"
                Visibility="{Binding SelectedBlueprint, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.3">
                <TextBlock Text="&#x2B21;" FontSize="52" Foreground="#3D2A1A" HorizontalAlignment="Center"/>
                <TextBlock Text="SELECT A BLUEPRINT" Foreground="#5A4A32" FontSize="11" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,14,0,4"/>
                <TextBlock Text="Choose a blueprint from the registry to begin simulation"
                           Foreground="#3A2A1A" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
