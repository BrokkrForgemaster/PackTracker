<UserControl x:Class="PackTracker.Presentation.Views.KillTracker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:entities="clr-namespace:PackTracker.Domain.Entities;assembly=PackTracker.Domain"
             xmlns:conv="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:global="clr-namespace:"
             Background="Transparent">

    <UserControl.Resources>
        <conv:KillTypeToColorConverter x:Key="KillTypeToColorConverter" />
        <conv:KillTypeToIconConverter  x:Key="KillTypeToIconConverter" />
        <conv:RelativeTimeConverter    x:Key="RelativeTimeConverter" />
        <conv:LocalTimeConverter       x:Key="LocalTimeConverter" />
        <global:SummaryFormatter         x:Key="SummaryFormatter" />
    </UserControl.Resources>

    <Grid>
        <Border Background="#181818"
                CornerRadius="16"
                Padding="24"
                Margin="24"
                BorderBrush="#292929"
                BorderThickness="1"
                SnapsToDevicePixels="True"
                Effect="{DynamicResource DropShadowEffect}">

            <DockPanel LastChildFill="True">
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <TextBlock Text="Kill Tracker"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#FFD700"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="ConnectionStatus"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Foreground="#FFC107"
                               Text="Connecting..." />
                </StackPanel>

                <!-- Main Content -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Summary Cards -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- FPS Kills -->
                        <Border Grid.Column="0"
                                Background="#1E1E1E"
                                CornerRadius="12"
                                Padding="18"
                                BorderBrush="#333"
                                BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="FPS Kills"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#AAAAAA"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtFpsKillCount"
                                           Text="0"
                                           FontSize="40"
                                           FontWeight="Bold"
                                           Foreground="#4CAF50"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- AIR Kills -->
                        <Border Grid.Column="2"
                                Background="#1E1E1E"
                                CornerRadius="12"
                                Padding="18"
                                BorderBrush="#333"
                                BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Air Kills"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#AAAAAA"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtAirKillCount"
                                           Text="0"
                                           FontSize="40"
                                           FontWeight="Bold"
                                           Foreground="#E53935"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Recent Kills List -->
                    <Border Grid.Row="1"
                            Background="#121212"
                            CornerRadius="12"
                            BorderBrush="#2b2b2b"
                            BorderThickness="1"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Recent Kills"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#FFD700"
                                       Margin="0,0,0,10" />

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="320">
                                <ItemsControl x:Name="RecentKillsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type entities:KillEntity}">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="5"/>   <!-- accent bar -->
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Accent bar driven by converter -->
                                                <Border Grid.Column="0"
                                                        Background="{Binding Type, Converter={StaticResource KillTypeToColorConverter}}"
                                                        CornerRadius="3"/>

                                                <!-- Card -->
                                                <Border Grid.Column="1"
                                                        Background="#1c1c1c"
                                                        BorderBrush="#2b2b2b"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="10">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Type, Converter={StaticResource KillTypeToIconConverter}}"
                                                                   Background="#E53935"
                                                                   FontSize="18"
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock>
                                                            <Run Text="{Binding Timestamp, Converter={StaticResource RelativeTimeConverter}}"
                                                                 Foreground="#aaa" FontSize="12"/>
                                                            <Run Text="  •  " Foreground="#555"/>
                                                            <!-- local formatted time -->
                                                            <Run Text="{Binding Timestamp, Converter={StaticResource LocalTimeConverter}}"
                                                                 Foreground="#ffd700" FontSize="12" FontWeight="SemiBold"/>
                                                            <Run Text="  •  " Foreground="#555"/>
                                                            <!-- summary cleaned -->
                                                            <Run Text="{Binding Summary, Converter={StaticResource SummaryFormatter}}"
                                                                 Foreground="White" FontSize="14"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
