<UserControl x:Class="PackTracker.Presentation.Views.KillTracker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:entities="clr-namespace:PackTracker.Domain.Entities;assembly=PackTracker.Domain"
             xmlns:conv="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:global="clr-namespace:"
             Background="Transparent">

    <UserControl.Resources>
        <conv:KillTypeToColorConverter x:Key="KillTypeToColorConverter" />
        <conv:KillTypeToIconConverter  x:Key="KillTypeToIconConverter" />
        <conv:RelativeTimeConverter    x:Key="RelativeTimeConverter" />
        <conv:LocalTimeConverter       x:Key="LocalTimeConverter" />
        <global:SummaryFormatter         x:Key="SummaryFormatter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                CornerRadius="16"
                Padding="20,16"
                Margin="0,0,0,20"
                BorderBrush="{DynamicResource AccentGoldBrush}"
                BorderThickness="2"
                Effect="{DynamicResource CardShadow}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="💀"
                               FontSize="36"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <TextBlock Text="Kill Tracker"
                               FontSize="32"
                               FontWeight="Black"
                               Foreground="#C2A23A"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="ConnectionStatus"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"
                           Foreground="#90EE90"
                           Text="Connecting..." />
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceAltBrush}"
                CornerRadius="16"
                Padding="24"
                BorderBrush="{DynamicResource PanelStrokeBrush}"
                BorderThickness="1"
                Effect="{DynamicResource CardShadow}">

            <DockPanel LastChildFill="True">

                <!-- Main Content -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Summary Cards -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="200"/>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" MinWidth="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- FPS Kills -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource SurfaceAltBrush}"
                                CornerRadius="14"
                                Padding="24"
                                BorderBrush="#4CAF50"
                                BorderThickness="0,0,0,3"
                                Effect="{DynamicResource CardShadow}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🎯 FPS KILLS"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtFpsKillCount"
                                           Text="0"
                                           FontSize="48"
                                           FontWeight="Black"
                                           Foreground="#4CAF50"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- AIR Kills -->
                        <Border Grid.Column="2"
                                Background="{DynamicResource SurfaceAltBrush}"
                                CornerRadius="14"
                                Padding="24"
                                BorderBrush="#E53935"
                                BorderThickness="0,0,0,3"
                                Effect="{DynamicResource CardShadow}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="✈️ AIR KILLS"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#888"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtAirKillCount"
                                           Text="0"
                                           FontSize="48"
                                           FontWeight="Black"
                                           Foreground="#E53935"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Recent Kills List -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="14"
                            BorderBrush="{DynamicResource PanelStrokeBrush}"
                            BorderThickness="1"
                            Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📜"
                                           FontSize="20"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Recent Kills"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#C2A23A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="320">
                                <ItemsControl x:Name="RecentKillsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type entities:KillEntity}">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="5"/>   <!-- accent bar -->
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Accent bar driven by converter -->
                                                <Border Grid.Column="0"
                                                        Background="{Binding Type, Converter={StaticResource KillTypeToColorConverter}}"
                                                        CornerRadius="3"/>

                                                <!-- Card -->
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource CardBackground}"
                                                        BorderBrush="{DynamicResource PanelStrokeBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="10">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Type, Converter={StaticResource KillTypeToIconConverter}}"
                                                                   Background="#E53935"
                                                                   FontSize="18"
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock>
                                                            <Run Text="{Binding Timestamp, Converter={StaticResource RelativeTimeConverter}}"
                                                                 Foreground="#aaa" FontSize="12"/>
                                                            <Run Text="  •  " Foreground="#555"/>
                                                            <!-- local formatted time -->
                                                            <Run Text="{Binding Timestamp, Converter={StaticResource LocalTimeConverter}}"
                                                                 Foreground="#ffd700" FontSize="12" FontWeight="SemiBold"/>
                                                            <Run Text="  •  " Foreground="#555"/>
                                                            <!-- summary cleaned -->
                                                            <Run Text="{Binding Summary, Converter={StaticResource SummaryFormatter}}"
                                                                 Foreground="White" FontSize="14"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
