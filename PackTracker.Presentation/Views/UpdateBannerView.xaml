<UserControl x:Class="PackTracker.Presentation.Views.UpdateBannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:vm="clr-namespace:PackTracker.Presentation.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:UpdateNotificationViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             VerticalAlignment="Top"
             HorizontalAlignment="Center"
             IsHitTestVisible="True"
             Visibility="{Binding ShowBanner, Converter={StaticResource BoolToVisibilityConverter}}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Status accent dot color, swapped by status via DataTriggers below -->
        <SolidColorBrush x:Key="BannerAccentBrush" Color="#C2A23A"/>
        <SolidColorBrush x:Key="BannerReadyBrush"  Color="#4CAF50"/>
        <SolidColorBrush x:Key="BannerUpdatedBrush" Color="#2ECC71"/>
        <SolidColorBrush x:Key="BannerErrorBrush"  Color="#DC3545"/>

        <Style x:Key="BannerActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="{DynamicResource AccentGoldBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ActionButtonStyle" BasedOn="{StaticResource BannerActionButton}">
            <Setter Property="Command" Value="{Binding OpenDialogCommand}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUpdated}" Value="True">
                    <Setter Property="Command" Value="{Binding DismissUpdateCommand}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border" x:Key="InnerDotStyle">
            <Setter Property="Background" Value="{StaticResource BannerAccentBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReadyToInstall}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BannerReadyBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUpdated}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BannerUpdatedBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BannerErrorBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Click-anywhere-on-banner opens the dialog -->
    <Border x:Name="BannerRoot"
            Margin="0,12,0,0"
            Padding="5,10"
            MinWidth="420"
            MaxWidth="560"
            HorizontalAlignment="Center"
            CornerRadius="10"
            Cursor="Hand"
            Background="#1A1A1A"
            BorderBrush="#C2A23A"
            BorderThickness="1"
            MouseLeftButtonUp="BannerRoot_MouseLeftButtonUp">
        <Border.Effect>
            <DropShadowEffect Color="#C2A23A"
                              BlurRadius="14"
                              ShadowDepth="0"
                              Opacity="0.35"
                              x:Name="BannerGlow"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status dot -->
            <Border Grid.Column="0"
                    Width="10"
                    Height="10"
                    CornerRadius="5"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Style="{StaticResource InnerDotStyle}"
                    x:Name="StatusDot">
                <Border.Effect>
                    <DropShadowEffect Color="{Binding Background.Color, ElementName=StatusDot}"
                                      BlurRadius="8"
                                      ShadowDepth="0"
                                      Opacity="0.9"/>
                </Border.Effect>
            </Border>

            <!-- Headline + subtext -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding BannerHeadline}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding BannerSubtext}"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Right side: progress mini bar OR action button -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- Inline progress (only when downloading) -->
                <Border Width="120"
                        Height="6"
                        CornerRadius="3"
                        Background="#2E2E2E"
                        Margin="0,0,12,0"
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid HorizontalAlignment="Left">
                        <ProgressBar Value="{Binding DownloadProgress, Mode=OneWay}"
                                     Minimum="0"
                                     Maximum="100"
                                     Width="120"
                                     Height="6"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource AccentGoldBrush}"/>
                    </Grid>
                </Border>

                <Button Style="{StaticResource ActionButtonStyle}"
                        Content="{Binding PrimaryActionLabel}"/>
            </StackPanel>
        </Grid>

        <!-- Status-driven recolor of border + dot -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A"/>
                <Setter Property="BorderBrush" Value="{StaticResource BannerAccentBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsReadyToInstall}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BannerReadyBrush}"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#4CAF50"
                                                  BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.45"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsUpdated}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BannerUpdatedBrush}"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#2ECC71"
                                                  BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.45"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsFailed}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BannerErrorBrush}"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#DC3545"
                                                  BlurRadius="10"
                                                  ShadowDepth="0"
                                                  Opacity="0.35"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
</UserControl>
