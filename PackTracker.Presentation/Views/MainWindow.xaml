<Window x:Class="PackTracker.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PackTracker"
        MinHeight="720"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MainBackground}"
        Icon="/Assets/housewolf2.ico"
        SizeToContent="Manual"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="20"
                Padding="18"
                Style="{StaticResource SectionCardStyle}"
                Background="{DynamicResource HeroGradientBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Bottom" Margin="0,20,0,0">
                    <Border Style="{StaticResource GlassPanelStyle}" Padding="8,6" Margin="0,0,0,14">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtLocalTime"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock x:Name="TxtTimeZone"
                                       FontSize="9"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Opacity="0.6"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel>
                    <Border Style="{StaticResource GlassPanelStyle}" Padding="18" Margin="0,0,0,18">
                        <StackPanel>
                            <Image Source="{DynamicResource SidebarImage}"
                                   Width="120"
                                   Height="120"
                                   HorizontalAlignment="Center"
                                   Stretch="Uniform"
                                   Margin="0,0,0,14" />
                            <TextBlock Text="PackTracker"
                                       FontSize="28"
                                       FontWeight="Black"
                                       Foreground="White"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="House Wolf Operations Center"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GlassPanelStyle}" Padding="16" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Navigation"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource AccentGoldBrush}"
                                       Margin="0,0,0,12" />

                            <Grid>
                                <StackPanel x:Name="NavButtonPanel">
                                    <Button Content="Dashboard"
                                            Tag="Dashboard"
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Click="Navigate_Click" />
                                    <Button Content="Trading Hub"
                                            Tag="TradingHub"
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Click="Navigate_Click" />
                                    <Button Content="Blueprints"
                                            Tag="Blueprints"
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Click="Navigate_Click" />
                                    <Button Content="Crafting Center"
                                            Tag="CraftingQueue"
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Click="Navigate_Click" />
                                    <Button Content="Procurement Center"
                                            Tag="ProcurementQueue"
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Click="Navigate_Click" />
                                    <Button Content="Request Hub"
                                            Tag="RequestHub"
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Click="Navigate_Click" />
                                    <Button Content="Settings"
                                            Tag="Settings"
                                            Style="{StaticResource SidebarButtonStyle}"
                                            Click="Navigate_Click" />
                                </StackPanel>
                                <!-- Transparent overlay blocks all mouse input when user is not authenticated -->
                                <Border x:Name="NavBlocker"
                                        Background="Transparent"
                                        Visibility="Collapsed"
                                        IsHitTestVisible="True" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2"
                                Margin="0,18,0,18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top">

                        <Grid Width="90" Height="90" Margin="0,0,0,12">
                            <Ellipse Width="90"
                                     Height="90"
                                     Stroke="#B15B34"
                                     StrokeThickness="3" />

                            <Image x:Name="SidebarAvatarImage"
                                   Width="84"
                                   Height="84"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Source="{Binding CurrentUserAvatar}">
                                <Image.Clip>
                                    <EllipseGeometry Center="42,42" RadiusX="42" RadiusY="42" />
                                </Image.Clip>
                            </Image>
                        </Grid>

                        <TextBlock Text="Welcome Dragoon,"
                                   FontSize="11"
                                   Foreground="#D7A56B"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,2" />

                        <TextBlock Text="{Binding DiscordDisplayName}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,4" />

                        <Border Background="#223A4A5A"
                                CornerRadius="10"
                                Padding="10,4"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,8">
                            <TextBlock Text="{Binding DiscordRank}"
                                       FontSize="11"
                                       Foreground="#C9D6E3"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <Border Style="{StaticResource GlassPanelStyle}" Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="PostureTitle"
                                       Text="Operational posture"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentGoldBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12" />

                            <!-- Normal state -->
                            <StackPanel x:Name="NormalPostureContent">
                                <TextBlock
                                    Text="Use this to navigate between dashboard, logistics, requests, and system configuration."
                                    FontSize="11"
                                    TextWrapping="Wrap"
                                    Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Button Content="Exit"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Margin="0,16,0,0"
                                        Click="Exit_Click" />
                            </StackPanel>

                            <!-- Update available state (hidden until an update is found) -->
                            <StackPanel x:Name="UpdatePostureContent" Visibility="Collapsed">
                                <TextBlock x:Name="UpdateVersionLabel"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,6"
                                           TextWrapping="Wrap" />
                                <Border Background="#0D1A0D"
                                        BorderBrush="#1E4A1E"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Margin="0,0,0,12">
                                    <ScrollViewer MaxHeight="100"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock x:Name="UpdateNotesText"
                                                   FontSize="11"
                                                   Foreground="#A8C8A8"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>
                                <Button x:Name="DownloadUpdateButton"
                                        Content="DOWNLOAD UPDATE"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Margin="0,0,0,8"
                                        Click="DownloadUpdate_Click" />
                                <ProgressBar x:Name="DownloadProgressBar"
                                             Height="8"
                                             Minimum="0"
                                             Maximum="100"
                                             Visibility="Collapsed"
                                             Background="#30FFFFFF"
                                             Foreground="{StaticResource AccentBrush}"
                                             Margin="0,0,0,6" />
                                <TextBlock x:Name="DownloadStatusText"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Visibility="Collapsed"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="0,20,20,20">
            <Image Source="/Assets/Pack_Tracker.png"
                   Opacity="0.30"
                   Stretch="UniformToFill"
                   IsHitTestVisible="False"
                   Panel.ZIndex="0" />

            <Border Panel.ZIndex="1"
                    Style="{StaticResource SectionCardStyle}"
                    Padding="0"
                    Background="Transparent">
                <Grid>
                    <Border Background="#14000000"
                            CornerRadius="18"
                            Margin="0" />
                    <Frame x:Name="ContentFrame"
                           Margin="0"
                           Padding="0"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>