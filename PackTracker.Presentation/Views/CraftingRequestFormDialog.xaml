<Window x:Class="PackTracker.Presentation.Views.CraftingRequestFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
        Title="New Crafting Request"
        Width="620" Height="720"
        Background="Transparent" WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        AllowsTransparency="True">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="DialogTextBox" TargetType="TextBox" BasedOn="{StaticResource OpTextBoxStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DialogComboBox" TargetType="ComboBox" BasedOn="{StaticResource OpComboBoxStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="42"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Padding="28"
            Background="{StaticResource OpBackgroundPanelBrush}"
            BorderBrush="#C0531A" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="REQUEST CRAFTING"
                           FontSize="24" FontWeight="Black"
                           Foreground="{StaticResource OpTextTitleBrush}"/>
                <TextBlock Text="{Binding BlueprintName}"
                           FontSize="15"
                           Foreground="{StaticResource OpTextAccentBrush}"
                           Margin="0,5,0,0"/>
                <TextBlock Text="{Binding SubmissionTimePreview}"
                           FontSize="12"
                           Foreground="{StaticResource OpTextMutedBrush}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource OpScrollViewerStyle}">
                <StackPanel Margin="0,0,6,0">
                    <TextBlock Text="MATERIALS" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding MaterialSupplyModeOptions}"
                              SelectedItem="{Binding SelectedMaterialSupplyMode}"
                              Style="{StaticResource DialogComboBox}"
                              Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="REWARD OFFERED" Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock Text=" *" Foreground="#E84040" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding RewardOffered, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogTextBox}"
                             ToolTip="e.g. 500k aUEC, split 70/30, negotiable"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="PRIORITY" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding PriorityOptions}"
                              SelectedItem="{Binding SelectedPriority}"
                              Style="{StaticResource DialogComboBox}"
                              Margin="0,0,0,14"/>

                    <TextBlock Text="QUANTITY" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding QuantityRequested, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogTextBox}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="MINIMUM QUALITY" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding MinimumQuality, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogTextBox}"
                             ToolTip="500-1000"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="MAX CLAIMS" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding MaxClaimsText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogTextBox}"
                             ToolTip="Leave blank for default of 1"
                             Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="DELIVERY LOCATION" Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock Text=" *" Foreground="#E84040" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding DeliveryLocation, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogTextBox}"
                             ToolTip="e.g. Port Olisar, Crusader L1"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="NOTES" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DialogTextBox}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="120"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="Special instructions or context for the crafter"
                             Margin="0,0,0,4"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock Text="* Required fields" Foreground="#E84040" FontSize="11"/>
                    <TextBlock Text="{Binding ValidationMessage}"
                               Foreground="#FFB36B"
                               FontSize="11"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding ValidationMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="CANCEL"
                            Command="{Binding CancelCommand}"
                            Padding="18,10"
                            FontWeight="Bold"
                            FontSize="13"
                            Background="#24374A"
                            Foreground="#E8F0F8"
                            BorderBrush="#4F6A84"
                            BorderThickness="1"
                            Margin="0,0,10,0"/>
                    <Button Content="SUBMIT REQUEST"
                            Command="{Binding SubmitCommand}"
                            IsEnabled="{Binding CanSubmit}"
                            Padding="18,10"
                            FontWeight="Bold"
                            FontSize="13"
                            Background="#2B4E2E"
                            Foreground="#EEF6EE"
                            BorderBrush="#5C8B5E"
                            BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
