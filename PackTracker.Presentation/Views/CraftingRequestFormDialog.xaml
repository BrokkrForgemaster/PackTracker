<Window x:Class="PackTracker.Presentation.Views.CraftingRequestFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Crafting Request"
        Width="520" Height="620"
        Background="Transparent" WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <!-- Drag to move -->
    <Border CornerRadius="16" Padding="28"
            Background="{StaticResource OpBackgroundPanelBrush}"
            BorderBrush="#C0531A" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="REQUEST CRAFTING"
                           FontSize="20" FontWeight="Black"
                           Foreground="{StaticResource OpTextTitleBrush}"/>
                <TextBlock Text="{Binding BlueprintName}"
                           FontSize="13" Foreground="{StaticResource OpTextAccentBrush}"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Form Body -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource OpScrollViewerStyle}">
                <StackPanel Margin="0,0,6,0">

                    <!-- Material Supply -->
                    <TextBlock Text="MATERIALS" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding MaterialSupplyModeOptions}"
                              SelectedItem="{Binding SelectedMaterialSupplyMode}"
                              Style="{StaticResource OpComboBoxStyle}"
                              Margin="0,0,0,14"/>

                    <!-- Reward -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="REWARD OFFERED" Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock Text=" *" Foreground="#E84040" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding RewardOffered, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource OpTextBoxStyle}"
                             ToolTip="e.g. 500k aUEC, split 70/30, negotiable"
                             Margin="0,0,0,14"/>

                    <!-- Priority -->
                    <TextBlock Text="PRIORITY" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding PriorityOptions}"
                              SelectedItem="{Binding SelectedPriority}"
                              Style="{StaticResource OpComboBoxStyle}"
                              Margin="0,0,0,14"/>

                    <!-- Quantity -->
                    <TextBlock Text="QUANTITY" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding QuantityRequested, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource OpTextBoxStyle}"
                             Margin="0,0,0,14"/>

                    <!-- Min Quality -->
                    <TextBlock Text="MINIMUM QUALITY" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding MinimumQuality, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource OpTextBoxStyle}"
                             ToolTip="500–1000"
                             Margin="0,0,0,14"/>

                    <!-- Delivery Location -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="DELIVERY LOCATION" Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock Text=" *" Foreground="#E84040" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding DeliveryLocation, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource OpTextBoxStyle}"
                             ToolTip="e.g. Port Olisar, Crusader L1"
                             Margin="0,0,0,14"/>

                    <!-- Notes -->
                    <TextBlock Text="NOTES" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource OpTextBoxStyle}"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="80"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="Special instructions or context for the crafter"
                             Margin="0,0,0,4"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="2" Margin="0,18,0,0">
                <TextBlock Text="* Required fields" Foreground="#E84040" FontSize="10"
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="CANCEL"
                            Command="{Binding CancelCommand}"
                            Padding="16,8" FontWeight="Bold"
                            Background="#24374A" Foreground="#E8F0F8"
                            BorderBrush="#4F6A84" BorderThickness="1"
                            Margin="0,0,10,0"/>
                    <Button Content="SUBMIT REQUEST"
                            Command="{Binding SubmitCommand}"
                            Padding="16,8" FontWeight="Bold"
                            Background="#2B4E2E" Foreground="#EEF6EE"
                            BorderBrush="#5C8B5E" BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
