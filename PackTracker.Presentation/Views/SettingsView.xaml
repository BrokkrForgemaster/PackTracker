<UserControl x:Class="PackTracker.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Style="{StaticResource OpHeaderBorderStyle}" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="SYSTEM CONFIGURATION" Foreground="{StaticResource OpTextTitleBrush}" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Manage operational parameters, API credentials, and game log integration for the House Wolf shell."
                           Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="800" HorizontalAlignment="Center" VerticalAlignment="Center" Width="800">

                <!-- Appearance Section -->
                <Border Style="{StaticResource OpPanelBorderStyle}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="APPEARANCE" Foreground="{StaticResource OpTextTitleBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Active Theme" Foreground="{StaticResource OpTextSecondaryBrush}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="CmbThemes" SelectionChanged="cmbThemes_SelectionChanged" Style="{StaticResource OpComboBoxStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- API Configuration Section -->
                <Border Style="{StaticResource OpPanelBorderStyle}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="BACKEND READINESS"
                                           Foreground="{StaticResource OpTextTitleBrush}"
                                           FontSize="14"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Shows whether the API is alive, whether startup initialization completed, and whether schema drift is blocking healthy operation."
                                           Foreground="{StaticResource OpTextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="BtnRefreshDiagnostics"
                                    Content="REFRESH STATUS"
                                    Click="RefreshDiagnostics_Click"
                                    Padding="16,8"
                                    Margin="16,0,0,0"
                                    FontWeight="Bold"
                                    Background="#3A3A3A"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </Grid>

                        <Border x:Name="BackendStatusBorder"
                                Background="#2A2A2A"
                                BorderBrush="#4A4A4A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock x:Name="TxtBackendOverallStatus"
                                           Text="Checking backend status..."
                                           Foreground="{StaticResource OpTextTitleBrush}"
                                           FontSize="13"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="TxtBackendSummary"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource OpTextSecondaryBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtBackendDetails"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource OpTextMutedBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="EXTERNAL API CREDENTIALS" Foreground="{StaticResource OpTextTitleBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>


                        <!-- UEXCorp API Key -->
                        <StackPanel>
                            <TextBlock Text="UEXCORP API KEY" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtUexcorpApiKey" Style="{StaticResource OpTextBoxStyle}"/>
                            <TextBlock Text="Required for real-time market data and trade route analysis." Foreground="{StaticResource OpTextMutedBrush}" FontSize="11" Margin="4,4,0,0"/>
                        </StackPanel>
                   
                        <TextBlock Text="GAME INTEGRATION" Foreground="{StaticResource OpTextTitleBrush}" FontSize="14" FontWeight="Bold" Margin="0,25,0,16"/>
                        <StackPanel>
                            <TextBlock Text="STAR CITIZEN LOG PATH" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtGameLogFilePath" Style="{StaticResource OpTextBoxStyle}"/>
                            <TextBlock Text="Path to Game.log for real-time event parsing (kills, deaths, disconnects)." Foreground="{StaticResource OpTextMutedBrush}" FontSize="11" Margin="4,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>


            
            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer / Actions ── -->
        <Border Grid.Row="2" Style="{StaticResource OpHeaderBorderStyle}" Margin="0,16,0,0" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Operational changes require a manual save to persist to the system registry." 
                           Foreground="{StaticResource OpTextSecondaryBrush}" VerticalAlignment="Center" FontSize="12"/>

                <Button Grid.Column="1" Content="CANCEL" Click="Cancel_Click" Margin="0,0,12,0" Padding="20,8" FontWeight="Bold" Background="#3A3A3A" Foreground="White" BorderThickness="0"/>
                <Button Grid.Column="2" Content="SAVE CONFIGURATION" Click="Save_Click" Padding="24,8" FontWeight="Bold" Background="#8B1A0F" Foreground="#F4EBDD" BorderBrush="#B15B34" BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
