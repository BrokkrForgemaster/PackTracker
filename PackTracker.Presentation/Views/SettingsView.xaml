<UserControl x:Class="PackTracker.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Border
            Padding="32"
            Background="{DynamicResource CardBackground}"
            CornerRadius="16"
            Effect="{DynamicResource CardShadow}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center">

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/> <!-- Header -->
          <RowDefinition Height="*"/>    <!-- Inputs -->
          <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="38"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,32"/>

        <!-- Inputs -->
        <StackPanel Grid.Row="1"
                    Margin="0,0,0,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="800"
                    >

          <!-- Theme -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Theme:"
                       FontSize="22"
                       Foreground="White"
                       Width="200"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,16,0"/>
            <ComboBox x:Name="CmbThemes"
                      SelectionChanged="cmbThemes_SelectionChanged"
                      FontSize="22" Height="42"
                      Width="500"
                      VerticalContentAlignment="Center"
                      Padding="4,0"/>
          </StackPanel>

          <!-- Regolith API Key -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Regolith API Key:"
                       FontSize="22"
                       Foreground="White"
                       Width="200"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,16,0"/>
            <TextBox x:Name="TxtRegolithApiKey"
                     FontSize="22"
                     Height="42"
                     Width="500"
                     Padding="8,0"
                     VerticalContentAlignment="Center"/>
          </StackPanel>

          <!-- Uexcorp API Key -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Uexcorp API Key:"
                       FontSize="22"
                       Foreground="White"
                       Width="200"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,16,0"/>
            <TextBox x:Name="TxtUexcorpApiKey"
                     FontSize="22"
                     Height="42"
                     Width="500"
                     Padding="8,0"
                     VerticalContentAlignment="Center"/>
          </StackPanel>

          <!-- Discord Connected -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Discord Connected:"
                       FontSize="22"
                       Foreground="White"
                       Width="200"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,16,0"/>
            <CheckBox x:Name="ChkDiscordConnected"
                      FontSize="22"
                      Height="42"
                      Width="500"
                      VerticalAlignment="Bottom"
                      Content="Connected"
                      Foreground="White"/>
          </StackPanel>

          <!-- Game Log File Path -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Game Log File Path:"
                       FontSize="22"
                       Foreground="White"
                       Width="200"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,0,16,0"/>
            <TextBox x:Name="TxtGameLogFilePath"
                     FontSize="22"
                     Height="42"
                     Width="500"
                     Padding="8,0"
                     VerticalContentAlignment="Center"/>
          </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,36,0,0"
                    >
          <Button
            Content="Cancel"
            Click="Cancel_Click"
            Width="150"
            Height="44"
            FontSize="18"
            Margin="0,0,16,0"
            Background="#FF454A58"
            Foreground="White"
            BorderBrush="#CC23232A"
            BorderThickness="1"
            />
          <Button
            Content="Save"
            Click="Save_Click"
            Width="150"
            Height="44"
            FontSize="18"
            Margin="16,0,0,0"
            Background="#FF0078D7"
            Foreground="White"
            BorderBrush="#FF005CA1"
            BorderThickness="1"
            />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
