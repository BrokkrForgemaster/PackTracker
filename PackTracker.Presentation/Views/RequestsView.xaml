<UserControl x:Class="PackTracker.Presentation.Views.RequestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        
        <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>  <!-- Header -->
        <RowDefinition Height="Auto"/>  <!-- Filters -->
        <RowDefinition Height="*"/>     <!-- Data grid expands -->
        <RowDefinition Height="Auto"/>  <!-- Action buttons -->
        </Grid.RowDefinitions>
        <!-- Outer floating container -->
        <Border Background="#202020"
                CornerRadius="24"
                Padding="32"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="Auto"/>  <!-- Filters -->
                    <RowDefinition Height="*"/>     <!-- Data grid expands -->
                    <RowDefinition Height="Auto"/>  <!-- Action buttons -->
                </Grid.RowDefinitions>
                <!-- Header -->
                <TextBlock Grid.Row="0" Text="Request Assistance Hub" />

                <!-- Filters -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" />

                <!-- List -->
                <DataGrid Grid.Row="2" />

                <!-- Actions -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" />
                

                  
                <!-- Header -->
                <StackPanel Orientation="Vertical" Margin="0,0,0,16">
                    <TextBlock Text="Request Assistance Hub"
                               FontSize="36"
                               FontWeight="Black"
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="16"
                               Foreground="#DDDDDD"
                               MaxWidth="900"
                               Margin="0,0,0,12">
                        Use this hub to request help from other House Wolf members.
                        Requests are shared through the organization’s Discord channel so others can respond.
                        You can ask for mission help, resource gathering, event support, or general assistance.
                    </TextBlock>

                    <Border Background="#2A2A2A" CornerRadius="10" Padding="10" Margin="0,4,0,8">
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="#BBBBBB"
                                   Text="💡 Tip: You can double-click a request to view details or mark it complete when finished."/>
                    </Border>
                </StackPanel>

                <!-- Filters -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20"
                           >

                    <ComboBox Width="180"
                              ItemsSource="{Binding KindOptions}"
                              SelectedItem="{Binding SelectedKind}"
                              Background="#2B2B2B"
                              Foreground="Black"
                              BorderBrush="#444"
                              Padding="6,2"
                              FontWeight="SemiBold"
                              ToolTip="Filter by request type"/>

                    <ComboBox Width="160"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Background="#2B2B2B"
                              Foreground="Black"
                              BorderBrush="#444"
                              Padding="6,2"
                              FontWeight="SemiBold"
                              ToolTip="Filter by status"/>

                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Background="#C2A23A"
                            Foreground="Black"
                            FontWeight="Bold"
                            Padding="14,6"
                            ToolTip="Reload requests from the server"/>
                </StackPanel>

                <!-- Request List -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Requests}"
                          SelectedItem="{Binding SelectedRequest}"
                          AutoGenerateColumns="False"
                          Background="#181818"
                          Foreground="Black"
                          BorderBrush="#333"
                          RowBackground="#252525"
                          AlternatingRowBackground="#1E1E1E"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          Margin="0,0,0,24"
                          RowHeight="44"
                          FontSize="14"
                          IsReadOnly="True"
                          ToolTip="Existing assistance requests within the organization">
                    <DataGrid.Columns
                        
                        >
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="1*" />
                        <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="1*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*" />
                        <DataGridTextColumn Header="Created By" Binding="{Binding CreatedByDisplayName}" Width="1.3*" />
                        <DataGridTextColumn Header="Assigned To" Binding="{Binding AssignedToDisplayName}" Width="1.3*" />
                        <DataGridTextColumn Header="Created At"
                                            Binding="{Binding CreatedAt, StringFormat='{}{0:g}'}"
                                            Width="1.4*" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Actions -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            >

                    <Button Content="➕  New Request"
                            Command="{Binding NewRequestCommand}"
                            Background="#C2A23A"
                            Foreground="Black"
                            FontWeight="Bold"
                            Padding="16,8"
                            ToolTip="Create a new assistance request"/>

                    <Button Content="✏️  Edit"
                            Command="{Binding EditCommand}"
                            IsEnabled="{Binding SelectedRequest, Converter={StaticResource NullToVisibilityConverter}}"
                            Background="#3A3A3A"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="16,8"
                            ToolTip="Edit selected request"/>

                    <Button Content="✔️  Mark Complete"
                            Command="{Binding CompleteCommand}"
                            IsEnabled="{Binding SelectedRequest, Converter={StaticResource NullToVisibilityConverter}}"
                            Background="#2D8A4E"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="16,8"
                            ToolTip="Mark selected request as complete"/>

                    <Button Content="🗑️  Delete"
                            Command="{Binding DeleteCommand}"
                            IsEnabled="{Binding SelectedRequest, Converter={StaticResource NullToVisibilityConverter}}"
                            Background="#8A2D2D"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="16,8"
                            ToolTip="Delete selected request"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
