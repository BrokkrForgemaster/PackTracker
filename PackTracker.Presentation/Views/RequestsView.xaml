<UserControl x:Class="PackTracker.Presentation.Views.RequestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:RequestKindToColorConverter x:Key="RequestKindToColorConverter" />
        <converters:RequestPriorityToColorConverter x:Key="RequestPriorityToColorConverter" />
        <converters:RequestKindToIconConverter x:Key="RequestKindToIconConverter" />

        <!-- Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Border Background="{DynamicResource SurfaceAltBrush}"
                CornerRadius="24"
                Padding="32"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="Auto"/>  <!-- Filters -->
                    <RowDefinition Height="*"/>     <!-- Content -->
                    <RowDefinition Height="Auto"/>  <!-- Actions -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,24">
                    <TextBlock Text="🤝 Request Assistance Hub"
                               FontSize="36"
                               FontWeight="Black"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="15"
                               Foreground="#CCCCCC"
                               MaxWidth="900"
                               Margin="0,0,0,16">
                        Request help from House Wolf members for materials, missions, escorts, and more.
                        Click a request to view details, or create your own to get assistance from the org.
                    </TextBlock>

                    <Border Background="{DynamicResource CardBackground}" CornerRadius="10" Padding="12" Margin="0,0,0,0" MaxWidth="800">
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="#AAAAAA"
                                   TextAlignment="Center"
                                   Text="💡 Select a request to see full details including materials, location, and rewards. Use 'Claim' to help someone!"/>
                    </Border>
                </StackPanel>

                <!-- Filters -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">

                    <ComboBox Width="200"
                              ItemsSource="{Binding KindOptions}"
                              SelectedItem="{Binding SelectedKind}"
                              Background="{DynamicResource SurfaceAltBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource PanelStrokeBrush}"
                              BorderThickness="1"
                              Padding="12,8"
                              Margin="6"
                              FontSize="14"
                              ToolTip="Filter by request type"/>

                    <ComboBox Width="180"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Background="{DynamicResource SurfaceAltBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource PanelStrokeBrush}"
                              BorderThickness="1"
                              Padding="12,8"
                              Margin="6"
                              FontSize="14"
                              ToolTip="Filter by status"/>

                    <Button Content="🔄 Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ModernButton}"
                            Background="#C2A23A"
                            Foreground="Black"
                            ToolTip="Reload requests from server"/>
                </StackPanel>

                <!-- Request Cards & Detail Panel -->
                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Request Cards List -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="16"
                            BorderBrush="{DynamicResource PanelStrokeBrush}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,12,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Requests}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                                CornerRadius="12"
                                                Margin="6"
                                                Padding="16"
                                                BorderThickness="0,0,0,3"
                                                BorderBrush="{Binding Priority, Converter={StaticResource RequestPriorityToColorConverter}}"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                            Command="{Binding DataContext.SelectRequestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Header Row -->
                                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon & Title -->
                                                    <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Kind, Converter={StaticResource RequestKindToIconConverter}}"
                                                                   FontSize="24"
                                                                   Margin="0,0,12,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- Priority Badge -->
                                                    <Border Grid.Column="2"
                                                            Background="{Binding Priority, Converter={StaticResource RequestPriorityToColorConverter}}"
                                                            CornerRadius="6"
                                                            Padding="8,4"
                                                            Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Priority}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Meta Info -->
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="{Binding Kind, Converter={StaticResource RequestKindToColorConverter}}"
                                                            CornerRadius="6"
                                                            Padding="8,4"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Kind}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"/>
                                                    </Border>

                                                    <Border Background="#3A3A3A"
                                                            CornerRadius="6"
                                                            Padding="8,4">
                                                        <TextBlock FontSize="11"
                                                                   Foreground="#AAAAAA">
                                                            <Run Text="Status:"/>
                                                            <Run Text="{Binding Status}" FontWeight="SemiBold"/>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Quick Info -->
                                                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,4,0,0">
                                                    <TextBlock FontSize="12" Foreground="#BBBBBB">
                                                        <Run Text="👤 Requested by:"/>
                                                        <Run Text="{Binding CreatedByDisplayName}" FontWeight="SemiBold" Foreground="White"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="#BBBBBB" Margin="0,4,0,0">
                                                        <Run Text="🕒"/>
                                                        <Run Text="{Binding CreatedAt, StringFormat='{}{0:g}'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Detail Panel -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="16"
                            BorderBrush="{DynamicResource PanelStrokeBrush}"
                            BorderThickness="1"
                            Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Show when no selection -->
                                <TextBlock Text="Select a request to view details"
                                           FontSize="16"
                                           Foreground="#777"
                                           TextAlignment="Center"
                                           Margin="0,40,0,0"
                                           Visibility="{Binding SelectedRequest, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>

                                <!-- Show when selected -->
                                <StackPanel Visibility="{Binding SelectedRequest, Converter={StaticResource NullToVisibilityConverter}}">
                                    <!-- Title -->
                                    <TextBlock Text="{Binding SelectedRequest.Title}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,16"/>

                                    <!-- Description -->
                                    <TextBlock Text="Description"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#C2A23A"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedRequest.Description}"
                                               FontSize="13"
                                               Foreground="#CCCCCC"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,16"/>

                                    <!-- Material Details (if applicable) -->
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            CornerRadius="10"
                                            Padding="16"
                                            Margin="0,0,0,16"
                                            Visibility="{Binding SelectedRequest.MaterialName, Converter={StaticResource NullToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="📦 Material Details"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="#FFA500"
                                                       Margin="0,0,0,12"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Material:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.MaterialName}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8" Visibility="{Binding SelectedRequest.QuantityNeeded, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Quantity:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.QuantityNeeded}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8" Visibility="{Binding SelectedRequest.MeetingLocation, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Location:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.MeetingLocation}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,0" Visibility="{Binding SelectedRequest.RewardOffered, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Reward:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.RewardOffered}" FontSize="12" Foreground="#FFD700" FontWeight="Bold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Helper Info (if applicable) -->
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            CornerRadius="10"
                                            Padding="16"
                                            Margin="0,0,0,16"
                                            Visibility="{Binding SelectedRequest.NumberOfHelpersNeeded, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="👥 Helpers Needed:" FontSize="13" Foreground="#AAA" Width="140"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.NumberOfHelpersNeeded}" FontSize="13" Foreground="White" FontWeight="Bold"/>
                                        </Grid>
                                    </Border>

                                    <!-- Request Info -->
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            CornerRadius="10"
                                            Padding="16"
                                            Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="ℹ️ Request Information"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="#6DB3F2"
                                                       Margin="0,0,0,12"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Type:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.Kind}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Priority:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.Priority}" FontSize="12" Foreground="{Binding SelectedRequest.Priority, Converter={StaticResource RequestPriorityToColorConverter}}" FontWeight="Bold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Status:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.Status}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Requested by:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.CreatedByDisplayName}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8" Visibility="{Binding SelectedRequest.AssignedToDisplayName, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Assigned to:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.AssignedToDisplayName}" FontSize="12" Foreground="#90EE90" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Created:" FontSize="12" Foreground="#AAA" Width="100"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedRequest.CreatedAt, StringFormat='{}{0:g}'}" FontSize="12" Foreground="White"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Action Buttons -->
                                    <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                                        <Button Content="🤝 Claim Request"
                                                Command="{Binding ClaimCommand}"
                                                Style="{StaticResource ModernButton}"
                                                Background="#2D8A4E"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,8"
                                                ToolTip="Claim this request to help"/>

                                        <Button Content="✔️ Mark Complete"
                                                Command="{Binding CompleteCommand}"
                                                Style="{StaticResource ModernButton}"
                                                Background="#1E6B3B"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,8"
                                                ToolTip="Mark as completed"/>

                                        <Button Content="🗑️ Delete Request"
                                                Command="{Binding DeleteCommand}"
                                                Style="{StaticResource ModernButton}"
                                                Background="#8A2D2D"
                                                HorizontalAlignment="Stretch"
                                                ToolTip="Delete this request"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Content="➕ New Request"
                            Command="{Binding NewRequestCommand}"
                            Style="{StaticResource ModernButton}"
                            Background="#C2A23A"
                            Foreground="Black"
                            FontSize="16"
                            Padding="24,12"
                            ToolTip="Create a new assistance request"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
