<UserControl x:Class="PackTracker.Presentation.Views.UpdateDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:vm="clr-namespace:PackTracker.Presentation.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:UpdateNotificationViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="DialogPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>

        <Style x:Key="DialogSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>

        <Style x:Key="DialogTextButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Backdrop covers the whole window; clicking it closes the dialog -->
    <Grid Background="#B0000000"
          MouseLeftButtonDown="Backdrop_MouseLeftButtonDown">

        <!-- Dialog card -->
        <Border MaxWidth="640"
                MinWidth="480"
                MaxHeight="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#15120F"
                BorderBrush="{DynamicResource AccentGoldBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="0"
                MouseLeftButtonDown="Card_MouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="40"
                                  ShadowDepth="6"
                                  Opacity="0.6"/>
            </Border.Effect>

            <DockPanel LastChildFill="True">

                <!-- ─── Header ─── -->
                <Border DockPanel.Dock="Top"
                        Padding="22,18,22,16"
                        BorderBrush="#2A2118"
                        BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1F1A14" Offset="0"/>
                            <GradientStop Color="#15120F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PACKTRACKER UPDATE"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentGoldBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding VersionLabel}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="28"
                                Height="28"
                                VerticalAlignment="Top"
                                Style="{StaticResource DialogTextButton}"
                                FontSize="16"
                                Content="✕"
                                Command="{Binding CloseDialogCommand}"/>
                    </Grid>
                </Border>

                <!-- ─── Footer (dock first so it's always visible) ─── -->
                <Border DockPanel.Dock="Bottom"
                        Padding="22,14,22,18"
                        BorderBrush="#2A2118"
                        BorderThickness="0,1,0,0"
                        Background="#100D0A">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource DialogTextButton}"
                                Content="Skip this version"
                                Command="{Binding SkipVersionCommand}"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource DialogSecondaryButton}"
                                    Content="REMIND ME LATER"
                                    Command="{Binding RemindLaterCommand}"/>
                            <Button Style="{StaticResource DialogPrimaryButton}"
                                    Content="RESTART NOW"
                                    Command="{Binding RestartNowCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── Body ─── -->
                <Border Padding="22,18,22,18">
                    <StackPanel>

                        <!-- Status pill -->
                        <Border HorizontalAlignment="Left"
                                Padding="10,4"
                                CornerRadius="10"
                                Margin="0,0,0,14"
                                Background="#1F1A14"
                                BorderBrush="#3E3023"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="●"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           Foreground="{DynamicResource AccentGoldBrush}"/>
                                <TextBlock Text="{Binding BannerHeadline}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Section label -->
                        <TextBlock Text="WHAT'S NEW"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,8"/>

                        <!-- Release notes (scrollable) -->
                        <Border Background="#0F0D0A"
                                BorderBrush="#2A2118"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,12"
                                MinHeight="160"
                                MaxHeight="240">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <TextBlock Text="{Binding ReleaseNotes}"
                                           FontSize="12"
                                           LineHeight="18"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Download progress (only visible during download) -->
                        <StackPanel Margin="0,16,0,0"
                                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Downloading…"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DownloadProgress, StringFormat={}{0}%}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentGoldBrush}"/>
                            </Grid>
                            <Border Background="#2E2E2E"
                                    Height="6"
                                    CornerRadius="3">
                                <ProgressBar Value="{Binding DownloadProgress, Mode=OneWay}"
                                             Minimum="0"
                                             Maximum="100"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource AccentGoldBrush}"/>
                            </Border>
                        </StackPanel>

                        <!-- Failure note -->
                        <Border Margin="0,14,0,0"
                                Padding="12,10"
                                Background="#1A0F0F"
                                BorderBrush="#DC3545"
                                BorderThickness="1"
                                CornerRadius="6"
                                Visibility="{Binding IsFailed, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding BannerSubtext}"
                                       FontSize="11"
                                       Foreground="#FFB3B3"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
