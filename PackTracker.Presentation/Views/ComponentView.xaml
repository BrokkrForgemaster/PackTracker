<UserControl x:Class="PackTracker.Presentation.Views.ComponentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Component card — all styles pulled from BlueprintStyles.xaml via App.xaml -->

    <Border Margin="0,0,0,10" CornerRadius="8" BorderThickness="1,2,1,1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#8B1A0F" Offset="0"/>
                <GradientStop Color="#2A1E12" Offset="0.2"/>
                <GradientStop Color="#2A1E12" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1E1812" Offset="0"/>
                <GradientStop Color="#14110D" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <StackPanel>

            <!-- Card Header -->
            <Border Padding="14,12" BorderBrush="#2A1E12" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Icon badge -->
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
                            Background="#2A1E12" BorderBrush="#3D2A1A" BorderThickness="1"
                            Margin="0,0,12,0" VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16">
                            <Canvas Width="24" Height="24">
                                <Polygon Points="12,2 22,7 22,17 12,22 2,17 2,7"
                                         Stroke="#C8922A" StrokeThickness="1.5" Fill="Transparent"/>
                                <Polygon Points="12,2 12,12 22,7"
                                         Stroke="#8B1A0F" StrokeThickness="1" Fill="Transparent"/>
                                <Line X1="12" Y1="12" X2="12" Y2="22"
                                      Stroke="#8B1A0F" StrokeThickness="1"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <!-- Part name + required -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PartName}"
                                   Foreground="#E8D5B0" FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="Required: 1"
                                   Foreground="#4A3A28" FontSize="10" Margin="0,1,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Material Row -->
            <Grid Margin="14,10,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="RESOURCE" Foreground="#4A3A28" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MaterialName}"
                                   Foreground="#C8922A" FontWeight="Bold" FontSize="16" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="SCU" Foreground="#4A3A28" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Quantity, StringFormat={}{0:F4}}"
                                   Foreground="#9A8A72" FontSize="15" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Quality Adjustment -->
            <Border Margin="14,0,14,12" Background="#12100E" CornerRadius="6"
                    Padding="12,10" BorderBrush="#2A1E12" BorderThickness="1">
                <StackPanel>
                    <!-- Label + value badge -->
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="QUALITY ADJUSTMENT"
                                   Foreground="#4A3A28" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border HorizontalAlignment="Right" Background="#2A1E12"
                                BorderBrush="#3D2A1A" BorderThickness="1" CornerRadius="4" Padding="8,2">
                            <TextBlock Text="{Binding QualityValue}"
                                       Foreground="#C8922A" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                    <!-- Slider + steppers -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Style="{StaticResource HouseWolfSliderStyle}"
                                Minimum="0" Maximum="1000"
                                Value="{Binding QualityValue, Mode=TwoWay}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource StepperButtonStyle}"
                                    Command="{Binding DecrementQualityCommand}"
                                    Margin="0,0,4,0">
                                <TextBlock Text="&#x2212;" Foreground="#9A8A72" FontSize="14" FontWeight="Bold"/>
                            </Button>
                            <TextBox Style="{StaticResource QuantityBoxStyle}"
                                     Text="{Binding QualityValue, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                            <Button Style="{StaticResource StepperButtonStyle}"
                                    Command="{Binding IncrementQualityCommand}"
                                    Margin="4,0,0,0">
                                <TextBlock Text="+" Foreground="#9A8A72" FontSize="14" FontWeight="Bold"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Stat Modifier Pills -->
            <ItemsControl ItemsSource="{Binding Modifiers}" Margin="14,0,14,14">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="4"
                                Background="#201810" BorderThickness="1">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#3D2A1A" Offset="0"/>
                                    <GradientStop Color="#2A1E12" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatName}"
                                           Foreground="#7A6A52" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Percentage, StringFormat={}{0:+0.##%;-0.##%}}"
                                           Foreground="#E8A020" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>
