<UserControl x:Class="PackTracker.Presentation.Views.UexView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:PackTracker.Presentation.Converters"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <Style x:Key="RightAlignCell" TargetType="{x:Type TextBlock}">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#C2A23A"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                CornerRadius="16"
                Padding="20,16"
                Margin="0,0,0,20"
                BorderBrush="{DynamicResource AccentGoldBrush}"
                BorderThickness="2"
                Effect="{DynamicResource CardShadow}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🚀"
                           FontSize="36"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBlock Text="UEXCorp Trade Routes"
                           FontSize="32"
                           FontWeight="Black"
                           Foreground="#C2A23A"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceAltBrush}"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,16"
                BorderBrush="{DynamicResource PanelStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📦"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox MinWidth="280"
                              MaxWidth="400"
                              ItemsSource="{Binding Commodities}"
                              SelectedItem="{Binding SelectedCommodity, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              Background="{DynamicResource SurfaceAltBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Padding="12,8"
                              FontSize="14"
                              BorderBrush="{DynamicResource PanelStrokeBrush}"
                              BorderThickness="1" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="🔄 Refresh Data"
                        Command="{Binding RefreshDataCommand}"
                        Style="{StaticResource ModernButton}"
                        Margin="12,0,0,0"
                        ToolTip="Refresh trade route data"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="500"/>
                <ColumnDefinition Width="*" MinWidth="350"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: All Routes Table -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceAltBrush}"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,12,0"
                    BorderBrush="{DynamicResource PanelStrokeBrush}"
                    BorderThickness="1"
                    Effect="{DynamicResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="📊"
                                   FontSize="24"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="All Trade Routes"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#C2A23A"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AllRoutes}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              Background="#101014"
                              Foreground="White"
                              BorderBrush="#333"
                              BorderThickness="1"
                              RowBackground="#17191d"
                              AlternatingRowBackground="#1f2228"
                              FontSize="13"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="None"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True">

                        <!-- Header look -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#4400F0FF" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="BorderBrush" Value="{DynamicResource PanelStrokeBrush}" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="BorderBrush" Value="#23262b" />
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Origin" Binding="{Binding OriginTerminalName}" Width="2*" />
                            <DataGridTextColumn Header="Destination" Binding="{Binding DestinationTerminalName}"
                                                Width="2*" />
                            <DataGridTextColumn Header="Buy" Binding="{Binding PriceOrigin, StringFormat={}{0:N0}}"
                                                Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTextColumn Header="Sell"
                                                Binding="{Binding PriceDestination, StringFormat={}{0:N0}}" Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTextColumn Header="ROI (%)" Binding="{Binding PriceRoi, StringFormat={}{0:N2}}"
                                                Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTextColumn Header="Profit (aUEC)"
                                                Binding="{Binding Profit, StringFormat={}{0:N0}}" Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTextColumn Header="Distance (km)"
                                                Binding="{Binding Distance, StringFormat={}{0:N0}}" Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>


            <!-- RIGHT: Top Routes and Best Route Summary -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Top Routes -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="16"
                            Padding="20"
                            Margin="0,0,0,16"
                            BorderBrush="{DynamicResource PanelStrokeBrush}"
                            BorderThickness="1"
                            Effect="{DynamicResource CardShadow}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="⭐"
                                           FontSize="20"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Top Routes"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Foreground="#C2A23A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding TopRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                CornerRadius="8"
                                                Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource PanelStrokeBrush}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{Binding OriginTerminalName}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="13"/>
                                                <TextBlock Text="{Binding DestinationTerminalName}"
                                                           Foreground="#BBB"
                                                           FontSize="12"
                                                           Margin="0,2,0,4"/>
                                                <Border Background="#90EE90"
                                                        CornerRadius="4"
                                                        Padding="6,3"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding PriceRoi, StringFormat='ROI: {0:N2}%'}"
                                                               Foreground="Black"
                                                               FontSize="12"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Best Route -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="16"
                            Padding="20"
                            Margin="0,0,0,16"
                            BorderBrush="{DynamicResource AccentGoldBrush}"
                            BorderThickness="2"
                            Effect="{DynamicResource CardShadow}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🏆"
                                           FontSize="20"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Best Route"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Foreground="#C2A23A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="10"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding BestRoute.DestinationTerminalName}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#C2A23A"/>
                                    <Border Background="#90EE90"
                                            CornerRadius="6"
                                            Padding="8,4"
                                            Margin="0,8,0,8"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding BestRoute.PriceRoi, StringFormat='ROI: {0:N2}%'}"
                                                   Foreground="Black"
                                                   FontSize="14"
                                                   FontWeight="Bold"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Foreground="#CCC" FontSize="12">
                                            <Run Text="💰 Profit:" FontWeight="SemiBold"/>
                                            <Run Text="{Binding BestRoute.Profit, StringFormat='{}{0:N0} aUEC'}" Foreground="White"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#CCC" FontSize="12" Margin="0,4,0,0">
                                            <Run Text="📏 Distance:" FontWeight="SemiBold"/>
                                            <Run Text="{Binding BestRoute.Distance, StringFormat='{}{0:N1} km'}" Foreground="White"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <!-- SHIP TRADE PROFIT ESTIMATOR -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="16"
                            Padding="20"
                            BorderBrush="{DynamicResource PanelStrokeBrush}"
                            BorderThickness="1"
                            Effect="{DynamicResource CardShadow}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🚢"
                                           FontSize="20"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Profit Calculator"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Foreground="#C2A23A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Ship Selector -->
                            <ComboBox ItemsSource="{Binding Ships}"
                                      SelectedItem="{Binding SelectedShip, Mode=TwoWay}"
                                      DisplayMemberPath="NameFull"
                                      Background="{DynamicResource SurfaceAltBrush}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      FontSize="13"
                                      Padding="10,8"
                                      BorderBrush="{DynamicResource PanelStrokeBrush}"
                                      BorderThickness="1"
                                      Margin="0,0,0,12"
                                      ToolTip="Select ship to calculate trade profits" />

                            <!-- Optional Ship Image -->
                            <Border Height="180"
                                    Margin="0,0,0,12"
                                    Background="{DynamicResource CardBackground}"
                                    CornerRadius="10"
                                    BorderBrush="{DynamicResource PanelStrokeBrush}"
                                    BorderThickness="1"
                                    Visibility="{Binding SelectedShip.UrlPhoto, Converter={StaticResource NullToVisibilityConverter}}">
                                <Image Source="{Binding SelectedShip.UrlPhoto}"
                                       Stretch="UniformToFill"
                                       ClipToBounds="True"/>
                            </Border>

                            <!-- Ship Details -->
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="10"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Foreground="#CCC" FontSize="12" Margin="0,0,0,4">
                                        <Run Text="🏭 Manufacturer:" FontWeight="SemiBold"/>
                                        <Run Text="{Binding SelectedShip.CompanyName}" Foreground="White"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#CCC" FontSize="12" Margin="0,0,0,10">
                                        <Run Text="📦 Cargo:" FontWeight="SemiBold"/>
                                        <Run Text="{Binding SelectedShip.Scu, StringFormat='{}{0:N0} SCU'}" Foreground="White"/>
                                    </TextBlock>
                                    <Border Background="#C2A23A"
                                            CornerRadius="8"
                                            Padding="10,6">
                                        <TextBlock HorizontalAlignment="Center">
                                            <Run Text="Est. Profit:" FontWeight="Bold" FontSize="12" Foreground="Black"/>
                                            <Run Text="{Binding EstimatedProfit, StringFormat='{}{0:N0} aUEC'}"
                                                 FontSize="16" FontWeight="Bold" Foreground="Black"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
      

        <!-- Status Bar -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="#999"
                   FontStyle="Italic"
                   HorizontalAlignment="Left"
                   Margin="5,10,0,0" />
    </Grid>
</UserControl>
