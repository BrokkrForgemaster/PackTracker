<UserControl x:Class="PackTracker.Presentation.Views.UexView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:PackTracker.Presentation.Converters"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <Style x:Key="RightAlignCell" TargetType="{x:Type TextBlock}">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="UEX Trade Routes"
                   FontSize="36"
                   FontWeight="Black"
                   Foreground="Yellow"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20" />

        <!-- Controls -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Left">
            <ComboBox Width="320"
                      ItemsSource="{Binding Commodities}"
                      SelectedItem="{Binding SelectedCommodity, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Background="#1e1e1e"
                      Foreground="Black"
                      Padding="6"
                      FontSize="14"
                      BorderBrush="#555"
                      BorderThickness="1" />
            <Button Content="🔄 Refresh Data"
                    Command="{Binding RefreshDataCommand}"
                    Background="#303030"
                    Foreground="White"
                    Padding="10,6"
                    FontWeight="SemiBold"
                    BorderBrush="#666"
                    BorderThickness="1"
                    Cursor="Hand" />
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="0,20,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: All Routes Table -->
            <!-- LEFT: All Routes Table -->
            <Border Background="#181818"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="All Trade Routes"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FFD700"
                               Margin="0,0,0,8" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AllRoutes}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              Background="#101014"
                              Foreground="White"
                              BorderBrush="#333"
                              BorderThickness="1"
                              RowBackground="#17191d"
                              AlternatingRowBackground="#1f2228"
                              FontSize="13"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="None"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True">

                        <!-- Header look -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#4400F0FF" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="BorderBrush" Value="#2b2b2b" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="BorderBrush" Value="#23262b" />
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Origin" Binding="{Binding OriginTerminalName}" Width="2*" />
                            <DataGridTextColumn Header="Destination" Binding="{Binding DestinationTerminalName}"
                                                Width="2*" />
                            <DataGridTextColumn Header="Buy" Binding="{Binding PriceOrigin, StringFormat={}{0:N0}}"
                                                Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTextColumn Header="Sell"
                                                Binding="{Binding PriceDestination, StringFormat={}{0:N0}}" Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTextColumn Header="ROI (%)" Binding="{Binding PriceRoi, StringFormat={}{0:N2}}"
                                                Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTextColumn Header="Profit (aUEC)"
                                                Binding="{Binding Profit, StringFormat={}{0:N0}}" Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTextColumn Header="Distance (km)"
                                                Binding="{Binding Distance, StringFormat={}{0:N0}}" Width="*"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>


            <!-- RIGHT: Top Routes and Best Route Summary -->
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <!-- Top Routes -->
                <Border Background="#1e1e1e"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Top Routes (Highest ROI)"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="#FFD700"
                                   Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding TopRoutes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4,0,4"
                                            Padding="8"
                                            CornerRadius="6"
                                            Background="#252525">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OriginTerminalName}" Foreground="White"
                                                       FontWeight="Bold" FontSize="12" />
                                            <TextBlock Text="{Binding DestinationTerminalName}" Foreground="#ccc"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding PriceRoi, StringFormat='ROI: {0:N2}%'}"
                                                       Foreground="#90EE90" FontSize="14" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Best Route -->
                <Border Background="#1e1e1e"
                        CornerRadius="12"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Best Route"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="#FFD700"
                                   Margin="0,0,0,10" />
                        <StackPanel>
                            <TextBlock Text="{Binding BestRoute.DestinationTerminalName}" FontSize="16"
                                       FontWeight="Bold" Foreground="#FFD700" />
                            <TextBlock Text="{Binding BestRoute.PriceRoi, StringFormat='ROI: {0:N2}%'}"
                                       Foreground="#90EE90" Margin="0,2,0,0" FontSize="12" />
                            <TextBlock Text="{Binding BestRoute.Profit, StringFormat='Profit: {0:N0} aUEC'}"
                                       Foreground="#fff" Margin="0,2,0,0" FontSize="12" />
                            <TextBlock Text="{Binding BestRoute.Distance, StringFormat='Distance: {0:N1} km'}"
                                       Foreground="#bbb" Margin="0,2,0,0" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- SHIP TRADE PROFIT ESTIMATOR -->
                <Border Background="#1e1e1e"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Ship Trade Profit Estimator"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="#FFD700"
                                   Margin="0,0,0,10" />

                        <!-- Ship Selector -->
                        <ComboBox ItemsSource="{Binding Ships}"
                                  SelectedItem="{Binding SelectedShip, Mode=TwoWay}"
                                  DisplayMemberPath="NameFull"
                                  Background="#101014"
                                  Foreground="Black"
                                  FontSize="14"
                                  Padding="6"
                                  BorderBrush="#555"
                                  BorderThickness="1"
                                  Margin="0,0,0,8"
                                  ToolTip="Select ship to calculate trade profits" />

                        <!-- Optional Ship Image -->
                        <Border Height="200"
                                Margin="0,6,0,6"
                                Background="#151515"
                                CornerRadius="6"
                                Visibility="{Binding SelectedShip.UrlPhoto, Converter={StaticResource NullToVisibilityConverter}}">
                            <Image Source="{Binding SelectedShip.UrlPhoto}"
                                   Stretch="UniformToFill"
                                   ClipToBounds="True"/>
                        </Border>

                        <!-- Ship Details -->
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock Text="{Binding SelectedShip.CompanyName, StringFormat='Manufacturer: {0}'}"
                                       Foreground="White" FontSize="14" />
                            <TextBlock Text="{Binding SelectedShip.Scu, StringFormat='Cargo Capacity: {0:N0} SCU'}"
                                       Foreground="White" FontSize="14" />
                            <TextBlock Text="{Binding EstimatedProfit, StringFormat='Est. Profit: {0:N0} aUEC'}"
                                       Foreground="#90EE90" FontSize="16" FontWeight="Bold" Margin="0,6,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
      

        <!-- Status Bar -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="#999"
                   FontStyle="Italic"
                   HorizontalAlignment="Left"
                   Margin="5,10,0,0" />
    </Grid>
</UserControl>