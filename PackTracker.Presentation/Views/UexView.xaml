<UserControl x:Class="PackTracker.Presentation.Views.UexView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:PackTracker.Presentation.Converters"
             mc:Ignorable="d"
             Background="Transparent">
    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <Style x:Key="RightAlignCell" TargetType="{x:Type TextBlock}">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <!-- Header style for right-aligned numeric columns -->
        <Style x:Key="RightAlignHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1108"/>
            <Setter Property="Foreground" Value="#C9A458"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="0,6,12,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="BorderBrush" Value="#3A2D22"/>
            <Setter Property="BorderThickness" Value="1,0,0,2"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextAlignment="Right"
                                   HorizontalAlignment="Stretch"
                                   Foreground="#C9A458"
                                   FontWeight="Bold"
                                   FontSize="10"
                                   Margin="0,0,4,0"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Style="{StaticResource OpHeaderBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="TRADING HUB" Foreground="{StaticResource OpTextTitleBrush}" FontSize="22"
                               FontWeight="Bold" />
                    <TextBlock
                        Text="Real-time trade route intelligence powered by UEXCorp. Analyze ROI, distances, and commodity margins."
                        Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="REFRESH DATA"
                            Command="{Binding RefreshDataCommand}"
                            Padding="16,8" FontWeight="Bold"
                            Background="#24374A" Foreground="#E8F0F8"
                            BorderBrush="#4F6A84" BorderThickness="1" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Controls ── -->
        <Border Grid.Row="1" Style="{StaticResource OpPanelBorderStyle}" Margin="0,0,0,16" Padding="12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="COMMODITY" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0" />
                <ComboBox Width="320"
                          ItemsSource="{Binding Commodities}"
                          SelectedItem="{Binding SelectedCommodity, Mode=TwoWay}"
                          Style="{StaticResource OpComboBoxStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- ── Main Content ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="500" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="350" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: All Routes Table -->
            <Border Grid.Column="0" Style="{StaticResource OpPanelBorderStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="MARKET ROUTES" Foreground="{StaticResource OpTextTitleBrush}"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AllRoutes}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              Background="Transparent"
                              Foreground="{StaticResource OpTextPrimaryBrush}"
                              BorderThickness="0"
                              RowBackground="#17120E"
                              AlternatingRowBackground="#211812"
                              RowHeight="34"
                              FontSize="12"
                              GridLinesVisibility="Vertical"
                              VerticalGridLinesBrush="#2A1F16">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1A1108"/>
                                <Setter Property="Foreground" Value="#C9A458"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="BorderBrush" Value="#3A2D22"/>
                                <Setter Property="BorderThickness" Value="1,0,0,2"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <!-- Row separator via bottom border -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderBrush" Value="#2A1F16"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3E3023"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A1E14"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,0" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ORIGIN"
                                                Binding="{Binding OriginTerminalName}"
                                                Width="1.5*"/>
                            <DataGridTextColumn Header="DESTINATION"
                                                Binding="{Binding DestinationTerminalName}"
                                                Width="1.5*"/>
                            <DataGridTextColumn Binding="{Binding PriceOrigin, StringFormat={}{0:N0}}"
                                                Width="0.8*"
                                                ElementStyle="{StaticResource RightAlignCell}"
                                                HeaderStyle="{StaticResource RightAlignHeader}">
                                <DataGridTextColumn.Header>BUY</DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding PriceDestination, StringFormat={}{0:N0}}"
                                                Width="0.8*"
                                                ElementStyle="{StaticResource RightAlignCell}"
                                                HeaderStyle="{StaticResource RightAlignHeader}">
                                <DataGridTextColumn.Header>SELL</DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding PriceRoi, StringFormat={}{0:N1}%}"
                                                Width="0.7*"
                                                ElementStyle="{StaticResource RightAlignCell}"
                                                HeaderStyle="{StaticResource RightAlignHeader}">
                                <DataGridTextColumn.Header>ROI %</DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Profit, StringFormat={}{0:N0}}"
                                                Width="0.8*"
                                                ElementStyle="{StaticResource RightAlignCell}"
                                                HeaderStyle="{StaticResource RightAlignHeader}">
                                <DataGridTextColumn.Header>PROFIT</DataGridTextColumn.Header>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- RIGHT: Blueprint Component Breakdown + Modifiers -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Best Route / Optimal Info (keep if you still want it, or remove) -->
                    <Border Style="{StaticResource OpHeaderBorderStyle}" Margin="0,0,0,16" Padding="18">
                        <StackPanel>
                            <TextBlock Text="OPTIMAL ROUTE" Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding BestRoute.DestinationTerminalName}" FontSize="18"
                                       FontWeight="Bold" Foreground="{StaticResource OpTextTitleBrush}"
                                       TextWrapping="Wrap" />
                            <Border Background="{StaticResource OpBackgroundPillBrush}"
                                    BorderBrush="{StaticResource OpBorderPillBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="8,4" Margin="0,8,0,8" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding BestRoute.PriceRoi, StringFormat='ROI: {0:N2}%'}"
                                           Foreground="#E8A020" FontSize="14" FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Ship Profit Estimator -->
                    <Border Style="{StaticResource OpPanelBorderStyle}" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="PROFIT ESTIMATOR"
                                       Foreground="{StaticResource OpTextTitleBrush}"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />

                            <TextBlock Text="SHIP" Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding Ships}"
                                      SelectedItem="{Binding SelectedShip, Mode=TwoWay}"
                                      Style="{StaticResource OpComboBoxStyle}"
                                      Margin="0,0,0,16">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding NameFull}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Border Style="{StaticResource OpItemBorderStyle}" Background="#1D1813" Padding="14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="CARGO CAPACITY"
                                                   Foreground="{StaticResource OpTextMutedBrush}" FontSize="11" />
                                        <TextBlock HorizontalAlignment="Right"
                                                   Text="{Binding SelectedShip.Scu, StringFormat='{}{0} SCU', TargetNullValue='—'}"
                                                   Foreground="{StaticResource OpTextPrimaryBrush}" FontWeight="Medium" />
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="PROFIT PER UNIT"
                                                   Foreground="{StaticResource OpTextMutedBrush}" FontSize="11" />
                                        <TextBlock HorizontalAlignment="Right"
                                                   Text="{Binding BestRoute.PriceMargin, StringFormat='{}{0:N0} aUEC', TargetNullValue='—'}"
                                                   Foreground="{StaticResource OpTextPrimaryBrush}" FontWeight="Medium" />
                                    </Grid>
                                    <Separator Margin="0,8,0,8" Background="#31271E" />
                                    <Grid>
                                        <TextBlock Text="ESTIMATED PROFIT"
                                                   Foreground="{StaticResource OpTextMutedBrush}" FontSize="12" />
                                        <TextBlock HorizontalAlignment="Right"
                                                   Text="{Binding EstimatedProfit, StringFormat='{}{0:N0} aUEC', TargetNullValue='—'}"
                                                   Foreground="#4ADE80" FontWeight="Bold" FontSize="15" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Top Routes -->
                    <Border Style="{StaticResource OpPanelBorderStyle}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="TOP ROUTES"
                                       Foreground="{StaticResource OpTextTitleBrush}"
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                            <ItemsControl ItemsSource="{Binding TopRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource OpItemBorderStyle}" Margin="0,0,0,8" Padding="12">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding OriginTerminalName}"
                                                               Foreground="{StaticResource OpTextTitleBrush}"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Border Grid.Column="1"
                                                            Background="{StaticResource OpBackgroundPillBrush}"
                                                            BorderBrush="{StaticResource OpBorderPillBrush}"
                                                            BorderThickness="1" CornerRadius="3" Padding="6,2">
                                                        <TextBlock Text="{Binding PriceRoi, StringFormat='{}{0:N1}%'}"
                                                                   Foreground="#E8A020" FontSize="11" FontWeight="Bold" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding DestinationTerminalName}"
                                                           Foreground="{StaticResource OpTextSecondaryBrush}"
                                                           FontSize="11" Margin="0,4,0,4"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding PriceOrigin, StringFormat='Buy: {0:N0}'}"
                                                               Foreground="{StaticResource OpTextMutedBrush}" FontSize="11" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Profit, StringFormat='Profit: {0:N0}'}"
                                                               Foreground="#4ADE80" FontSize="11" HorizontalAlignment="Right" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Style="{StaticResource OpHeaderBorderStyle}" Margin="0,16,0,0" Padding="12,10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource OpTextAccentBrush}" FontSize="12"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>