<UserControl x:Class="PackTracker.Presentation.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Border Background="{DynamicResource AppBackgroundBrush}" />

        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="400">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo / Wordmark -->
            <StackPanel Grid.Row="0"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,40">
                <Border Width="200"
                        Height="200"
                        CornerRadius="18"
                        Background="Transparent"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">

                    <Border.Effect>
                        <DropShadowEffect x:Name="PulseShadow"
                                          Color="#FFD6B25E"
                                          BlurRadius="15"
                                          ShadowDepth="0"
                                          Opacity="0.6" />
                    </Border.Effect>

                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">

                                    <!-- Bigger glow -->
                                    <DoubleAnimation Storyboard.TargetName="PulseShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     From="15" To="40"
                                                     Duration="0:0:1.2" />

                                    <!-- Stronger brightness -->
                                    <DoubleAnimation Storyboard.TargetName="PulseShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.5" To="1.0"
                                                     Duration="0:0:1.2" />

                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>

                    <Image Source="/Assets/HWiconnew.png"
                           Width="200"
                           Height="200"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Uniform" />
                </Border>

                <TextBlock Text="PackTracker"
                           FontSize="52"
                           FontWeight="SemiBold"
                           Foreground="#FFF8F8F8"
                           HorizontalAlignment="Center">

                    <TextBlock.Effect>
                        <DropShadowEffect Color="#AA000000"
                                          BlurRadius="6"
                                          ShadowDepth="1"
                                          Opacity="0.6"/>
                    </TextBlock.Effect>

                </TextBlock>

                <TextBlock Text="House Wolf Operations"
                           FontSize="23"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Status pill -->
            <Border Grid.Row="1"
                    x:Name="StatusPill"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource PanelStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,10"
                    Margin="0,0,0,20"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="7"
                             Height="7"
                             Fill="LightGreen"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0" />
                    <TextBlock x:Name="DiscordStatus"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Primary action card -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource PanelStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Opacity="0.95"
                    Padding="28">
                <StackPanel>
                    <TextBlock Text="Sign in to continue"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center" />

                    <TextBlock
                        Text="PackTracker uses Discord OAuth to verify your House Wolf membership. No passwords stored."
                        FontSize="13"
                        Foreground="{DynamicResource TextMutedBrush}"
                        TextWrapping="Wrap"
                        TextAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="300"
                        Margin="0,8,0,24" />

                    <Button x:Name="DiscordLoginButton"
                            Click="DiscordLogin_Click"
                            Height="46"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{StaticResource PrimaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Background="#5865F2"
                                    CornerRadius="6"
                                    Padding="5,3"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="D"
                                           FontSize="12"
                                           FontWeight="Black"
                                           Foreground="White" />
                            </Border>
                            <TextBlock Text="Continue with Discord"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Grid Margin="0,20,0,20">
                        <Separator Background="{DynamicResource PanelStrokeBrush}" VerticalAlignment="Center" />
                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                HorizontalAlignment="Center"
                                Padding="10,0">
                            <TextBlock Text="having trouble?"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </Border>
                    </Grid>

                    <Button Content="Retry API readiness"
                            Click="RetryApi_Click"
                            Height="38"
                            FontSize="13"
                            Style="{StaticResource SecondaryActionButtonStyle}" />
                </StackPanel>
            </Border>

            <!-- Authenticated confirmation -->
            <StackPanel Grid.Row="3"
                        x:Name="AuthConfirmPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,18,0,0"
                        Visibility="Collapsed">
                <TextBlock x:Name="DiscordCheck"
                           Text="✓"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="LimeGreen"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="Authenticated — redirecting to dashboard"
                           FontSize="13"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Footer note -->
            <TextBlock Grid.Row="4"
                       Text="A browser window will open for OAuth login. Once authenticated, you'll be redirected back to the app, and can safely close the browser tab."
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="320"
                       Margin="0,24,0,0" />
        </Grid>
    </Grid>
</UserControl>