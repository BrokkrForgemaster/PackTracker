<UserControl x:Class="PackTracker.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
  
    <Grid Margin="24">
        <!-- Main container -->
        <Border Background="#202020"
                CornerRadius="20"
                Padding="24"
                Effect="{DynamicResource CardShadow}">
            
            <Grid>
                <!-- Title -->
                <TextBlock Text="Dashboard"
                           FontSize="36"
                           FontWeight="Black"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,12,0,24"
                           TextOptions.TextFormattingMode="Ideal" />

                <!-- Scrollable content area -->
                <ScrollViewer Grid.Row="1"
                              Margin="0,72,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">

                    <!-- Centered content container -->
                    <StackPanel Orientation="Vertical"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">

                        <!-- Inner content wrapper -->
                        <StackPanel Width="Auto"
                                    MaxWidth="1200"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Orientation="Vertical">

                            <!-- 🟣 FPS Leaders -->
                            <Border Background="#2C2C2C"
                                    Padding="20"
                                    CornerRadius="16"
                                    Effect="{DynamicResource CardShadow}">
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1"
                                                                 Duration="0:0:0.6" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <StackPanel>
                                    <TextBlock Text="Top 5 Mercenaries"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#B5CBF7"
                                               Margin="0,0,0,16"
                                               HorizontalAlignment="Left" />

                                    <ItemsControl ItemsSource="{Binding Fps}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <!-- Cards wrap and stay centered -->
                                                <WrapPanel HorizontalAlignment="Center"
                                                           Orientation="Horizontal"
                                                           ItemWidth="220"
                                                           MinWidth="220"
                                                           MaxWidth="Infinity"
                                                           Margin="0,0,0,8" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#3A3F5A"
                                                        BorderBrush="#436EE6"
                                                        BorderThickness="1.5"
                                                        CornerRadius="12"
                                                        Margin="8"
                                                        Padding="12"
                                                        MinWidth="180"
                                                        MaxWidth="240"
                                                        MinHeight="100"
                                                        Effect="{DynamicResource CardShadow}">
                                                    <StackPanel>
                                                        <TextBlock  
                                                            Text="{Binding Username}"
                                                                   FontWeight="Bold"
                                                                   FontSize="17"
                                                                   Foreground="#F2F6FF" />
                                                        <TextBlock Text="{Binding KillCount, StringFormat='Kills: {0}'}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#A0E4C7"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- 🟢 Air Leaders -->
                            <Border Background="#2C2C2C"
                                    Padding="20"
                                    CornerRadius="16"
                                    Effect="{DynamicResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="Top 5 Ace Pilots"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#C3FFD1"
                                               Margin="0,0,0,16"
                                               HorizontalAlignment="Left" />

                                    <ItemsControl ItemsSource="{Binding AirLeaders}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center"
                                                           Orientation="Horizontal"
                                                           ItemWidth="220"
                                                           MinWidth="220"
                                                           MaxWidth="Infinity"
                                                           Margin="0,0,0,8" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#334D41"
                                                        BorderBrush="#2DC37F"
                                                        BorderThickness="1.5"
                                                        CornerRadius="12"
                                                        Margin="8"
                                                        Padding="12"
                                                        MinWidth="180"
                                                        MaxWidth="240"
                                                        MinHeight="100"
                                                        Effect="{DynamicResource CardShadow}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Attacker}"
                                                                   FontWeight="Bold"
                                                                   FontSize="17"
                                                                   Foreground="#F2FFF6" />
                                                        <TextBlock Text="{Binding KillCount, StringFormat='Kills: {0}'}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#68F5A9"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
