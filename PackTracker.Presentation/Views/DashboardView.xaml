<!-- DashboardView.xaml with centered Dashboard title, leaderboard cards left-aligned and pushed down -->

<UserControl x:Class="PackTracker.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Margin="32"
            Background="{DynamicResource CardBackground}"
            CornerRadius="32"
            Padding="18"
            Effect="{DynamicResource CardShadow}">
        <Grid>
            <!-- Centered Dashboard Title -->
            <TextBlock Text="Dashboard"
                       FontSize="36"
                       FontWeight="Black"
                       Foreground="#fff"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"
                       VerticalAlignment="Top"/>

            <!-- Responsive Leader Cards Area -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,88,0,0">
                <StackPanel Orientation="Vertical"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Left"
                            Width="Auto">
                    
                    <!-- FPS Leaders Section Card -->
                    <Border Margin="0 60 0 8"
                            Padding="18"
                            MaxWidth="900"
                            Background="#393a38"
                            CornerRadius="24"
                            Effect="{DynamicResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Top 5 Mercenaries"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#B5CBF7"
                                       Margin="0,0,0,12"
                                       HorizontalAlignment="Left"/>
                            <ItemsControl ItemsSource="{Binding FpsLeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="8"
                                                Padding="16"
                                                MinWidth="170"
                                                MaxWidth="210"
                                                MinHeight="100"
                                                CornerRadius="14"
                                                Background="#3A3F5A"
                                                BorderBrush="#436EE6"
                                                BorderThickness="2"
                                                Effect="{DynamicResource CardShadow}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Username}"
                                                           FontWeight="Bold"
                                                           FontSize="17"
                                                           Foreground="#F2F6FF"/>
                                                <TextBlock Text="{Binding KillCount, StringFormat='Kills: {0}'}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="#A0E4C7"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Air Leaders Section Card -->
                    <Border Margin="0 16 0 12"
                            Padding="18"
                            MaxWidth="900"
                            Background="#393a38"
                            CornerRadius="24"
                            Effect="{DynamicResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Top 5 Ace Pilots"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#C3FFD1"
                                       Margin="0,0,0,12"
                                       HorizontalAlignment="Left"/>
                            <ItemsControl ItemsSource="{Binding AirLeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="8"
                                                Padding="16"
                                                MinWidth="170"
                                                MaxWidth="210"
                                                MinHeight="100"
                                                CornerRadius="14"
                                                Background="#334D41"
                                                BorderBrush="#2DC37F"
                                                BorderThickness="2"
                                                Effect="{DynamicResource CardShadow}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Username}"
                                                           FontWeight="Bold"
                                                           FontSize="17"
                                                           Foreground="#F2FFF6"/>
                                                <TextBlock Text="{Binding KillCount, StringFormat='Kills: {0}'}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="#68F5A9"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
