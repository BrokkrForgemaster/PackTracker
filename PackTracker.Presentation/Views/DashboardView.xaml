<UserControl x:Class="PackTracker.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:vm="clr-namespace:PackTracker.Presentation.ViewModels"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Send button with explicit template so Background/Foreground render correctly -->
        <Style x:Key="ChatSendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource OpBackgroundPillBrush}" />
            <Setter Property="Foreground" Value="{StaticResource OpTextAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OpBorderPillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4B3828" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5A4533" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1512" />
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{StaticResource OpBorderItemBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Style="{StaticResource OpHeaderBorderStyle}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="OPERATIONS DASHBOARD"
                               Foreground="{StaticResource OpTextTitleBrush}"
                               FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Live snapshot of House Wolf readiness across squads and support teams."
                               Foreground="{StaticResource OpTextSecondaryBrush}"
                               FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Connection status pill -->
                <Border DockPanel.Dock="Right" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#3A1A1A" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Background" Value="#1A3A1A" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontSize="10" FontWeight="Bold" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="OFFLINE" />
                                <Setter Property="Foreground" Value="#CC4444" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Text" Value="LIVE" />
                                        <Setter Property="Foreground" Value="#00A86B" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- Logged-in user display -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="{Binding CurrentUserDisplayName}"
                               Foreground="{StaticResource OpTextTitleBrush}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                               Visibility="{Binding CurrentUserDisplayName, Converter={StaticResource NullToVisibilityConverter}}" />
                    <TextBlock Text=" · " Foreground="{StaticResource OpTextMutedBrush}" FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding CurrentUserRole, Converter={StaticResource NullToVisibilityConverter}}" />
                    <TextBlock Text="{Binding CurrentUserRole}"
                               Foreground="{StaticResource OpTextAccentBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               Visibility="{Binding CurrentUserRole, Converter={StaticResource NullToVisibilityConverter}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Main 3-column layout ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════
                 LEFT SIDEBAR
            ══════════════════════════════════════ -->
            <DockPanel Grid.Column="0">

                <!-- Guide Rota — compact summary at top -->
                <Border DockPanel.Dock="Top" Style="{StaticResource OpPanelBorderStyle}"
                        Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,6">
                            <TextBlock Text="GUIDE ROTA" DockPanel.Dock="Left"
                                       Foreground="{StaticResource OpTextTitleBrush}"
                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                            <Border DockPanel.Dock="Right"
                                    Background="{StaticResource OpBackgroundPillBrush}"
                                    BorderBrush="{StaticResource OpBorderPillBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="5,1">
                                <TextBlock Text="{Binding Guide.Requests.Count, StringFormat={}{0} SCHEDULED}"
                                           Foreground="{StaticResource OpTextAccentBrush}"
                                           FontSize="9" FontWeight="Bold" />
                            </Border>
                        </DockPanel>

                        <!-- Show only 2 entries to keep it compact -->
                        <ItemsControl ItemsSource="{Binding TopGuideRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource OpItemBorderStyle}"
                                            Padding="7,4" Margin="0,0,0,3">
                                        <DockPanel LastChildFill="True">
                                            <Border DockPanel.Dock="Right"
                                                    Background="#1D1813"
                                                    BorderBrush="{StaticResource OpBorderItemBrush}"
                                                    BorderThickness="1" CornerRadius="3"
                                                    Padding="4,1" Margin="4,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="{StaticResource OpTextAccentBrush}"
                                                           FontSize="9" FontWeight="Bold" />
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No guide shifts scheduled." FontStyle="Italic"
                                   Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" Margin="0,2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Guide.Requests.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Active Requests — primary panel, fills remaining space -->
                <Border DockPanel.Dock="Top" Style="{StaticResource OpPanelBorderStyle}" Padding="12">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,8">
                            <TextBlock Text="ACTIVE REQUESTS" DockPanel.Dock="Left"
                                       Foreground="{StaticResource OpTextTitleBrush}"
                                       FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                            <Border DockPanel.Dock="Right"
                                    Background="{StaticResource OpBackgroundPillBrush}"
                                    BorderBrush="{StaticResource OpBorderPillBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="6,2">
                                <TextBlock Text="{Binding ActiveRequests.Count, StringFormat={}{0} TASKS}"
                                           Foreground="{StaticResource OpTextAccentBrush}"
                                           FontSize="9" FontWeight="Bold" />
                            </Border>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding TopRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource OpItemBorderStyle}"
                                            Padding="8,6" Margin="0,0,0,4">
                                        <DockPanel LastChildFill="True">
                                            <!-- Status Indicator -->
                                            <Border DockPanel.Dock="Right"
                                                    Background="#1A3A1A" CornerRadius="3"
                                                    Padding="5,2" Margin="6,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#00A86B"
                                                           FontSize="9" FontWeight="Bold" />
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource OpTextPrimaryBrush}"
                                                           FontSize="11" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding RequestType}"
                                                           Foreground="{StaticResource OpTextMutedBrush}"
                                                           FontSize="9" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No active tasks." FontStyle="Italic"
                                   Foreground="{StaticResource OpTextMutedBrush}" FontSize="11" Margin="0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveRequests.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </DockPanel>

            <!-- Invisible GridSplitter -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" IsEnabled="False" />

            <!-- ══════════════════════════════════════
                 CENTER CHAT PANEL
            ══════════════════════════════════════ -->
            <Border Grid.Column="2" Style="{StaticResource OpPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Chat workspace header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource OpBackgroundHeaderBrush}"
                            BorderBrush="{StaticResource OpBorderPanelBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="10,10,0,0"
                            Padding="12,10">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="COMMS WORKSPACE"
                                           Foreground="{StaticResource OpTextTitleBrush}"
                                           FontSize="13"
                                           FontWeight="Bold" />
                                <TextBlock Text="Open, move, collapse, and monitor active communication channels."
                                           Foreground="{StaticResource OpTextMutedBrush}"
                                           FontSize="10"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="CASCADE"
                                        Command="{Binding CascadeChatWindowsCommand}"
                                        Margin="0,0,8,0"
                                        Padding="12,6"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Background="#24374A"
                                        Foreground="#E8F0F8"
                                        BorderBrush="#4F6A84"
                                        BorderThickness="1" />

                                <Button Content="MINIMIZE ALL"
                                        Command="{Binding CollapseAllChatWindowsCommand}"
                                        Margin="0,0,8,0"
                                        Padding="12,6"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Background="#4A3424"
                                        Foreground="#F4EBDD"
                                        BorderBrush="#84654F"
                                        BorderThickness="1" />

                                <Button Content="RESTORE ALL"
                                        Command="{Binding ExpandAllChatWindowsCommand}"
                                        Padding="12,6"
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Background="#2B4E2E"
                                        Foreground="#EEF6EE"
                                        BorderBrush="#5C8B5E"
                                        BorderThickness="1" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Floating workspace -->
                    <Grid Grid.Row="1" ClipToBounds="True" Background="#090705">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Channel launcher -->
                        <Border Grid.Column="0"
                                BorderBrush="{StaticResource OpBorderPanelBrush}"
                                BorderThickness="0,0,1,0"
                                Background="#0D0907"
                                Padding="10">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="AVAILABLE CHANNELS"
                                               Foreground="{StaticResource OpTextTitleBrush}"
                                               FontSize="11"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Shown based on your Discord role access."
                                               Foreground="{StaticResource OpTextMutedBrush}"
                                               FontSize="10"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding AvailableChatChannels}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="10"
                                                        Background="#15110E"
                                                        BorderBrush="{StaticResource OpBorderItemBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="8"
                                                                         Height="8"
                                                                         Margin="0,0,6,0"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding AccentBrush}" />
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           Foreground="{StaticResource OpTextTitleBrush}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold" />
                                                            </StackPanel>

                                                            <TextBlock Text="{Binding AccessSummary}"
                                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                                       FontSize="9"
                                                                       Margin="14,2,0,0"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Border Background="#8B1A0F"
                                                                    CornerRadius="8"
                                                                    Padding="5,1"
                                                                    Margin="0,0,6,0"
                                                                    Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="{Binding UnreadCount}"
                                                                           Foreground="#F4EBDD"
                                                                           FontSize="9"
                                                                           FontWeight="Bold" />
                                                            </Border>

                                                            <Button Content="OPEN"
                                                                    Command="{Binding DataContext.OpenChatWindowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Padding="10,4"
                                                                    FontSize="9"
                                                                    FontWeight="Bold"
                                                                    Background="#24374A"
                                                                    Foreground="#E8F0F8"
                                                                    BorderBrush="#4F6A84"
                                                                    BorderThickness="1" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- Floating windows surface -->
                        <Border Grid.Column="1"
                                Background="#070504"
                                Padding="8">
                            <Canvas x:Name="ChatWorkspaceCanvas"
                                    Background="Transparent">
                                <ItemsControl ItemsSource="{Binding OpenChatWindows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                            <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}"
                                                    Height="{Binding WindowHeight}"
                                                    MinWidth="300"
                                                    MaxWidth="520"
                                                    Background="#120D0A"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- Window header / drag handle -->
                                                    <Border Grid.Row="0"
                                                            Background="#1A1410"
                                                            BorderBrush="{Binding AccentBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            CornerRadius="8,8,0,0"
                                                            Padding="10,8"
                                                            Cursor="SizeAll"
                                                            MouseLeftButtonDown="ChatHeader_MouseLeftButtonDown"
                                                            MouseMove="ChatHeader_MouseMove"
                                                            MouseLeftButtonUp="ChatHeader_MouseLeftButtonUp">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="8"
                                                                         Height="8"
                                                                         Margin="0,0,6,0"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding AccentBrush}" />
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="{StaticResource OpTextTitleBrush}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           VerticalAlignment="Center" />
                                                                <Border Background="#8B1A0F"
                                                                        CornerRadius="8"
                                                                        Padding="5,1"
                                                                        Margin="8,0,0,0"
                                                                        Visibility="{Binding ShowUnreadBadge, Converter={StaticResource BoolToVisibility}}">
                                                                    <TextBlock Text="{Binding UnreadCount}"
                                                                               Foreground="#F4EBDD"
                                                                               FontSize="9"
                                                                               FontWeight="Bold" />
                                                                </Border>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1"
                                                                        Orientation="Horizontal">
                                                                <Button Content="_"
                                                                        Command="{Binding CollapseCommand}"
                                                                        Width="26"
                                                                        Height="22"
                                                                        Margin="0,0,4,0"
                                                                        FontWeight="Bold"
                                                                        Background="#2A211B"
                                                                        Foreground="{StaticResource OpTextAccentBrush}"
                                                                        BorderBrush="{StaticResource OpBorderItemBrush}"
                                                                        BorderThickness="1" />

                                                                <Button Content="□"
                                                                        Command="{Binding PopFrontCommand}"
                                                                        Width="26"
                                                                        Height="22"
                                                                        Margin="0,0,4,0"
                                                                        FontWeight="Bold"
                                                                        Background="#2A211B"
                                                                        Foreground="{StaticResource OpTextAccentBrush}"
                                                                        BorderBrush="{StaticResource OpBorderItemBrush}"
                                                                        BorderThickness="1" />

                                                                <Button Content="X"
                                                                        Command="{Binding CloseCommand}"
                                                                        Width="26"
                                                                        Height="22"
                                                                        FontWeight="Bold"
                                                                        Background="#4A2424"
                                                                        Foreground="#F8E8E8"
                                                                        BorderBrush="#844F4F"
                                                                        BorderThickness="1" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Expanded message body -->
                                                    <Grid Grid.Row="1"
                                                          Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <ScrollViewer Grid.Row="0"
                                                                      VerticalScrollBarVisibility="Auto"
                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                      Padding="8">
                                                            <StackPanel>
                                                                <ItemsControl ItemsSource="{Binding Messages}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Margin="0,0,0,6"
                                                                                Padding="8"
                                                                                Background="#1A1411"
                                                                                BorderBrush="{StaticResource OpBorderItemBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4">
                                                                                <StackPanel>
                                                                                    <DockPanel LastChildFill="False">
                                                                                        <TextBlock
                                                                                            Text="{Binding SenderDisplayName}"
                                                                                            Foreground="{StaticResource OpTextTitleBrush}"
                                                                                            FontSize="11"
                                                                                            FontWeight="SemiBold"
                                                                                            DockPanel.Dock="Left" />
                                                                                        <TextBlock
                                                                                            Text="{Binding FormattedTime}"
                                                                                            Foreground="{StaticResource OpTextMutedBrush}"
                                                                                            FontSize="9"
                                                                                            Margin="8,1,0,0"
                                                                                            DockPanel.Dock="Left" />
                                                                                    </DockPanel>

                                                                                    <TextBlock Text="{Binding Content}"
                                                                                        Foreground="{StaticResource OpTextPrimaryBrush}"
                                                                                        FontSize="11"
                                                                                        Margin="0,3,0,0"
                                                                                        TextWrapping="Wrap" />
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <TextBlock Text="No messages yet."
                                                                           Foreground="{StaticResource OpTextMutedBrush}"
                                                                           FontStyle="Italic"
                                                                           FontSize="11"
                                                                           HorizontalAlignment="Center"
                                                                           Margin="0,18,0,8">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility"
                                                                                Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger
                                                                                    Binding="{Binding Messages.Count}"
                                                                                    Value="0">
                                                                                    <Setter Property="Visibility"
                                                                                        Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </ScrollViewer>

                                                        <Border Grid.Row="1"
                                                                Background="{StaticResource OpBackgroundInputBrush}"
                                                                BorderBrush="{StaticResource OpBorderPanelBrush}"
                                                                BorderThickness="0,1,0,0"
                                                                Padding="8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBox Grid.Column="0"
                                                                         Text="{Binding DraftMessage, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource OpTextBoxStyle}"
                                                                         Padding="10,8"
                                                                         VerticalAlignment="Center">
                                                                    <TextBox.InputBindings>
                                                                        <KeyBinding Key="Return" Command="{Binding SendMessageCommand}" />
                                                                    </TextBox.InputBindings>
                                                                </TextBox>

                                                                <Button Grid.Column="1"
                                                                        Content="SEND"
                                                                        Command="{Binding SendMessageCommand}"
                                                                        Style="{StaticResource ChatSendButtonStyle}"
                                                                        Margin="8,0,0,0" />
                                                            </Grid>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Collapsed bar -->
                                                    <Border Grid.Row="1"
                                                            Grid.RowSpan="2"
                                                            Padding="10,8"
                                                            Background="#120D0A"
                                                            Visibility="{Binding IsCollapsed, Converter={StaticResource BoolToVisibility}}">
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock Text="Collapsed - unread alerts remain active"
                                                                       Foreground="{StaticResource OpTextMutedBrush}"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center" />

                                                            <StackPanel DockPanel.Dock="Right"
                                                                        Orientation="Horizontal">
                                                                <Border Background="#8B1A0F"
                                                                        CornerRadius="8"
                                                                        Padding="6,2"
                                                                        Margin="0,0,6,0"
                                                                        Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibility}}">
                                                                    <TextBlock
                                                                        Text="{Binding UnreadCount, StringFormat={}{0} NEW}"
                                                                        Foreground="#F4EBDD"
                                                                        FontSize="9"
                                                                        FontWeight="Bold" />
                                                                </Border>

                                                                <Button Content="EXPAND"
                                                                        Command="{Binding ExpandCommand}"
                                                                        Padding="10,4"
                                                                        FontSize="9"
                                                                        FontWeight="Bold"
                                                                        Background="#2B4E2E"
                                                                        Foreground="#EEF6EE"
                                                                        BorderBrush="#5C8B5E"
                                                                        BorderThickness="1" />
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                        </Border>
                    </Grid>

                    <!-- Bottom docked collapsed alerts -->
                    <Border Grid.Row="2"
                            Background="{StaticResource OpBackgroundInputBrush}"
                            BorderBrush="{StaticResource OpBorderPanelBrush}"
                            BorderThickness="0,1,0,0"
                            CornerRadius="0,0,10,10"
                            Padding="10,8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       Text="COLLAPSED ALERTS"
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />

                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding CollapsedWindowsWithUnread}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding AlertCaption}"
                                                    Command="{Binding ExpandCommand}"
                                                    Margin="0,0,8,0"
                                                    Padding="10,5"
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    Background="#4A2424"
                                                    Foreground="#F8E8E8"
                                                    BorderBrush="#844F4F"
                                                    BorderThickness="1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Invisible GridSplitter -->
            <GridSplitter Grid.Column="3" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" IsEnabled="False" />

            <!-- ══════════════════════════════════════
                 RIGHT SIDEBAR — ONLINE USERS
            ══════════════════════════════════════ -->
            <Border Grid.Column="4" Style="{StaticResource OpPanelBorderStyle}" Padding="12">
                <DockPanel>
                    <!-- Online users header -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="ONLINE"
                                   Foreground="{StaticResource OpTextTitleBrush}"
                                   FontSize="12" FontWeight="Bold" />
                        <TextBlock Text="{Binding OnlineUsers.Count, StringFormat={}{0} active}"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="10" />
                        <Separator Margin="0,6" Background="{StaticResource OpBorderPanelBrush}" />
                    </StackPanel>

                    <!-- User list -->
                    <ScrollViewer DockPanel.Dock="Top"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding OnlineUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:OnlineUserViewModel}">
                                    <Border Margin="0,4" Padding="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Role-colored avatar circle -->
                                            <Border Grid.Column="0"
                                                    Width="34" Height="34"
                                                    CornerRadius="17"
                                                    VerticalAlignment="Top"
                                                    Background="{Binding RoleColorBrush}">
                                                <TextBlock Text="{Binding InitialLetter}"
                                                           Foreground="#15120F"
                                                           FontSize="13" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name + role label -->
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{StaticResource OpTextTitleBrush}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Foreground="{StaticResource OpTextMutedBrush}"
                                                           FontSize="10" TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding Role}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Null}">
                                                                    <Setter Property="Text" Value="Member" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>