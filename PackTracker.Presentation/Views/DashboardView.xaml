<UserControl x:Class="PackTracker.Presentation.Views.DashboardView"
             x:Name="RootDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:PackTracker.Presentation.Behaviors"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             xmlns:vm="clr-namespace:PackTracker.Presentation.ViewModels"
             xmlns:dto="clr-namespace:PackTracker.Application.DTOs.Dashboard;assembly=PackTracker.Application"
             xmlns:global="clr-namespace:"
             xmlns:controls="clr-namespace:PackTracker.Presentation.Controls"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <Style x:Key="DarkMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#C8A96E" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="12,6">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="12" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A2E24" />
                                <Setter Property="Foreground" Value="#E8C87E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#1E1A16" />
            <Setter Property="BorderBrush" Value="#3A2E24" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0,2" />
        </Style>

        <Style x:Key="ChatSendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource OpBackgroundPillBrush}" />
            <Setter Property="Foreground" Value="{StaticResource OpTextAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OpBorderPillBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4B3828" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5A4533" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1512" />
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{StaticResource OpBorderItemBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OnlineUserCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#120D0A" />
            <Setter Property="BorderBrush" Value="{StaticResource OpBorderItemBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="OnlineUserActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#24374A" />
            <Setter Property="Foreground" Value="#E8F0F8" />
            <Setter Property="BorderBrush" Value="#4F6A84" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F4A63" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F3142" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1512" />
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{StaticResource OpBorderItemBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OnlineUserContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#15110E" />
            <Setter Property="BorderBrush" Value="{StaticResource OpBorderItemBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style x:Key="OnlineUserContextMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#24374A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- New chat message menu styles -->
        <Style x:Key="ChatMessageMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1410" />
                                <Setter Property="Foreground" Value="{StaticResource OpTextAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A211B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatMessageContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#15110E" />
            <Setter Property="BorderBrush" Value="{StaticResource OpBorderItemBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <StackPanel IsItemsHost="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatMessageMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#24374A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource OpTextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionExpanderStyle" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <DockPanel>
                            <ToggleButton DockPanel.Dock="Top"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          OverridesDefaultStyle="True"
                                          HorizontalContentAlignment="Stretch"
                                          Focusable="False"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                Padding="12,11">
                                            <DockPanel LastChildFill="True">
                                                <TextBlock x:Name="Arrow"
                                                           DockPanel.Dock="Right"
                                                           Text="▼"
                                                           FontSize="8"
                                                           Foreground="#6E5A46"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0" />
                                                <ContentPresenter HorizontalAlignment="Stretch" />
                                            </DockPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="Arrow" Property="Text" Value="▶" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#0D0A07" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" />
                            </ToggleButton>
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource OpBorderPanelBrush}"
                                    BorderThickness="0,1,0,0">
                                <ContentPresenter x:Name="ExpandSite"
                                                  Focusable="False"
                                                  Visibility="Collapsed" />
                            </Border>
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ActiveRequestCardTemplate" DataType="{x:Type dto:ActiveRequestDto}">
            <Border Style="{StaticResource OpItemBorderStyle}"
                    Padding="10,9"
                    Margin="0,0,0,6"
                    Cursor="Hand"
                    MouseLeftButtonUp="ActiveRequest_MouseLeftButtonUp">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Right"
                            Background="#1A3A1A"
                            CornerRadius="3"
                            Padding="6,3"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status}"
                                   Foreground="#00A86B"
                                   FontSize="9"
                                   FontWeight="Bold" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PINNED"
                                       Foreground="{StaticResource OpTextAccentBrush}"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{StaticResource OpTextPrimaryBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="10"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Bottom">
                                <Run Text="(" /><Run Text="{Binding ClaimCount, Mode=OneWay}" /><Run Text="/" /><Run Text="{Binding MaxClaims, Mode=OneWay}" /><Run Text=" CLAIMS)" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding RequestType}"
                                       Foreground="{StaticResource OpTextMutedBrush}"
                                       FontSize="9"
                                       VerticalAlignment="Center" />
                            <Border Background="#16261A"
                                    BorderBrush="#245B36"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="5,2"
                                    Margin="6,0,0,0"
                                    Visibility="{Binding IsRequestedByCurrentUser, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="MINE"
                                           Foreground="#7ED6A5"
                                           FontSize="8"
                                           FontWeight="Bold" />
                            </Border>
                            <Border Background="#1E1927"
                                    BorderBrush="#5F4A8A"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="5,2"
                                    Margin="4,0,0,0"
                                    Visibility="{Binding IsAssignedToCurrentUser, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="ASSIGNED"
                                           Foreground="#B7A7F5"
                                           FontSize="8"
                                           FontWeight="Bold" />
                            </Border>
                            <Border Background="#1A2D34"
                                    BorderBrush="#3E7282"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="5,2"
                                    Margin="4,0,0,0"
                                    Visibility="{Binding IsAvailableToClaim, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="AVAILABLE"
                                           Foreground="#8FD4E7"
                                           FontSize="8"
                                           FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource OpHeaderBorderStyle}">
            <DockPanel LastChildFill="False">

                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="OPERATIONS DASHBOARD"
                               Foreground="{StaticResource OpTextTitleBrush}"
                               FontSize="22"
                               FontWeight="Bold" />
                    <TextBlock Text="Live snapshot of House Wolf readiness across squads and support teams."
                               Foreground="{StaticResource OpTextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border CornerRadius="4"
                            Padding="8,4"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#3A1A1A" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#1A3A1A" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TextBlock FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="OFFLINE" />
                                    <Setter Property="Foreground" Value="#CC4444" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="LIVE" />
                                            <Setter Property="Foreground" Value="#00A86B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <TextBlock Text="{Binding CurrentUserDisplayName}"
                               Foreground="{StaticResource OpTextTitleBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Visibility="{Binding CurrentUserDisplayName, Converter={StaticResource NullToVisibilityConverter}}" />
                    <TextBlock Text=" · "
                               Foreground="{StaticResource OpTextMutedBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding CurrentUserRole, Converter={StaticResource NullToVisibilityConverter}}" />
                    <TextBlock Text="{Binding CurrentUserRole}"
                               Foreground="{StaticResource OpTextAccentBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Visibility="{Binding CurrentUserRole, Converter={StaticResource NullToVisibilityConverter}}" />
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Main Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- GUIDE ROTA -->
                    <Border Style="{StaticResource OpPanelBorderStyle}" Margin="0,0,0,10">
                        <Expander Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                            <Expander.Header>
                                <DockPanel LastChildFill="False" HorizontalAlignment="Stretch">
                                    <TextBlock Text="GUIDE ROTA"
                                               DockPanel.Dock="Left"
                                               Foreground="{StaticResource OpTextTitleBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <Border DockPanel.Dock="Right"
                                            Background="{StaticResource OpBackgroundPillBrush}"
                                            BorderBrush="{StaticResource OpBorderPillBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="5,1">
                                        <TextBlock Text="{Binding Guide.Requests.Count, StringFormat={}{0} SCHEDULED}"
                                                   Foreground="{StaticResource OpTextAccentBrush}"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="12,10,12,12">
                                <ItemsControl ItemsSource="{Binding TopGuideRequests}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource OpItemBorderStyle}"
                                                    Padding="7,5"
                                                    Margin="0,0,0,4">
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Right"
                                                            Background="#1D1813"
                                                            BorderBrush="{StaticResource OpBorderItemBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="3"
                                                            Padding="4,1"
                                                            Margin="4,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Status}"
                                                                   Foreground="{StaticResource OpTextAccentBrush}"
                                                                   FontSize="9"
                                                                   FontWeight="Bold" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{StaticResource OpTextMutedBrush}"
                                                               FontSize="10"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No guide shifts scheduled."
                                           FontStyle="Italic"
                                           Foreground="{StaticResource OpTextMutedBrush}"
                                           FontSize="10"
                                           Margin="0,2">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Guide.Requests.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- MY ACTIVE TASKS -->
                    <Border Style="{StaticResource OpPanelBorderStyle}" Margin="0,0,0,10">
                        <Expander Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                            <Expander.Header>
                                <DockPanel LastChildFill="False" HorizontalAlignment="Stretch">
                                    <TextBlock Text="MY ACTIVE TASKS"
                                               DockPanel.Dock="Left"
                                               Foreground="{StaticResource OpTextTitleBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <Border DockPanel.Dock="Right"
                                            Background="#1E1927"
                                            BorderBrush="#5F4A8A"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,1">
                                        <TextBlock Text="{Binding MyActiveTasks.Count, StringFormat={}{0} OWNED}"
                                                   Foreground="#B7A7F5"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="12,10,12,12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="160">
                                    <ItemsControl ItemsSource="{Binding MyActiveTasks}"
                                                  ItemTemplate="{StaticResource ActiveRequestCardTemplate}" />
                                </ScrollViewer>
                                <TextBlock Text="Nothing assigned to you right now."
                                           FontStyle="Italic"
                                           Foreground="{StaticResource OpTextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MyActiveTasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- MY OPEN REQUESTS -->
                    <Border Style="{StaticResource OpPanelBorderStyle}" Margin="0,0,0,10">
                        <Expander Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                            <Expander.Header>
                                <DockPanel LastChildFill="False" HorizontalAlignment="Stretch">
                                    <TextBlock Text="MY OPEN REQUESTS"
                                               DockPanel.Dock="Left"
                                               Foreground="{StaticResource OpTextTitleBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <Border DockPanel.Dock="Right"
                                            Background="#16261A"
                                            BorderBrush="#245B36"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,1">
                                        <TextBlock Text="{Binding MyOpenRequests.Count, StringFormat={}{0} PENDING}"
                                                   Foreground="#7ED6A5"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="12,10,12,12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="160">
                                    <ItemsControl ItemsSource="{Binding MyOpenRequests}"
                                                  ItemTemplate="{StaticResource ActiveRequestCardTemplate}" />
                                </ScrollViewer>
                                <TextBlock Text="You have no outstanding requests."
                                           FontStyle="Italic"
                                           Foreground="{StaticResource OpTextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MyOpenRequests.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- ACTIVE REQUESTS -->
                    <Border Style="{StaticResource OpPanelBorderStyle}">
                        <Expander Style="{StaticResource SectionExpanderStyle}" IsExpanded="True">
                            <Expander.Header>
                                <DockPanel LastChildFill="False" HorizontalAlignment="Stretch">
                                    <TextBlock Text="ACTIVE REQUESTS"
                                               DockPanel.Dock="Left"
                                               Foreground="{StaticResource OpTextTitleBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <Border DockPanel.Dock="Right"
                                            Background="{StaticResource OpBackgroundPillBrush}"
                                            BorderBrush="{StaticResource OpBorderPillBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6,1">
                                        <TextBlock Text="{Binding ActiveRequests.Count, StringFormat={}{0} TASKS}"
                                                   Foreground="{StaticResource OpTextAccentBrush}"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Border>
                                </DockPanel>
                            </Expander.Header>
                            <StackPanel Margin="12,10,12,12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="400">
                                    <StackPanel>
                                        <!-- Pinned Section -->
                                        <StackPanel Visibility="{Binding PinnedRequests.Count, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=0}">
                                            <TextBlock Text="PINNED BY LEADERSHIP"
                                                       Foreground="{StaticResource OpTextAccentBrush}"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,8" />
                                            <ItemsControl ItemsSource="{Binding PinnedRequests}"
                                                          ItemTemplate="{StaticResource ActiveRequestCardTemplate}" />
                                            <Separator Background="{StaticResource OpBorderPanelBrush}" Margin="0,8,0,12" />
                                        </StackPanel>

                                        <!-- Regular Section -->
                                        <ItemsControl ItemsSource="{Binding RegularRequests}"
                                                      ItemTemplate="{StaticResource ActiveRequestCardTemplate}" />
                                    </StackPanel>
                                </ScrollViewer>
                                <TextBlock Text="{Binding RequestLoadError}"
                                           Foreground="#CC4444"
                                           FontSize="10"
                                           TextWrapping="Wrap"
                                           Margin="0,4"
                                           Visibility="{Binding RequestLoadError, Converter={StaticResource NullToVisibilityConverter}}" />
                                <TextBlock Text="No active tasks."
                                           FontStyle="Italic"
                                           Foreground="{StaticResource OpTextMutedBrush}"
                                           FontSize="11"
                                           Margin="0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ActiveRequests.Count}" Value="0" />
                                                        <Condition Binding="{Binding RequestLoadError}" Value="{x:Null}" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          IsEnabled="False" />

            <!-- CENTER CHAT PANEL -->
            <Border Grid.Column="2" Style="{StaticResource OpPanelBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Channel list sidebar -->
                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource OpBorderPanelBrush}"
                            BorderThickness="0,0,1,0"
                            Background="#0A0705">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Padding="12,10"
                                    Background="#080503"
                                    BorderBrush="{StaticResource OpBorderPanelBrush}"
                                    BorderThickness="0,0,0,1">
                                <TextBlock Text="CHANNELS"
                                           Foreground="{StaticResource OpTextTitleBrush}"
                                           FontSize="11"
                                           FontWeight="Bold" />
                            </Border>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding AvailableChatChannels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:AvailableChannelViewModel}">
                                            <Border Margin="4,1"
                                                    Padding="8,7"
                                                    CornerRadius="4"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="Channel_MouseLeftButtonUp">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#2A211B" />
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1A1410" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Right"
                                                            Background="#8B1A0F"
                                                            CornerRadius="8"
                                                            Padding="5,1"
                                                            Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{Binding UnreadCount}"
                                                                   Foreground="#F4EBDD"
                                                                   FontSize="9"
                                                                   FontWeight="Bold" />
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Foreground="{Binding AccentBrush}"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="# " />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDirectMessage}" Value="True">
                                                                            <Setter Property="Text" Value="@ " />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding DisplayName}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground"
                                                                            Value="{StaticResource OpTextMutedBrush}" />
                                                                    <Setter Property="FontSize" Value="12" />
                                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}"
                                                                            Value="True">
                                                                            <Setter Property="Foreground"
                                                                                Value="{StaticResource OpTextTitleBrush}" />
                                                                            <Setter Property="FontWeight"
                                                                                Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Active chat area -->
                    <Grid Grid.Column="1">
                        <!-- Empty state -->
                        <TextBlock Text="Select a channel to start chatting"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="13"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveChatWindow}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Active channel panel -->
                        <ContentControl Content="{Binding ActiveChatWindow}"
                                        Visibility="{Binding ActiveChatWindow, Converter={StaticResource NullToVisibilityConverter}}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type vm:ChatWindowViewModel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Channel header -->
                                        <Border Grid.Row="0"
                                                Background="{StaticResource OpBackgroundHeaderBrush}"
                                                BorderBrush="{StaticResource OpBorderPanelBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="16,10">
                                            <DockPanel LastChildFill="False">
                                                <Button DockPanel.Dock="Right"
                                                        Command="{Binding DataContext.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Padding="8,4"
                                                        FontSize="9"
                                                        FontWeight="Bold"
                                                        BorderBrush="{StaticResource OpBorderItemBrush}"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center"
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#2A211B" />
                                                            <Setter Property="Foreground"
                                                                    Value="{StaticResource OpTextAccentBrush}" />
                                                            <Setter Property="Content" Value="MUTE" />
                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding DataContext.ChatSoundMuted, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    Value="True">
                                                                    <Setter Property="Background" Value="#4A2424" />
                                                                    <Setter Property="Foreground" Value="#F8E8E8" />
                                                                    <Setter Property="Content" Value="MUTED" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="# "
                                                               Foreground="{Binding AccentBrush}"
                                                               FontSize="15"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{StaticResource OpTextTitleBrush}"
                                                               FontSize="15"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>

                                        <!-- Messages -->
                                        <ScrollViewer Grid.Row="1"
                                                      behaviors:AutoScrollBehavior.AutoScrollSource="{Binding Messages}"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Padding="8">
                                            <StackPanel>
                                                <ItemsControl ItemsSource="{Binding Messages}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1,0,0">
                                                                <Grid.Style>
                                                                    <Style TargetType="Grid">
                                                                        <Setter Property="Background"
                                                                            Value="Transparent" />
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsMouseOver"
                                                                                Value="True">
                                                                                <Setter Property="Background"
                                                                                    Value="#0CFFFFFF" />
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>

                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="44" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="32" />
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Avatar circle -->
                                                                <Border Grid.Column="0"
                                                                        Width="36"
                                                                        Height="36"
                                                                        CornerRadius="18"
                                                                        Background="#5C3D1E"
                                                                        VerticalAlignment="Top"
                                                                        HorizontalAlignment="Center"
                                                                        Margin="0,6,0,0">
                                                                    <Grid>
                                                                        <TextBlock Text="{Binding InitialLetter}"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            FontWeight="Bold"
                                                                            FontSize="13"
                                                                            Foreground="#E8C87A"
                                                                            Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibility}}" />
                                                                        <Image Source="{Binding AvatarImage}"
                                                                               Width="36"
                                                                               Height="36"
                                                                               Stretch="UniformToFill"
                                                                               Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}">
                                                                            <Image.Clip>
                                                                                <EllipseGeometry Center="18,18"
                                                                                    RadiusX="18" RadiusY="18" />
                                                                            </Image.Clip>
                                                                        </Image>
                                                                    </Grid>
                                                                </Border>

                                                                <!-- Message body -->
                                                                <StackPanel Grid.Column="1" Margin="4,6,8,6">
                                                                    <DockPanel LastChildFill="False">
                                                                        <TextBlock Text="{Binding SenderDisplayName}"
                                                                            FontWeight="SemiBold"
                                                                            FontSize="12"
                                                                            Foreground="{StaticResource OpTextTitleBrush}"
                                                                            DockPanel.Dock="Left"
                                                                            VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding RoleDisplay}"
                                                                            FontSize="9"
                                                                            FontWeight="Bold"
                                                                            Foreground="#D4AF37"
                                                                            Margin="6,0,0,0"
                                                                            Padding="4,1"
                                                                            Background="#1AD4AF37"
                                                                            DockPanel.Dock="Left"
                                                                            VerticalAlignment="Center"
                                                                            Visibility="{Binding RoleDisplay, Converter={StaticResource NullToVisibilityConverter}}" />
                                                                        <TextBlock Text="{Binding FormattedTime}"
                                                                            FontSize="9"
                                                                            Foreground="{StaticResource OpTextMutedBrush}"
                                                                            Margin="8,0,0,0"
                                                                            DockPanel.Dock="Left"
                                                                            VerticalAlignment="Center" />
                                                                    </DockPanel>

                                                                    <controls:MarkdownTextBlock
                                                                        Markdown="{Binding Content}"
                                                                        FontSize="12"
                                                                        Foreground="{StaticResource OpTextPrimaryBrush}"
                                                                        TextWrapping="Wrap"
                                                                        Margin="0,2,0,0"
                                                                        LineHeight="18"
                                                                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}" />

                                                                    <Grid Margin="0,3,0,0"
                                                                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <TextBox Grid.Column="0"
                                                                            Text="{Binding EditDraft, UpdateSourceTrigger=PropertyChanged}"
                                                                            Style="{StaticResource OpTextBoxStyle}"
                                                                            Padding="6,4"
                                                                            FontSize="11">
                                                                            <TextBox.InputBindings>
                                                                                <KeyBinding Key="Return"
                                                                                    Command="{Binding ConfirmEditCommand}" />
                                                                                <KeyBinding Key="Escape"
                                                                                    Command="{Binding CancelEditCommand}" />
                                                                            </TextBox.InputBindings>
                                                                        </TextBox>

                                                                        <Button Grid.Column="1"
                                                                            Content="Save"
                                                                            Command="{Binding ConfirmEditCommand}"
                                                                            Margin="4,0,0,0"
                                                                            Padding="8,3"
                                                                            FontSize="10"
                                                                            Background="#2A3A2A"
                                                                            Foreground="#AAD4AA"
                                                                            BorderBrush="#5C8B5E"
                                                                            BorderThickness="1" />

                                                                        <Button Grid.Column="2"
                                                                            Content="Cancel"
                                                                            Command="{Binding CancelEditCommand}"
                                                                            Margin="4,0,0,0"
                                                                            Padding="8,3"
                                                                            FontSize="10"
                                                                            Background="#2A211B"
                                                                            Foreground="{StaticResource OpTextMutedBrush}"
                                                                            BorderBrush="{StaticResource OpBorderItemBrush}"
                                                                            BorderThickness="1" />
                                                                    </Grid>
                                                                </StackPanel>

                                                                <!-- Three dots menu -->
                                                                <Button Grid.Column="2"
                                                                        Content="⋯"
                                                                        Margin="0,6,4,0"
                                                                        VerticalAlignment="Top"
                                                                        HorizontalAlignment="Right"
                                                                        Style="{StaticResource ChatMessageMenuButtonStyle}"
                                                                        Visibility="{Binding IsOwnMessage, Converter={StaticResource BoolToVisibility}}">
                                                                    <Button.ContextMenu>
                                                                        <ContextMenu
                                                                            Style="{StaticResource ChatMessageContextMenuStyle}">
                                                                            <MenuItem Header="Edit"
                                                                                Command="{Binding BeginEditCommand}"
                                                                                Style="{StaticResource ChatMessageMenuItemStyle}" />
                                                                            <MenuItem Header="Delete"
                                                                                Command="{Binding DeleteCommand}"
                                                                                Style="{StaticResource ChatMessageMenuItemStyle}" />
                                                                        </ContextMenu>
                                                                    </Button.ContextMenu>
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="No messages yet."
                                                           Foreground="{StaticResource OpTextMutedBrush}"
                                                           FontStyle="Italic"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,18,0,8">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Messages.Count}"
                                                                             Value="0">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <!-- Input -->
                                        <Border Grid.Row="2"
                                                Background="{StaticResource OpBackgroundInputBrush}"
                                                BorderBrush="{StaticResource OpBorderPanelBrush}"
                                                BorderThickness="0,1,0,0"
                                                Padding="12,8,12,6">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="ChatInputBox"
                                                             Grid.Column="0"
                                                             Text="{Binding DraftMessage, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource OpTextBoxStyle}"
                                                             Padding="10,8"
                                                             MaxHeight="100"
                                                             AcceptsReturn="False"
                                                             VerticalScrollBarVisibility="Auto"
                                                             VerticalContentAlignment="Center"
                                                             PreviewKeyDown="ChatInput_PreviewKeyDown">
                                                        <TextBox.InputBindings>
                                                            <KeyBinding Key="Return"
                                                                        Command="{Binding SendMessageCommand}" />
                                                        </TextBox.InputBindings>
                                                    </TextBox>
                                                    <Button Grid.Column="1"
                                                            Content="SEND"
                                                            Command="{Binding SendMessageCommand}"
                                                            Style="{StaticResource ChatSendButtonStyle}"
                                                            Margin="8,0,0,0" />
                                                </Grid>
                                                <TextBlock Margin="2,4,0,0"
                                                           FontSize="9"
                                                           Foreground="{StaticResource OpTextMutedBrush}"
                                                           TextWrapping="Wrap">
                                                    <Run Text="**bold**" />
                                                    <Run Text="  " />
                                                    <Run Text="*italic*" />
                                                    <Run Text="  " />
                                                    <Run Text="__underline__" />
                                                    <Run Text="  " />
                                                    <Run Text="~~strike~~" />
                                                    <Run Text="  " />
                                                    <Run FontFamily="Consolas" Text="`code`" />
                                                    <Run Text="  " />
                                                    <Run Text="||spoiler||" />
                                                    <Run Text="  " />
                                                    <Run Text="&gt; quote" />
                                                    <Run Text="  · Shift+Enter for new line" Foreground="#4E5058" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Grid>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="3"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          IsEnabled="False" />

            <!-- RIGHT SIDEBAR -->
            <Border Grid.Column="4"
                    Style="{StaticResource OpPanelBorderStyle}"
                    Padding="12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="ONLINE"
                                   Foreground="{StaticResource OpTextTitleBrush}"
                                   FontSize="12"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding OnlineUsers.Count, StringFormat={}{0} active}"
                                   Foreground="{StaticResource OpTextMutedBrush}"
                                   FontSize="10" />
                        <Separator Margin="0,6"
                                   Background="{StaticResource OpBorderPanelBrush}" />
                    </StackPanel>

                    <ScrollViewer DockPanel.Dock="Top"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding OnlineUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:OnlineUserViewModel}">
                                    <Border x:Name="UserCard"
                                            Style="{StaticResource OnlineUserCardStyle}">
                                        <Border.ContextMenu>
                                            <ContextMenu Style="{StaticResource OnlineUserContextMenuStyle}"
                                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="Message"
                                                          Style="{StaticResource OnlineUserContextMenuItemStyle}"
                                                          Command="{Binding DataContext.OpenDirectMessageCommand, Source={x:Reference RootDashboard}}"
                                                          CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar -->
                                            <Border Grid.Column="0"
                                                    Width="34"
                                                    Height="34"
                                                    CornerRadius="17"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding RoleColorBrush}"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding AvatarImage}"
                                                           Stretch="UniformToFill"
                                                           Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}" />

                                                    <TextBlock Text="{Binding InitialLetter}"
                                                               Foreground="#15120F"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibility}}" />
                                                </Grid>
                                            </Border>

                                            <!-- Name and role -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="8,0,8,0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ContactLabel}"
                                                           Foreground="{StaticResource OpTextTitleBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock FontSize="10"
                                                           Foreground="{StaticResource OpTextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding Role}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Role}" Value="{x:Null}">
                                                                    <Setter Property="Text" Value="Member" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Role}" Value="">
                                                                    <Setter Property="Text" Value="Member" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Hover action -->
                                            <Button x:Name="MessageButton"
                                                    Grid.Column="2"
                                                    Content="MESSAGE"
                                                    Style="{StaticResource OnlineUserActionButtonStyle}"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.OpenDirectMessageCommand, Source={x:Reference RootDashboard}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="UserCard" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="MessageButton" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="UserCard" Property="BorderBrush"
                                                    Value="{StaticResource OpBorderPillBrush}" />
                                            <Setter TargetName="UserCard" Property="Background" Value="#18120E" />
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
