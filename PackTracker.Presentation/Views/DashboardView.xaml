<UserControl x:Class="PackTracker.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

        <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2B2B2B" Offset="0"/>
            <GradientStop Color="#1C1C1C" Offset="0.65"/>
            <GradientStop Color="#141414" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#232323"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect" Value="{DynamicResource CardShadow}"/>
        </Style>

        <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="12,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="MetricLabelStyle">
            <Setter Property="Foreground" Value="#B6B6B6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="MetricValueStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Orientation="Vertical" Margin="0,0,0,12">
            <TextBlock Text="Operations Dashboard"
                       FontSize="34"
                       FontWeight="Black"
                       Foreground="White"/>
            <TextBlock Text="Live snapshot of House Wolf readiness across squads and support teams."
                       FontSize="15"
                       Foreground="#B5B5B5"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical" Margin="0,4,0,0">

                <!-- Hero -->
                <Border Background="{StaticResource HeroBackgroundBrush}"
                        CornerRadius="26"
                        Padding="28"
                        Effect="{DynamicResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Guild support posture is stable."
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Keep this view pinned for request traffic, guide scheduling, and logistics coordination while crafting workflows are brought online."
                                   FontSize="14"
                                   Foreground="#BEBEBE"
                                   Margin="0,4,0,12"/>

                        <WrapPanel Margin="0,12,0,0"
                                   HorizontalAlignment="Stretch">
                            <Border Width="220"
                                    CornerRadius="16"
                                    Padding="12"
                                    Margin="0,0,12,12"
                                    Background="#2F2F2F"
                                    Effect="{DynamicResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="Active requests"
                                               Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding ActiveRequests.Count}"
                                               Style="{StaticResource MetricValueStyle}"
                                               ToolTip="Currently open, ordered by priority."/>
                                </StackPanel>
                            </Border>
                            <Border Width="220"
                                    CornerRadius="16"
                                    Padding="12"
                                    Margin="0,0,12,12"
                                    Background="#2F2F2F"
                                    Effect="{DynamicResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="Scheduled guides"
                                               Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding Guide.Requests.Count}"
                                               Style="{StaticResource MetricValueStyle}"
                                               ToolTip="Guide request watcher feed."/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Content cards -->
                <WrapPanel Margin="0,24,0,0"
                           HorizontalAlignment="Stretch">

                    <!-- Active requests -->
                    <Border Style="{StaticResource DashboardCardStyle}"
                            Width="420"
                            MinWidth="340">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                <TextBlock Text="Urgent requests"
                                           Style="{StaticResource SectionHeaderTextStyle}"/>
                                <Border Style="{StaticResource BadgeStyle}">
                                    <TextBlock Text="{Binding ActiveRequests.Count, StringFormat={}{0} open}"
                                               FontSize="12"
                                               Foreground="#F1F1F1"/>
                                </Border>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ActiveRequests}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1F1F1F"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           TextWrapping="Wrap"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border Background="#43536A"
                                                            CornerRadius="8"
                                                            Padding="8,2"
                                                            Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding Kind}"
                                                                   FontSize="12"
                                                                   Foreground="#F3F6FF"/>
                                                    </Border>
                                                    <Border Background="#5B2A2A"
                                                            CornerRadius="8"
                                                            Padding="8,2"
                                                            Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding Priority}"
                                                                   FontSize="12"
                                                                   Foreground="#FFD7D7"/>
                                                    </Border>
                                                    <Border Background="#2F3B2F"
                                                            CornerRadius="8"
                                                            Padding="8,2">
                                                        <TextBlock Text="{Binding Status}"
                                                                   FontSize="12"
                                                                   Foreground="#B9FFBF"/>
                                                    </Border>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="#B7B7B7"
                                                           FontSize="12"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>

                                                <TextBlock Text="{Binding CreatedByDisplayName, StringFormat='Raised by {0}'}"
                                                           Foreground="#909090"
                                                           FontSize="12"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MMM dd · HH:mm}}"
                                                           Foreground="#6D6D6D"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveRequests.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                            <TextBlock Text="All quiet on the request board."
                                       Foreground="#7D7D7D"
                                       FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveRequests.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Guide schedule -->
                    <Border Style="{StaticResource DashboardCardStyle}"
                            Width="420"
                            MinWidth="340">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="Guide rota"
                                           Style="{StaticResource SectionHeaderTextStyle}"
                                           DockPanel.Dock="Left"/>
                                <Button Content="Refresh"
                                        Command="{Binding Guide.RefreshCommand}"
                                        DockPanel.Dock="Right"
                                        Padding="10,4"
                                        Margin="12,0,0,0"
                                        FontSize="12"
                                        HorizontalAlignment="Right"/>
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding Guide.Requests}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1F1F1F"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="15"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding Requester, StringFormat='Requested by {0}'}"
                                                               Foreground="#9F9F9F"
                                                               FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            HorizontalAlignment="Right">
                                                    <Border Background="#454545"
                                                            CornerRadius="8"
                                                            Padding="8,2"
                                                            HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding Status}"
                                                                   Foreground="#F7F7F7"
                                                                   FontSize="12"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MMM dd · HH:mm}}"
                                                               Foreground="#7F7F7F"
                                                               FontSize="11"
                                                               Margin="0,6,0,0"
                                                               HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Guide.Requests.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>

                            <TextBlock Text="No guide shifts are scheduled."
                                       Foreground="#7D7D7D"
                                       FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Guide.Requests.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
