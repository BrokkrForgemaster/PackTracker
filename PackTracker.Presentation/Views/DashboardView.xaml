<UserControl x:Class="PackTracker.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Style="{StaticResource OpHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="OPERATIONS DASHBOARD" Foreground="{StaticResource OpTextTitleBrush}" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Live snapshot of House Wolf readiness across squads and support teams."
                           Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <!-- ── Hero Section ── -->
                <Border Style="{StaticResource OpHeaderBorderStyle}" Margin="0,0,0,16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Guild support posture is stable." Foreground="{StaticResource OpTextTitleBrush}" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Keep this view pinned for request traffic, guide scheduling, and logistics coordination while crafting workflows are brought online."
                                   Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="12" Margin="0,4,0,16" TextWrapping="Wrap"/>

                        <WrapPanel HorizontalAlignment="Stretch">
                            <Border Width="220" Style="{StaticResource OpItemBorderStyle}" Background="{StaticResource OpBackgroundPillBrush}" BorderBrush="{StaticResource OpBorderPillBrush}" Margin="0,0,12,0" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="ACTIVE REQUESTS" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ActiveRequests.Count}" Foreground="{StaticResource OpTextTitleBrush}" FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Width="220" Style="{StaticResource OpItemBorderStyle}" Background="{StaticResource OpBackgroundPillBrush}" BorderBrush="{StaticResource OpBorderPillBrush}" Margin="0,0,12,0" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="SCHEDULED GUIDES" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Guide.Requests.Count}" Foreground="{StaticResource OpTextTitleBrush}" FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ── Content Grid ── -->
                <UniformGrid Columns="2">
                    
                    <!-- Urgent Requests -->
                    <Border Style="{StaticResource OpPanelBorderStyle}" Margin="0,0,8,0" Padding="16">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,12">
                                <TextBlock Text="URGENT REQUESTS" Style="{x:Null}" Foreground="{StaticResource OpTextTitleBrush}" FontSize="14" FontWeight="Bold" DockPanel.Dock="Left"/>
                                <Border Background="{StaticResource OpBackgroundPillBrush}" CornerRadius="10" Padding="8,2" DockPanel.Dock="Right">
                                    <TextBlock Text="{Binding ActiveRequests.Count, StringFormat={}{0} OPEN}" Foreground="{StaticResource OpTextAccentBrush}" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding ActiveRequests}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource OpItemBorderStyle}" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource OpTextTitleBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border Background="#24374A" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding Kind}" Foreground="#E8F0F8" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <Border Background="#8B1A0F" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding Priority}" Foreground="#F4EBDD" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <Border Background="#2B4E2E" CornerRadius="4" Padding="6,2">
                                                        <TextBlock Text="{Binding Status}" Foreground="#EEF6EE" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource OpTextSecondaryBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                                                           Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>

                                                <DockPanel Margin="0,8,0,0">
                                                    <TextBlock Text="{Binding CreatedByDisplayName, StringFormat='Raised by {0}'}" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MMM dd · HH:mm}}" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" DockPanel.Dock="Right"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="All quiet on the request board." Foreground="{StaticResource OpTextMutedBrush}" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveRequests.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Guide Rota -->
                    <Border Style="{StaticResource OpPanelBorderStyle}" Margin="8,0,0,0" Padding="16">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,12">
                                <TextBlock Text="GUIDE ROTA" Style="{x:Null}" Foreground="{StaticResource OpTextTitleBrush}" FontSize="14" FontWeight="Bold" DockPanel.Dock="Left"/>
                                <Button Content="REFRESH" Command="{Binding Guide.RefreshCommand}" DockPanel.Dock="Right" Padding="8,2" FontSize="10" FontWeight="Bold" Background="#24374A" Foreground="#E8F0F8" BorderBrush="#4F6A84"/>
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding Guide.Requests}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource OpItemBorderStyle}" Padding="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource OpTextTitleBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Requester, StringFormat='Requested by {0}'}" Foreground="{StaticResource OpTextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <Border Background="#1D1813" BorderBrush="#3E3023" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource OpTextAccentBrush}" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MMM dd · HH:mm}}" Foreground="{StaticResource OpTextMutedBrush}" FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No guide shifts are scheduled." Foreground="{StaticResource OpTextMutedBrush}" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Guide.Requests.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>