<Window x:Class="PackTracker.Presentation.Views.NewRequestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
        Title="New Assistance Request"
        Width="700" Height="750"
        Background="Transparent" WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        AllowsTransparency="True">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:RequestKindToIconConverter x:Key="RequestKindToIconConverter"/>
        <converters:RequestKindToColorConverter x:Key="RequestKindToColorConverter"/>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelStrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,6,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Padding="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="24" Padding="32"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource AccentGoldBrush}" BorderThickness="2"
            Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Margin="0,0,0,20" Grid.Row="0" HorizontalAlignment="Center">
                <TextBlock Text="➕ New Assistance Request"
                           FontSize="32" FontWeight="Black"
                           Foreground="White" TextAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Request help from House Wolf members for materials, missions, and more."
                           FontSize="14" Foreground="#CCCCCC"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="600"/>
            </StackPanel>

            <!-- BODY -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                <StackPanel Orientation="Vertical">

                    <!-- Request Type & Priority Row -->
                    <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="📋 Request Type"
                                           Foreground="#C2A23A"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding KindOptions}"
                                          SelectedItem="{Binding SelectedKind}"
                                          Style="{StaticResource ModernComboBox}"
                                          Background="{DynamicResource SurfaceAltBrush}"
                                          Margin="0,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="⚡ Priority"
                                           Foreground="#C2A23A"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding PriorityOptions}"
                                          SelectedItem="{Binding SelectedPriority}"
                                          Style="{StaticResource ModernComboBox}"
                                          Margin="0,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Basic Information -->
                    <TextBlock Text="📝 Basic Information"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Title *"
                               Foreground="#BBB"
                               FontSize="13"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             ToolTip="Brief title describing what you need"/>

                    <TextBlock Text="Description *"
                               Foreground="#BBB"
                               FontSize="13"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="100"
                             Style="{StaticResource ModernTextBox}"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="Detailed description of what you need help with"/>

                    <!-- Material/Resource Section (conditional) -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,4,0,20"
                            Visibility="{Binding ShowMaterialFields, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="📦 Material / Resource Details"
                                       Foreground="#FFA500"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Material Name"
                                               Foreground="#BBB"
                                               FontSize="13"
                                               Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding MaterialName}"
                                             Style="{StaticResource ModernTextBox}"
                                             Margin="0,0,0,0"
                                             ToolTip="e.g., Quantanium, Hadanite, Medical Supplies"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="Quantity"
                                               Foreground="#BBB"
                                               FontSize="13"
                                               Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding QuantityNeeded}"
                                             Style="{StaticResource ModernTextBox}"
                                             Margin="0,0,0,0"
                                             ToolTip="How much you need"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Meeting Location"
                                       Foreground="#BBB"
                                       FontSize="13"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MeetingLocation}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="e.g., Port Olisar, Crusader L1"/>

                            <TextBlock Text="Reward Offered"
                                       Foreground="#BBB"
                                       FontSize="13"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding RewardOffered}"
                                     Style="{StaticResource ModernTextBox}"
                                     Margin="0,0,0,0"
                                     ToolTip="e.g., 100k aUEC, Split 60/40, Free"/>
                        </StackPanel>
                    </Border>

                    <!-- Crew/Helper Section (conditional) -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,4,0,20"
                            Visibility="{Binding ShowCrewFields, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="👥 Crew / Helper Information"
                                       Foreground="#6DB3F2"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Number of Helpers Needed"
                                       Foreground="#BBB"
                                       FontSize="13"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NumberOfHelpersNeeded}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="How many people do you need?"/>

                            <TextBlock Text="Meeting Location"
                                       Foreground="#BBB"
                                       FontSize="13"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MeetingLocation}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="Where should helpers meet you?"/>

                            <TextBlock Text="Reward Offered"
                                       Foreground="#BBB"
                                       FontSize="13"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding RewardOffered}"
                                     Style="{StaticResource ModernTextBox}"
                                     Margin="0,0,0,0"
                                     ToolTip="Payment or reward for helping"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="* Required fields"
                               Foreground="#888"
                               FontSize="12"
                               FontStyle="Italic"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- FOOTER -->
            <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center">
                <Button Content="✖ Cancel"
                        Width="140"
                        Style="{StaticResource ModernButton}"
                        Background="#3A3A3A"
                        Click="Cancel_Click"
                        ToolTip="Cancel and close"/>

                <Button Content="✅ Submit Request"
                        Width="180"
                        Style="{StaticResource ModernButton}"
                        Background="#C2A23A"
                        Foreground="Black"
                        FontWeight="Bold"
                        Command="{Binding SubmitCommand}"
                        ToolTip="Submit your request to the org"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
