<Window x:Class="PackTracker.Presentation.Views.NewRequestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Assistance Request"
        Width="780" Height="820"
        Background="Transparent" WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">

    <Border CornerRadius="24" Padding="28"
            Background="#1E1E1E"
            BorderBrush="#C2A23A" BorderThickness="2"
            Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Margin="0,0,0,12" Grid.Row="0" HorizontalAlignment="Center">
                <TextBlock Text="Request Assistance"
                           FontSize="30" FontWeight="Black"
                           Foreground="White" TextAlignment="Center"/>
                <TextBlock Text="Describe what you want to learn or need help with."
                           FontSize="14" Foreground="#CCCCCC"
                           TextAlignment="Center"/>
            </StackPanel>

            <!-- BODY -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Skill / Objective" Foreground="#C2A23A" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding SkillObjectiveOptions}"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding SkillObjective}"
                              IsEditable="True"
                              Background="#2B2B2B" Foreground="Black"/>

                    <TextBlock Text="Game Build" Foreground="#C2A23A" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding GameBuildOptions}"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding GameBuild}"
                              Background="#2B2B2B" Foreground="Black"/>

                    <TextBlock Text="Player Handle / In-Game Name" Foreground="#C2A23A"  FontWeight="Bold"/>
                    <TextBox Text="{Binding PlayerHandle}" Background="#2B2B2B" Foreground="White"/>

                    <TextBlock Text="Time Zone" FontWeight="Bold" Foreground="#C2A23A"/>
                    <ComboBox ItemsSource="{Binding TimeZoneOptions}"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding TimeZone}"
                              Background="#2B2B2B" Foreground="Black"/>

                    <TextBlock Text="Mic / VOIP" FontWeight="Bold" Foreground="#C2A23A"/>
                    <CheckBox Content="I have a working mic" IsChecked="{Binding HasMic}"
                              Foreground="#C2A23A" Margin="4,0,0,0"/>

                    <TextBlock Text="Platform / Specs" FontWeight="Bold" Foreground="#C2A23A"/>
                    <ComboBox ItemsSource="{Binding PlatformOptions}"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding PlatformSpecs}"
                              Background="#2B2B2B" Foreground="Black"/>

                    <TextBlock Text="Availability (next 7 days)" FontWeight="Bold" Foreground="#C2A23A"/>
                    <TextBox Text="{Binding Availability}" AcceptsReturn="True" Height="60"
                             Background="#2B2B2B" Foreground="White"/>

                    <TextBlock Text="Current Baseline" FontWeight="Bold" Foreground="#C2A23A"/>
                    <TextBox Text="{Binding Baseline}" AcceptsReturn="True" Height="60"
                             Background="#2B2B2B" Foreground="White"/>

                    <TextBlock Text="Assets / Ships" FontWeight="Bold" Foreground="#C2A23A"/>
                    <ComboBox ItemsSource="{Binding AssetOptions}"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding Assets}"
                              Background="#2B2B2B" Foreground="Black"/>

                    <TextBlock Text="Urgency" FontWeight="Bold" Foreground="#C2A23A"/>
                    <ComboBox ItemsSource="{Binding UrgencyOptions}"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding Urgency}"
                              Background="#2B2B2B" Foreground="Black"/>

                    <TextBlock Text="Group Size Preference" FontWeight="Bold" Foreground="#C2A23A"/>
                    <ComboBox ItemsSource="{Binding GroupOptions}"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding GroupPreference}"
                              Background="#2B2B2B" Foreground="Black"/>

                    <TextBlock Text="Success Criteria" FontWeight="Bold" Foreground="#C2A23A"/>
                    <TextBox Text="{Binding SuccessCriteria}" AcceptsReturn="True" Height="60"
                             Background="#2B2B2B" Foreground="White"/>

                    <TextBlock Text="Recording Permission" FontWeight="Bold" Foreground="#C2A23A"/>
                    <ComboBox ItemsSource="{Binding RecordOptions}"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding RecordingPermission}"
                              Background="#2B2B2B" Foreground="Black"/>
                </StackPanel>
            </ScrollViewer>

            <!-- FOOTER -->
            <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button Content="Cancel" Width="120" Height="38"
                        Background="#3A3A3A" Foreground="White"
                        Margin="8,0" Click="Cancel_Click"/>
                <Button Content="Submit Request" Width="180" Height="38"
                        Background="#C2A23A" Foreground="Black" FontWeight="Bold"
                        Command="{Binding SubmitCommand}" Margin="8,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
