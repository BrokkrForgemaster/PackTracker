{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Authentication": {
    "Discord": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-discord",
      "RequiredGuildId": "1119651167639715962"
    }
  },
  "Jwt": {
    "Key": "",
    "Issuer": "PackTracker",
    "Audience": "PackTrackerClients",
    "ExpiresInMinutes": 60
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/packtracker-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] ({SourceContext}) {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  }
}