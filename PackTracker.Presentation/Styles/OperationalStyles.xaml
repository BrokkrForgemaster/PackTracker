<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
    ═══════════════════════════════════════════════════════════════
    HOUSE WOLF — Operational UI Palette
    Shared colors and styles for a unified Star Citizen aesthetic.
    ═══════════════════════════════════════════════════════════════
    -->

    <!-- Colors -->
    <Color x:Key="OpBackgroundHeaderColor">#15120F</Color>
    <Color x:Key="OpBackgroundPanelColor">#14110E</Color>
    <Color x:Key="OpBackgroundItemColor">#191510</Color>
    <Color x:Key="OpBackgroundInputColor">#1D1813</Color>
    <Color x:Key="OpBackgroundPillColor">#20170F</Color>
    
    <Color x:Key="OpBorderHeaderColor">#30251B</Color>
    <Color x:Key="OpBorderPanelColor">#2A2118</Color>
    <Color x:Key="OpBorderItemColor">#31271E</Color>
    <Color x:Key="OpBorderInputColor">#3E3023</Color>
    <Color x:Key="OpBorderPillColor">#4B3828</Color>
    <Color x:Key="OpBorderAccentColor">#8B1A0F</Color>
    
    <Color x:Key="OpTextTitleColor">#E7D7B8</Color>
    <Color x:Key="OpTextPrimaryColor">#E6D5B6</Color>
    <Color x:Key="OpTextSecondaryColor">#85745E</Color>
    <Color x:Key="OpTextMutedColor">#7E6B56</Color>
    <Color x:Key="OpTextAccentColor">#CBB293</Color>

    <SolidColorBrush x:Key="OpBackgroundHeaderBrush" Color="{StaticResource OpBackgroundHeaderColor}"/>
    <SolidColorBrush x:Key="OpBackgroundPanelBrush" Color="{StaticResource OpBackgroundPanelColor}"/>
    <SolidColorBrush x:Key="OpBackgroundItemBrush" Color="{StaticResource OpBackgroundItemColor}"/>
    <SolidColorBrush x:Key="OpBackgroundInputBrush" Color="{StaticResource OpBackgroundInputColor}"/>
    <SolidColorBrush x:Key="OpBackgroundPillBrush" Color="{StaticResource OpBackgroundPillColor}"/>

    <SolidColorBrush x:Key="OpBorderHeaderBrush" Color="{StaticResource OpBorderHeaderColor}"/>
    <SolidColorBrush x:Key="OpBorderPanelBrush" Color="{StaticResource OpBorderPanelColor}"/>
    <SolidColorBrush x:Key="OpBorderItemBrush" Color="{StaticResource OpBorderItemColor}"/>
    <SolidColorBrush x:Key="OpBorderInputBrush" Color="{StaticResource OpBorderInputColor}"/>
    <SolidColorBrush x:Key="OpBorderPillBrush" Color="{StaticResource OpBorderPillColor}"/>
    <SolidColorBrush x:Key="OpBorderAccentBrush" Color="{StaticResource OpBorderAccentColor}"/>

    <SolidColorBrush x:Key="OpTextTitleBrush" Color="{StaticResource OpTextTitleColor}"/>
    <SolidColorBrush x:Key="OpTextPrimaryBrush" Color="{StaticResource OpTextPrimaryColor}"/>
    <SolidColorBrush x:Key="OpTextSecondaryBrush" Color="{StaticResource OpTextSecondaryColor}"/>
    <SolidColorBrush x:Key="OpTextMutedBrush" Color="{StaticResource OpTextMutedColor}"/>
    <SolidColorBrush x:Key="OpTextAccentBrush" Color="{StaticResource OpTextAccentColor}"/>

    <!-- ══════════════════════════════════════
         BASE PANEL STYLE
    ══════════════════════════════════════ -->
    <Style x:Key="OpHeaderBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OpBackgroundHeaderBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OpBorderHeaderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="18,14"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="OpPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OpBackgroundPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OpBorderPanelBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="OpItemBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OpBackgroundItemBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OpBorderItemBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- ══════════════════════════════════════
         COMBO BOX STYLES (Extracted from BlueprintExplorer)
    ══════════════════════════════════════ -->
    <Style x:Key="OpComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource OpBackgroundInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#3E3023"/>
                            <Setter Property="Foreground" Value="#F0DFC0"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#4B3828"/>
                            <Setter Property="Foreground" Value="#F0DFC0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OpComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource OpBackgroundInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OpBorderInputBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource OpComboBoxItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"/>

                        <ContentPresenter x:Name="ContentSite"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="10,0,32,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"/>

                        <TextBlock Text="▾"
                                   Foreground="#9A8264"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   IsHitTestVisible="False"/>

                        <ToggleButton Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    Background="{StaticResource OpBackgroundInputBrush}"
                                    BorderBrush="{StaticResource OpBorderInputBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="300"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#6B5A42"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#8B6F4E"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════
         INPUT STYLES
    ══════════════════════════════════════ -->
    <Style x:Key="OpTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource OpBackgroundInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OpTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OpBorderInputBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="CaretBrush" Value="{StaticResource OpTextPrimaryBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource OpBorderAccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════
         LISTBOX ITEM STYLE
    ══════════════════════════════════════ -->
    <Style x:Key="OpListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <!-- We don't want a default background for selection if we're using card-based items -->
                            <Setter Property="Foreground" Value="{StaticResource OpTextTitleBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OpListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource OpListBoxItemStyle}"/>
    </Style>

</ResourceDictionary>
