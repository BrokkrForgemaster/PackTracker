<Application x:Class="PackTracker.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PackTracker.Presentation.Converters"
             DispatcherUnhandledException="App_DispatcherUnhandledException">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/OperationalStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/BlueprintStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>