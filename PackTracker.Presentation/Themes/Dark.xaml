<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Base colors -->
  <Color x:Key="AccentColor">#CC5500</Color>
  <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>

  <SolidColorBrush x:Key="SidebarBackground" Color="#1a1a1a"/>
  <SolidColorBrush x:Key="MainBackground"    Color="#111111"/>
  <SolidColorBrush x:Key="CardBackground"    Color="#222222"/>

  <SolidColorBrush x:Key="ForegroundBrush"   Color="White"/>
  <SolidColorBrush x:Key="GlassBorderBrush"  Color="#40FFFFFF"/>
  <LinearGradientBrush x:Key="GlassAccentBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#80FFFFFF" Offset="0.0"/>
    <GradientStop Color="#40FFFFFF" Offset="0.5"/>
    <GradientStop Color="#20FFFFFF" Offset="1.0"/>
  </LinearGradientBrush>

  <BitmapImage x:Key="SidebarImage" UriSource="/Assets/HWiconnew.png"/>

  <!-- Card shadow now uses AccentColor -->
  <DropShadowEffect x:Key="CardShadow"
                    Color="{DynamicResource AccentColor}"
                    ShadowDepth="4"
                    BlurRadius="15"
                    Opacity="0.5"/>

  <!-- Glow under the main content -->
  <DropShadowEffect x:Key="ContentGlowEffect"
                    Color="{DynamicResource AccentColor}"
                    BlurRadius="20"
                    ShadowDepth="0"
                    Opacity="0.6"/>

  <!-- Sidebar style -->
  <Style x:Key="SidebarBorderStyle" TargetType="Border">
    <Setter Property="Background"      Value="{DynamicResource SidebarBackground}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="CornerRadius"    Value="24"/>
    <Setter Property="Effect"          Value="{DynamicResource CardShadow}"/>
  </Style>

  <!-- Main content style -->
  <Style x:Key="ContentBorderStyle" TargetType="Border">
    <Setter Property="Background"      Value="{DynamicResource CardBackground}"/>
    <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="CornerRadius"    Value="24"/>
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect
          Color="{DynamicResource AccentColor}"
          BlurRadius="25"
          ShadowDepth="0"
          Opacity="0.4"/>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Sidebar Button Style -->
  <Style x:Key="SidebarButtonStyle" TargetType="Button">
    <Setter Property="Foreground"     Value="{DynamicResource ForegroundBrush}"/>
    <Setter Property="Background"     Value="{DynamicResource GlassAccentBrush}"/>
    <Setter Property="BorderBrush"    Value="{DynamicResource GlassBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"        Value="12,8"/>
    <Setter Property="Margin"         Value="0,8"/>
    <Setter Property="FontSize"       Value="16"/>
    <Setter Property="Cursor"         Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="12"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#90FFFFFF" Offset="0.0"/>
                    <GradientStop Color="#50FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#30FFFFFF" Offset="1.0"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
              <Setter TargetName="Bd" Property="Effect">
                <Setter.Value>
                  <DropShadowEffect Color="Black"
                                    BlurRadius="8"
                                    Opacity="0.2"
                                    ShadowDepth="1"/>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="RenderTransformOrigin" Value="0.5,0.5"/>
              <Setter TargetName="Bd" Property="RenderTransform">
                <Setter.Value>
                  <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
