<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- MODERN GLASS MORPHISM EFFECTS               -->
    <!-- ============================================ -->

    <!-- Glass Background Effect -->
    <SolidColorBrush x:Key="GlassBackground" Color="#33FFFFFF" Opacity="0.15"/>
    <SolidColorBrush x:Key="GlassBackgroundStrong" Color="#55FFFFFF" Opacity="0.25"/>

    <!-- Glass Border Brushes -->
    <LinearGradientBrush x:Key="GlassBorderGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#60FFFFFF" Offset="0.0"/>
        <GradientStop Color="#30FFFFFF" Offset="0.5"/>
        <GradientStop Color="#60FFFFFF" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- Glass Reflection Effect -->
    <LinearGradientBrush x:Key="GlassReflection" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#40FFFFFF" Offset="0.0"/>
        <GradientStop Color="#10FFFFFF" Offset="0.3"/>
        <GradientStop Color="#05FFFFFF" Offset="0.7"/>
        <GradientStop Color="#20FFFFFF" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- Modern Blur Effect -->
    <BlurEffect x:Key="ModernBlur" Radius="40"/>

    <!-- Glass Shadow -->
    <DropShadowEffect x:Key="GlassShadow"
                      Color="#000000"
                      BlurRadius="30"
                      ShadowDepth="10"
                      Opacity="0.3"
                      Direction="270"/>

    <!-- Subtle Glow Effect -->
    <DropShadowEffect x:Key="SubtleGlow"
                      Color="{DynamicResource AccentColor}"
                      BlurRadius="20"
                      ShadowDepth="0"
                      Opacity="0.4"/>

    <!-- Enhanced Card Shadow -->
    <DropShadowEffect x:Key="ModernCardShadow"
                      Color="#000000"
                      BlurRadius="25"
                      ShadowDepth="8"
                      Opacity="0.25"
                      Direction="270"/>

    <!-- ============================================ -->
    <!-- MODERN BUTTON STYLES                        -->
    <!-- ============================================ -->

    <!-- Glass Button Style -->
    <Style x:Key="GlassButtonStyle" TargetType="Button">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#40FFFFFF" Offset="0"/>
                    <GradientStop Color="#20FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderGradient}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{StaticResource ModernCardShadow}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Effect="{TemplateBinding Effect}">
                        <!-- Glass Reflection Overlay -->
                        <Border CornerRadius="12"
                                Background="{StaticResource GlassReflection}"
                                Opacity="0.3"/>
                    
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#50FFFFFF" Offset="0"/>
                                        <GradientStop Color="#30FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource SubtleGlow}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#30FFFFFF" Offset="0"/>
                                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent Glass Button (for primary actions) -->
    <Style x:Key="AccentGlassButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                    <GradientStop Color="{DynamicResource AccentGoldColor}" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Effect" Value="{StaticResource SubtleGlow}"/>
    </Style>

    <!-- ============================================ -->
    <!-- MODERN CARD/PANEL STYLES                    -->
    <!-- ============================================ -->

    <!-- Glass Card Style -->
    <Style x:Key="GlassCardStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#20FFFFFF"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderGradient}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect" Value="{StaticResource ModernCardShadow}"/>
    </Style>

    <!-- Glass Panel with Strong Background -->
    <Style x:Key="GlassPanelStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#30FFFFFF" Offset="0"/>
                    <GradientStop Color="#15FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#30FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderGradient}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Effect" Value="{StaticResource GlassShadow}"/>
    </Style>

    <!-- Frosted Glass Effect (for overlays/modals) -->
    <Style x:Key="FrostedGlassStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#40000000"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#80FFFFFF" Offset="0"/>
                    <GradientStop Color="#40FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- MODERN TEXTBOX STYLE                        -->
    <!-- ============================================ -->

    <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#20FFFFFF"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderGradient}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CaretBrush" Value="{DynamicResource AccentGoldBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#30FFFFFF"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentGoldBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#35FFFFFF"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentGoldBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource SubtleGlow}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- MODERN SCROLLBAR STYLE                      -->
    <!-- ============================================ -->

    <Style x:Key="GlassScrollBarThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="#50FFFFFF"
                            CornerRadius="6"
                            BorderBrush="{StaticResource GlassBorderGradient}"
                            BorderThickness="1"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Background" Value="#10FFFFFF"/>
        <Setter Property="Width" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource GlassScrollBarThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- SIDEBAR BUTTON STYLE (Glass variant)        -->
    <!-- ============================================ -->

    <Style x:Key="SidebarGlassButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#20FFFFFF"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#30FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#40FFFFFF" Offset="0"/>
                                        <GradientStop Color="#30FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentGoldBrush}"/>
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource SubtleGlow}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                        <GradientStop Color="{DynamicResource AccentGoldColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- PROGRESS BAR STYLE (Glass variant)          -->
    <!-- ============================================ -->

    <Style x:Key="GlassProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Background" Value="#20FFFFFF"/>
        <Setter Property="Foreground">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                    <GradientStop Color="{DynamicResource AccentGoldColor}" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            BorderBrush="{StaticResource GlassBorderGradient}"
                            BorderThickness="1">
                        <Border x:Name="PART_Track">
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left">
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource AccentColor}"
                                                      BlurRadius="10"
                                                      ShadowDepth="0"
                                                      Opacity="0.6"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
