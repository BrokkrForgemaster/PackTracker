# ── Database ─────────────────────────────────────────────────────────────────
# Full ADO.NET / Npgsql connection string.
# Neon example:   Host=<host>;Port=5432;Database=neondb;Username=<user>;Password=<pass>;SSL Mode=Require;Trust Server Certificate=true
# Local Postgres: Host=packtracker-postgres;Port=5432;Database=packtracker;Username=packtracker;Password=<pass>;SSL Mode=Disable
DB_CONNECTION_STRING=

# If running a local Postgres container (see docker-compose.yml packtracker-postgres service)
POSTGRES_PASSWORD=changeme_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_KEY=replace_with_your_base64_secret

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# From https://discord.com/developers/applications → your app → OAuth2
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_app_client_secret
# Your Discord server (guild) ID
DISCORD_GUILD_ID=your_discord_server_id

# ── Optional ─────────────────────────────────────────────────────────────────
# UEX Corp API key (leave blank if not using)
UEX_API_KEY=

# Host port the API is exposed on (default: 5199)
API_PORT=5199
