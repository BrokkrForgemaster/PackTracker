# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Strong password for the local Postgres container
POSTGRES_PASSWORD=changeme_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_KEY=replace_with_your_base64_secret

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# From https://discord.com/developers/applications → your app → OAuth2
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_app_client_secret
# Your Discord server (guild) ID
DISCORD_GUILD_ID=your_discord_server_id

# ── Optional ─────────────────────────────────────────────────────────────────
# UEX Corp API key (leave blank if not using)
UEX_API_KEY=

# Host port the API is exposed on (default: 5199)
API_PORT=5199
