<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PackTracker.Mobile.Pages.ProcurementQueuePage"
             Title="Procurement">
    <Grid RowDefinitions="Auto,*">

        <VerticalStackLayout Grid.Row="0" Padding="16,16,16,0" Spacing="0">
            <Border Style="{StaticResource PageHeaderBorderStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="PROCUREMENT CENTER"
                               Style="{StaticResource PageTitleStyle}" />
                        <Label Text="Sourcing raw materials and commodities to fulfil crafting and org needs."
                               Style="{StaticResource PageSubtitleStyle}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="REFRESH"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalOptions="Center"
                            Margin="12,0,0,0"
                            Clicked="RefreshButton_Clicked" />
                </Grid>
            </Border>
            <Label x:Name="StatusLabel"
                   Text=""
                   Style="{StaticResource MutedLabelStyle}"
                   Margin="4,0,4,8" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" Padding="16,0,16,16">
            <CollectionView x:Name="ProcurementView" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No procurement requests in the queue."
                           Style="{StaticResource MutedLabelStyle}"
                           Padding="0,8" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ItemCardStyle}" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="4,*">
                                <BoxView Grid.Column="0"
                                         BackgroundColor="{StaticResource PriorityAmber}"
                                         CornerRadius="8,0,0,8" />
                                <VerticalStackLayout Grid.Column="1" Padding="12,10" Spacing="4">
                                    <Label Text="{Binding Title}"
                                           Style="{StaticResource BodyLabelStyle}"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding Summary}"
                                           Style="{StaticResource SecondaryLabelStyle}" />
                                    <Label Text="{Binding Notes}"
                                           Style="{StaticResource MutedLabelStyle}"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

    </Grid>
</ContentPage>
