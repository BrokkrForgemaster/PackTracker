<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PackTracker.Mobile.Pages.ProfilePage"
             Title="Profile">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <Border Style="{StaticResource PageHeaderBorderStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="PROFILE DOSSIER"
                               Style="{StaticResource PageTitleStyle}" />
                        <Label Text="Your House Wolf identity, rank, and service record."
                               Style="{StaticResource PageSubtitleStyle}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1"
                           x:Name="StatusLabel"
                           Text=""
                           Style="{StaticResource AccentLabelStyle}"
                           VerticalOptions="Start"
                           Margin="12,4,0,0" />
                </Grid>
            </Border>

            <!-- Character card -->
            <Border BackgroundColor="{StaticResource OpBgPanel}"
                    Stroke="{StaticResource OpBorderPanel}"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 16"
                    Padding="20"
                    Margin="0,0,0,12">
                <VerticalStackLayout Spacing="12">
                    <Label Text="CHARACTER PROFILE"
                           Style="{StaticResource SectionHeaderStyle}" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <!-- Avatar placeholder -->
                        <BoxView Grid.Column="0"
                                 WidthRequest="64"
                                 HeightRequest="64"
                                 CornerRadius="32"
                                 BackgroundColor="{StaticResource OpBgItem}"
                                 VerticalOptions="Start" />

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label x:Name="NameLabel"
                                   Text="&#x2014;"
                                   Style="{StaticResource AccentLabelStyle}"
                                   FontAttributes="Bold"
                                   FontSize="18" />
                            <Label x:Name="RankLabel"
                                   Text="&#x2014;"
                                   Style="{StaticResource SecondaryLabelStyle}" />
                            <Label x:Name="DivisionLabel"
                                   Text="&#x2014;"
                                   Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource OpBorderPanel}" />

                    <Label Text="BIO"
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0" />
                    <Label x:Name="BioLabel"
                           Text="&#x2014;"
                           Style="{StaticResource SecondaryLabelStyle}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="24" BackgroundColor="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
