<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PackTracker.Mobile.Pages.LoginPage"
             Title="PackTracker">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
            <Label Text="PackTracker"
                   Style="{StaticResource TitleLabelStyle}"
                   HorizontalOptions="Center" />
            <Label Text="House Wolf Operations Center"
                   Style="{StaticResource MutedLabelStyle}"
                   HorizontalOptions="Center" />
            <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,8" />
            <Label Text="Sign in with your Discord account to continue."
                   Style="{StaticResource BodyLabelStyle}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
            <Button Text="LOGIN WITH DISCORD"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Clicked="LoginButton_Clicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
