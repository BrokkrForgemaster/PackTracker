<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);CA1031;CA1034;CA1062;CA1305;CA1307;CA1308;CA1515;CA1707;CA1812;CA1848;CA1849;CA1852;CA1862;CA1869;CA2000;CA2007</NoWarn>
