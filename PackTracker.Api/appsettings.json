{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Uex": {
    "ApiBaseUrl": "https://api.uexcorp.uk/2.0",
    "ApiKey": ""
  },
  "Api": {
    "BaseUrl": "https://packtracker-yke3.onrender.com"
  },
  "AppSettings": {
    "ApiBaseUrl": "https://packtracker-yke3.onrender.com"
  },
  "Authentication": {
    "Jwt": {
      "Key": "",
      "Issuer": "PackTracker",
      "Audience": "PackTrackerClients",
      "ExpiresInMinutes": 60,
      "RefreshTokenDays": 30
    },
    "Discord": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-discord",
      "RequiredGuildId": ""
    }
  },
  "Updates": {
    "GitHubOwner": "BrokkrForgemaster",
    "GitHubRepository": "PackTracker",
    "AllowedAssetExtensions": [ ".exe", ".msi", ".zip" ],
    "UserAgent": "PackTracker-Updater",
    "RestartExecutableName": "PackTracker.Presentation.exe"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "CorrelationId": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/packTracker-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] ({SourceContext}) {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  }
}
